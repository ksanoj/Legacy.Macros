|--- The Nest Vishimtar

Sub VishDeathTouch
	/if (!${bossmods}) /return
	/multiline ; /stick off ; /attack off ; /pet back off ; /stand ; /stopcast ; /afollow off

	:vdtstart
	/target Mournful Spirit
		/delay 5
	/if (${Target.DisplayName.NotEqual[Mournful Spirit]}) /goto :vdtstart
	/if (${Target.DisplayName.Equal[Mournful Spirit]}) /nav target
		/delay 5
	/if (${Target.DisplayName.NotEqual[Mournful Spirit]}) /goto :vdtstart
	/if (${Target.Distance}>=50) /goto :vdtstart
		/say Shoulder My Burden
		/delay 5
	/if (${Me.Buff[Creeping Doom].Duration}>10) /goto :vdtstart
	
	:vdtreturn
	/target Vishimtar
		/delay 5
	/if (${Target.DisplayName.NotEqual[Vishimtar the Fallen]}) /goto :vdtreturn
	/if (${Target.DisplayName.Equal[Vishimtar the Fallen]}) /nav target
		/if (${Me.Buff[Creeping Doom].Duration}>10) /goto :vdtstart
		/delay 5
	/if (${Target.DisplayName.NotEqual[Vishimtar the Fallen]}) /goto :vdtreturn
	/if (${Target.Distance}>=55) /goto :vdtreturn
		/delay 5
	/if (${Me.Buff[Creeping Doom].Duration}>10) /goto :vdtstart
	/if (${Navigation.Active}) /nav stop
/return

|------- Demiplane Hatchet the Torturer

Sub Event_HatchetDuck
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote - Ducking
		/varset hatchetemote TRUE
		/varset hatchetduck TRUE
		/multiline ; /stopcast ; /attack off ; /stick off
		/if (${Me.Sitting}) /stand
		/if (!${Me.Ducking}) /keypress X
		/delay 10
/return

Sub Event_HatchetAway
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote - Running Away from Hatchet
		/varset hatchetemote TRUE
		/varset hatchetaway TRUE
		/multiline ; /stopcast ; /attack off ; /stick off
		/nav loc 2930 345 -63
		/delay 10
/return

Sub Event_HatchetClose
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote - Running to Hatchet
		/stick off
		/varset hatchetemote TRUE
		/varset hatchetclose TRUE
		:recheckhatchet
		/target Hatchet
		/delay 5
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :recheckhatchet
		/if (${Target.DisplayName.Equal[Hatchet the Torturer]}) /nav target
			/delay 10
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :recheckhatchet
		/if (${Target.Distance}>=10) /goto :recheckhatchet
		/delay 5
/return

Sub Event_HatchetKite
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote - Charge + Suicide
		/multiline ; /stopcast ; /attack off ; /stick off
		/varset hatchetsafe FALSE
		/varset hatchetemote TRUE
		/varset hatchetkite TRUE
		/nav loc 3090 345 -63
		/delay 10
/return

Sub Event_HatchetSafe
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote - Charge! Getting Safe!
		/if (${Me.Class.Name.Equal[Warrior]}) /return
		/if (${Me.Class.Name.Equal[Shadow Knight]}) /return
		/if (${Me.Class.Name.Equal[Paladin]}) /return
			/echo BOSSMODS: Emote - Charge! Getting Safe!
			/multiline ; /stick off ; /attack off ; /pet back off
			/varset hatchetemote TRUE
			/varset hatchetsafe TRUE
			/nav loc 2940 400 -63
			/delay 10
/return

Sub Event_HatchetReturn
	/if (!${bossmods}) /return
		/echo BOSSMODS: Emote Successful - Returning to Hatchet!
		/varset hatchetemote FALSE
		/varset hatchetaway FALSE
		/varset hatchetclose FALSE
		/varset hatchetduck FALSE
		/varset hatchetsafe FALSE
		
		:recheckduck
		/delay 5
		/if (${Me.Ducking}) /stand
		/if (${Me.Ducking}) /goto :recheckduck
		
		:returnhatchet
		/target Hatchet
		/delay 5
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :returnhatchet
		/if (${Target.DisplayName.Equal[Hatchet the Torturer]}) /nav target
			/delay 15
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :returnhatchet
		/if (${Target.Distance}>=25) /goto :returnhatchet
		/delay 5
		/if (${Navigation.Active}) /nav stop
/return

Sub Event_HatchetResume
	/if (!${bossmods}) /return
	/if (${hatchetkite} || ${hatchetduck} || ${hatchetclose} || ${hatchetaway}) /return
		/if (${Me.Class.Name.Equal[Warrior]}) /return
		/if (${Me.Class.Name.Equal[Shadow Knight]}) /return
		/if (${Me.Class.Name.Equal[Paladin]}) /return
			/echo BOSSMODS: Returning to Hatchet!		
			/multiline ; /stick off ; /attack off ; /pet back off
			/varset hatchetemote FALSE
			/varset hatchetsafe FALSE
		:recheckhatchetfour
		/target Hatchet
		/delay 5
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :recheckhatchetfour
		/if (${Target.DisplayName.Equal[Hatchet the Torturer]}) /nav target
			/delay 15
		/if (${Target.DisplayName.NotEqual[Hatchet the Torturer]}) /goto :recheckhatchetfour
		/if (${Target.Distance}>=30) /goto :recheckhatchetfour
		/delay 5
		/if (${Navigation.Active}) /nav stop
/return

