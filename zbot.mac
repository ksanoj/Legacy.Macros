	/declare sitmedtwist bool outer FALSE

	/declare summontimer timer outer
	
	/declare groupleadercount int outer 0
	/declare partycount int outer 0
	/declare groupleader[12] string outer NULL
	/declare party[72] string outer NULL
	/declare doraid bool outer TRUE
	/declare raidset string outer RaidSetup
	/declare raidleader string outer PICKME
	/declare groupsendercount int outer 0
	/declare groupsender[10] string outer NULL
	/declare groupbuffercount int outer 0
	/declare groupbuffer[10] string outer NULL
	/declare singlebuffcount int outer 0
	/declare sender[20] string outer NULL
	/declare buffer[20] string outer NULL
	/declare alias[20] string outer NULL
	/declare offcount int outer 0
	/declare off[20] string outer
	/declare mainassist string outer NULL
	/declare percent int outer 98
	
	/if (!${Ini[${Me.Name}Settings.ini,General,Version].Length}) /ini "${Me.Name}Settings.ini" "General" "Version" "0.0" 
	/if (${Ini[${Me.Name}Settings.ini,General,Version].NotEqual[${zbotversion}]}) {
		/call SetIni General version ${zbotversion}
	}

	/call LoadIni Heal active dohealing

	/call LoadIni General taunt ztaunt
	/call LoadIni General bossmods bossmods
	/call LoadIni General driver driver
	/call LoadIni General curef curef
	/call LoadIni General focusbeneficial focusbeni
	/call LoadIni General focusdetrimental focusdetr
	/call LoadIni General fdstand fdstand
	/call LoadIni General bcspam bcspam
	/call LoadIni General bctell bctell
	/call LoadIni General bclist bclist
	/call LoadIni General autorez autorez
	/call LoadIni General forage forage
	/call LoadIni General bosslevel bosslevel
	/call LoadIni General attackwindow idleuser
	/call LoadIni General announce temp
	/call LoadIni General taskupdate temp
	/call LoadIni General sitmed sitmed
	/call LoadIni General sitmedrange sitmedrange
	/call LoadIni General sitmedsong sitmedsong
	/call LoadIni General autohide autohide
	/call LoadIni General autoevade autoevade
	/call LoadIni General autoyaulp autoyaulp
	/call LoadIni General yaulpspell yaulpspell
	/call LoadIni General yaulppct yaulppct
	/call LoadIni General autoharvest autoharvest
	/call LoadIni General harvestspell harvestspell
	/call LoadIni General harvestpct harvestpct
	/call LoadIni General harvestwait harvestwait
	/call LoadIni General autocanni autocanni
	/call LoadIni General cannispell cannispell
	/call LoadIni General cannipct cannipct
	/call LoadIni General smallcannihp smallcannihp
	/call LoadIni General bigcannipct bigcannipct
	/call LoadIni General bigcannihp bigcannihp
	/call LoadIni General portauth1 portauth1
	/call LoadIni General portauth2 portauth2
	
	/call LoadIni General leashholder leashholder
	/call LoadIni General leashlength leashlength
	/call LoadIni General leashslop leashslop

	/call LoadIni Melee active domelee
	/call LoadIni Melee stick dostick
	/call LoadIni Melee stickoption stickoption
	/call LoadIni Melee stopfighthealth stopfighthealth
	/call LoadIni Melee targetswitch dotargetswitch
	|/call LoadIni Melee rangetarget rngtarget
	|/call LoadIni Melee rangetank rngtank
	/call LoadIni Melee range meleerange
	/call LoadIni Melee dynamic dodynamicclose
	/call LoadIni Melee enrage doenrage
	/call LoadIni Melee bsmainhand bsmainhand
	/call LoadIni Melee bsoffhand bsoffhand
	/call LoadIni Melee strikedisc strikedisc
	/call LoadIni Melee strikeendur strikeendur
	
	/call LoadIni Melee avatarmode avatarmode
	/call LoadIni Melee avatarweaponid avatarweaponid
	/call LoadIni Melee normaloffhandid normaloffhandid

	/call LoadIni Melee rangeitem tempstr
	/if (${tempstr.Length}) /varset rangeitem ${FindItem[=${tempstr}].ID}
	/call LoadIni Melee rangedist rangedist
	
	/for i 1 to 50
		/if (${Ini[${Me.Name}Settings.ini,Spells,spell${i}].Length}) {
			/varset spellsid[${i}] ${Spell[${Ini[${Me.Name}Settings.ini,Spells,spell${i}]}].ID}
			/if (!${spellsid[${i}]}) /echo ERROR: Unknown Spell ${Ini[${Me.Name}Settings.ini,Spells,spell${i}]} in [Spells].
			/varset spellsband[${i}] ${Ini[${Me.Name}Settings.ini,Spells,band${i}]}
		}
	/next i
	
	/echo ===================================================
	/popup ZBot (ver ${zbotversion}) ... Ready!

	/if (${driver}) /call LoadDriverSettings
	/if (!${driver}) /echo MODE: Bot
	/if (${dohealing}) /multiline ; /echo INFO: Heals are ON! ; /call HealingIni
	/call AssistIni
	/call CureIni
	/call BuffingIni
	/call EventIni
	/call DebuffIni
	/call NukeIni
	/call DotIni
	/call MezIni
	/call PetIni
	/call ModRodIni
	/call GearIni
	/call ClickyIni
	/if (${Ini[${Me.Name}Settings.ini,General,announce]}) /squelch /announce on
	
	/if (${Navigation.Active}) {
		/nav stop
		/keypress W
	}

	|--- Forever Loop Start
	:foreverloop
	/delay 5
	
	/if (${EverQuest.GameState.Equal[CHARSELECT]}) /endmac
	/if (${Zone.ID}!=${lastzone}) /call JustZoned
	
	/if (${debug}==1) /echo DEBUG: Before /doevents
	/doevents
	/if (${debug}==1) /echo DEBUG: After /doevents
	
	/if (${turedanger}) {
		/call Event_TureBackOut
		/goto :foreverloop
		}
		
	/if (${mayongdanger}) {
		/call Event_MayongBackOut
		/goto :foreverloop
		}
		
	/if (${trisemote}) {
		/call Event_TrisFaceAway
		/goto :foreverloop
		}
		
	/if (${hatchetemote}) {
		/if (${hatchetkite}) /call Event_HatchetKite
		/if (${hatchetsafe}) /call Event_HatchetSafe
		/if (${hatchetduck}) /call Event_HatchetDuck
		/if (${hatchetclose}) /call Event_HatchetClose
		/if (${hatchetaway}) /call Event_HatchetAway
		/goto :foreverloop
	}
	
	/if (${Target.DisplayName.Equal[Adrianna]} && ${Me.Combat} && ${Me.PctHPs}<=75) {
		/call Event_AdriannaHP
		/goto :foreverloop
	}
		
	/if (${paused})	/goto :foreverloop
	
	/if (${fdstand} && ${Me.State.Equal[Feign]}) {
		/stand
		/if (${Me.Class.Name.Equal[Warrior]}) /attack on
	}
	
	:checkrez
	/if (${Window[RespawnWnd].Open}) {
|		/varset paused TRUE
|		/varset bufftimer 9999m
		/call AutoRezTwo
		/goto :foreverloop
	}
	
	/if (${Me.Stunned} || ${Me.Ducking} || ${Me.State.Equal[BIND]} || (!${bard} && ${Cast.Status.NotEqual[I]})) /goto :foreverloop

	/if (${spellbookopen}) {
		/if (!${spellbooktimer}) {
			/if (${Window[SpellBookWnd]}) /keypress ctrl+b
			/varset spellbookopen FALSE
		}
	} else {
		/if (${Window[SpellBookWnd]}) {
			/varset spellbookopen TRUE
			/varset spellbooktimer 30s
		}
	}

	/if (${Window[MerchantWnd]} || ${Window[TradeWnd]} || ${Window[GiveWnd]} || ${Window[LootWnd]} || ${Window[SpellBookWnd]} || ${Window[BigBankWnd]} || ${Window[LootWnd]} || ${Window[BankWnd]} || ${Window[TributeMasterWnd]} || ${Window[GuildTributeMasterWnd]}) {
		/delay 2
		/goto :foreverloop 
	} 
	/if (!${bard} && ${Window[CastingWindow]}) {
		/delay 2
		/goto :foreverloop
	}
	
	/if (${doscan}) {
		/call DoScan
	}
	
	/if (${Me.Buff[Creeping Doom].Duration}>10) { 
		/if (${Me.Class.Name.Equal[Warrior]}) /goto :skipvishdt
		/if (${Me.Class.Name.Equal[Shadow Knight]}) /goto :skipvishdt
		/if (${Me.Class.Name.Equal[Paladin]}) /goto :skipvishdt
		/call VishDeathTouch
		:skipvishdt
	}
	
	/if (${Me.Combat} && ${ztaunt} && ${Me.TargetOfTarget.ID}!=${Me.ID} && ${Me.AbilityReady[Taunt]}) {
		/doability Taunt
	}
	
	/if (${Me.Class.Name.Equal[Warrior]} && !${Me.Song[Commanding Voice].ID} && ${Me.Combat}) {
		/disc Commanding Voice
	}

	/if (${Me.Moving}) /multiline ; /varset idle1 1m;/varset idle5 5m
	/if (${bard} && ${Me.Standing} && !${Me.Invis} && ${sitmedtwist}) /multiline ; /squelch /twist start ; /varset sitmedtwist FALSE

	/if (${bufflev}) /call BuffLev

	/if (!${justzoned}) {
		/varset debuffsdone TRUE
		/call ResistClear
		/call SpecialZone
		/if (${Macro.Return}) /goto :foreverloop
		/if (${domez}) /call DoMez
		/if (${feedperc}) /call FeedCheck
		/if (${Me.Pet.ID}) /call ManagePet
		/call DoModRod
		/if (${docures} && ${curetotal}) /call CheckCures
		/if (${curesomeone}) /call CureSomeone
		/if (${dohealing}) {
			/call DoHealing
			/if (${Macro.Return}) /goto :checkmelee
		}
		/if (${battlerez}) /call BattleRez
		/call DoClassStuff
		/if (${doevents} || ${dotrigger}) /call DoEvents
		/if (${dodebuffs}) {
			/call DoDebuffs
			/if (${Macro.Return}) /goto :checkmelee
		}
		/if (${debuffsdone}) {
			/if (${clickycount}) {
				/call DoClicky
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${doautopet}) {
				/call DoPetStuff
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${buffgom.NotEqual[NULL]} && ${Me.SpellReady[${buffgom}]} && ${Me.Song[Gift of Mana].ID}) {
				/if (${Me.PctMana}<10 || ${Me.Buff[${buffgom}].Duration}>10000 || ${Me.Song[${buffgom}].Duration}>10000) /goto :skipbuffgom
				/call DoBuffGom
				/if (${Macro.Return}) /call DoHealing
				:skipbuffgom
			}
			/if	(${doattackbuff}) {
				/call DoAttackBuff
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${donukes} && !${dpspaused}) {
				/call DoNukes
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${dodots} || ${dodebuffs} && !${dpspaused}) {
				/call DoDots
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${dobuffs} && !${bufftimer} && (${buffcount} || ${bufftarget[1]})) {
				/call DoBuffs
				/if (${Macro.Return}) /goto :checkmelee
			}
			/if (${blockcount}) /call DoBuffs
			/call DoSitMed
			/if (${dogear}) /call CheckGear
			/if (!${summontimer}) /call DoSummonItems FALSE 0
			/if (!${watchtimer}) /call WatchMobs
		}
	}

	:checkmelee
	/delay 1
	/if (${driver}) /goto :leashstart
	/doevents
	/call ValidateTarget
	/if (${validtarget}) {
		/if (${Target.PctHPs}<100) /multiline ; /varset idle ${idleuser};/varset idle1 1m;/varset idle5 5m
	} else {
		/if (${Target.ID} && ${Target.Type.Equal[PC]} && ${Me.TargetOfTarget.Type.Equal[NPC]} && ${Me.TargetOfTarget.PctHPs}<100) /multiline ; /varset idle ${idleuser};/varset idle1 1m;/varset idle5 5m
		/if (${Stick.Active}) /squelch /stick off
		/if (${enraged}) /varset enraged FALSE
	}

	/if (${dodisarm} && !${Me.CombatAbilityTimer[Disarm Traps]}) {
		/for i 1 to 10
			/if (!${disarmlist.Token[${i},|].Length}) /goto :nodisarm
			/if (${SpawnCount[${disarmlist.Token[${i},|]} radius ${disarmrng} zradius 30]}) {
				/target ID ${Spawn[${disarmlist.Token[${i},|]} radius ${disarmrng} zradius 30].ID}
				:disarmagain
				/if (${Window[RespawnWnd].Open}) /goto :foreverloop
				/if (${Me.Combat}) /attack off
				/if (${Target.Distance}<=20) {
					/docommand /disc Disarm Traps
					/goto :foreverloop
				} else {
					/face fast nolook
					/keypress forward hold 
					/delay 2s ${Target.Distance}<20
					/keypress forward
				}
				/goto :foreverloop
			}
		/next i
		:nodisarm
	}

	/if (${Me.Combat}) { 
		/varset leashtimer 9999s
		/varset strikeready 9999m

		/if (${dpspaused} && ${domelee}) {
			/if (${Stick.Active}) /squelch /stick off
			/squelch /attack off
			/goto :foreverloop
		}
		
		/if (${dostick}) {
			/if (${Stick.Active}) {
				/if (${Me.TargetOfTarget.ID}==${Me.ID}) /squelch /stick off
			} else /if (${validtarget} && ${Target.Distance}<=${rngtarget} && ${Spawn[pc ${assistcur}].Distance}<=${rngtank}) {
				/if (${Me.TargetOfTarget.ID}!=${Me.ID}) {
					/squelch /stick ${stickoption} ${meleerange}
				} else {
					/squelch /stick ${stickoption} ${meleerange}
				}
			}
		}

		/if (${domelee}) {
			/if (!${validtarget} || ${Me.PctHPs}<=${stopfighthealth} || ${Target.PctHPs}<=${stoppct}) {
				/attack off
				/if (${Stick.Active}) /squelch /stick off
				/goto :foreverloop
			}
			/if (${enraged} && ${doenrage}) {
				/call CheckBehind
				/if (!${Macro.Return}) {
					/attack off
					/if (${Stick.Active}) /squelch /stick off
					/goto :foreverloop
				}
			}
		}

		/if (${Me.Class.Name.Equal[rogue]} && !${bstimer}) {
			/call CheckBehind 
			/if (${autobs} && ${Me.AbilityReady[backstab]} && ${Macro.Return} && ${Target.Distance}<${Math.Calc[${Target.MaxRangeTo}*150/100]}) {
				/call FancyBS
			} else /if (${autoevade} && ${Me.AbilityReady[hide]} && (!${Me.Moving} || ${Me.AltAbilityReady[Nimble Evasion]})) {
				/attack off 
				/delay 1 !${Me.Combat}
				/doability hide
				/attack on 
			}
		}

		/if (${dofocus}) {
			/for i 1 to 10
				/if (!${focuslist.Token[${i},|].Length}) /goto :checkfocus
				/if (${Target.CleanName.Find[${focuslist.Token[${i},|]}]}) /goto :notargetswitch
			/next i
			:checkfocus
			/for i 1 to 10
				/if (!${focuslist.Token[${i},|].Length}) /goto :foundfocus			
				/if (${SpawnCount[npc ${focuslist.Token[${i},|]} radius ${focusrng} zradius 30]}) {
					/target ID ${Spawn[npc ${focuslist.Token[${i},|]} radius ${focusrng} zradius 30].ID}
					/if (${domelee} && !${Me.Combat}) /attack on
					/goto :notargetswitch
				}
			/next i
			:foundfocus
		}

		/if (${dotargetswitch} && ${doautoassist} && !${assistcheck}) {			
			/varset oldtarget ${Target.ID}
			/call FindAssist
			/if (${assistcur.Length}) {
				/assist ${assistcur} 
				/delay 2
				/if (${Target.ID}!=${oldtarget}) {
					/if (${Stick.Active}) /squelch /stick off
					/attack off
					/goto :foreverloop 
				}
			}
		} 
		:notargetswitch

		/if (${leashholder.NotEqual[Nobody]} && !${Spawn[${leashholder}].ID}) /varset doleash FALSE
		/if (${doleash} && ${Zone.ID}==${lastzone}) { 
			/if (${leashholder.NotEqual[Nobody]} && ${Spawn[pc ${leashholder}].ID}) {
				/varset stakeY ${Spawn[pc ${leashholder}].Y}
				/varset stakeX ${Spawn[pc ${leashholder}].X}
			}
			/if (${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}>${leashlength}) { 
				/varset assistcheck 30
				/attack off
				/squelch /stick off 
				/if (${Me.Pet.ID}) {
					/pet back off
					/varset petcombat FALSE
				}
				/face nolook loc ${stakeY},${stakeX} 
				/keypress forward hold 
				/delay 1s ${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}<${leashslop}
				/keypress forward          
				/goto :foreverloop 
			} 
		} 
	} else {
		/if (${dofocus}) {
			/for i 1 to 10
				/if (!${focuslist.Token[${i},|].Length}) /goto :nofocus2
				/if (${SpawnCount[npc ${focuslist.Token[${i},|]} radius ${focusrng} zradius 30]}) {
					/target ID ${Spawn[npc ${focuslist.Token[${i},|]} radius ${focusrng} zradius 30].ID}
					/if (${domelee} && !${Me.Combat}) /attack on
					/goto :foreverloop
				}
			/next i
			:nofocus2
		}
		/if (${domelee} && !${autofire} && ${enraged} && ${validtarget}) { 
			/call CheckBehind 
			/if (${Target.ID} && ${Marco.Return}) { 
				/if (${Me.Sitting}) /stand
				/attack on
				/goto :foreverloop
			}  
		}

		/if (${Me.AutoFire}) {
			/if (!${InvSlot[ammo].Item.ID} && !${summontimer}) /call DoSummonItems FALSE 0
			/if (!${dotargetswitch}) /goto :foreverloop
		}

		/if (${doautoassist} && !${assistcheck} && !${enraged} && !${dpspaused} && (!${Me.Casting.ID} || ${bard})) {
			/call FindAssist
			/if (!${assistcur.Length}) /goto :skipassist
			/assist ${assistcur}
			/delay 1
			/call ValidateTarget
			/if (!${validtarget}) /goto :skipassist

			/varset assistcheck 5
			/if (${Target.ID}!=${mezmainid}) {
				/varset mezmainid ${Target.ID}
				/varset mezmaindly 999m
			}

			/if (${doautofire} && ${Target.PctHPs}<=${assistpct} && ${Target.PctHPs}>=${stoppct}) {
				/squelch /face nolook
				/if (${Me.Sitting}) /stand
				/if (!${Me.AutoFire}) /autofire
				/if (!${Stick.Active} && ${Target.Distance}<=30) /stick moveback 35
				/goto :foreverloop
			}

			/if (${domelee} && ${Target.PctHPs}<=${assistpct} && ${Target.PctHPs}>=${stoppct}) { 
				/if (${Me.Sitting}) /stand
				/attack on
				/if (${dostick}) {
					/if (${Stick.Active}) {
						/if (${Me.TargetOfTarget.ID}==${Me.ID}) /squelch /stick off
					} else /if (${validtarget} && ${Target.Distance}<=${rngtarget} && ${Spawn[pc ${assistcur}].Distance}<=${rngtank}) {
						/if (${Me.TargetOfTarget.ID}!=${Me.ID}) {
							/squelch /stick ${stickoption} ${meleerange}
						} else {
							/squelch /stick ${stickoption} ${meleerange}
						}
					}
				}
				/goto :foreverloop      
			}
		} 
		:skipassist 

		:leashstart
		/if (${doscan}) {
			/if (${scantimer}>5) {
|				/echo ForeverLooping
				/goto :foreverloop
				/call DoScan
				} else {
|				/echo Setting Scan Timer (continue to Leash)
				/varset scantimer 30
				/call DoScan
		}
		}
		/delay 1
		/doevents
		/if (${leashtimer}>30) /varset leashtimer 30
|		/if (${leashholder.NotEqual[NULL]} && !${Spawn[${leashholder}].ID}) /varset doleash FALSE
		/if (${Window[RespawnWnd].Open}) /goto :foreverloop
		/if (${doleash} && !${leashtimer} && ${Zone.ID}==${lastzone}) { 
			/if (${Me.Combat} || ${paused}) /goto :foreverloop

			/if (${leashholder.NotEqual[NULL]} && ${Spawn[pc ${leashholder}].ID}) {
				/varset stakeY ${Spawn[pc ${leashholder}].Y}
				/varset stakeX ${Spawn[pc ${leashholder}].X}
			}
			/if (${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}>${leashslop}) { 
				/if (${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}>1000) {
					/echo INFO: Exceeded Leash Length, Disabled Leash!
					/varset doleash FALSE 
					/goto :foreverloop
				}
				/if (${Me.Sitting}) /stand
				/if (!${Me.Running}) /keypress ctrl+r 
				/face nolook loc ${stakeY},${stakeX} 
				/keypress forward hold 
				/delay 10 ${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}<${leashslop}
				/keypress forward
				/if (${idle} && ${SpawnCount[npc radius ${leashlength} zradius 50]}) /goto :foreverloop
				/if (${Math.Distance[${Me.Y},${Me.X}:${stakeY},${stakeX}]}>${leashslop}) {
					/doevents
					/goto :leashstart
				}
			}
		}

		/if (${autopull}) {
			/varset oldtarget ${Target.ID}
			/for i 1 to 20
				/if (${NearestSpawn[${i},npc radius ${autopull} zradius 30].LineOfSight}) {
					/varset oldtarget ${NearestSpawn[${i}, npc radius ${autopull} zradius 30].ID}
					/goto :foundpull
				}
			/next i
			/goto :foreverloop
			:foundpull
			/if (${oldtarget} && !${Target.ID} || ${Target.Type.NotEqual[NPC]} || ${Target.Distance}>${autopull} || ${Target.ID}!=${oldtarget}) {
				/if (${Me.Sitting}) /stand
				/target ID ${oldtarget}
				/squelch /face nolook
				/delay 5 ${Target.ID}==${oldtarget}
				/varset i ${InvSlot[ranged].Item.ID}
|				/if (${rangeitem}) /exchange ${rangeitem} ranged
				/range
|				/exchange ${i} ranged
				/goto :foreverloop
			} else /if (${Target.ID} && ${Target.Type.Equal[NPC]}) {
				/if (${Target.Distance}>${autopull} || !${Target.LineOfSight}) {
					/target clear
				} else /if (${Target.Distance}<50) {
					/if (${Me.Sitting}) /stand
					/attack on
				} else /if (${Target.Distance}<100 && !${Me.CombatAbilityTimer[Sneer]}) {
					/docommand /disc Incite
				} else /if (${Target.Distance}<=${autopull}) {
					/if (${Me.Sitting}) /stand
					/squelch /face nolook
					/varset i ${InvSlot[ranged].Item.ID}
|					/if (${rangeitem}) /exchange ${rangeitem} ranged
					/range
|					/exchange ${i} ranged
				}
			}
		}
	}
	/goto :foreverloop 
/return

Sub ValidateTarget
	/varset validtarget FALSE
	/if (!${Target.ID} || ${Target.ID}==${ignoreid}) /return
	/if (${Select[${Target.Type},PC,CORPSE,CHEST,TRIGGER,TRAP,TIMER,ITEM,MOUNT,MERCENARY]}) /return
	/if (${Target.Type.Equal[Pet]} && ${Target.Master.ID}==${Me.ID}) /return
	/varset validtarget TRUE
/return

Sub FancyBS
	/varset currentmain ${InvSlot[mainhand].Item.ID}
	/varset currentoff ${InvSlot[offhand].Item.ID}
	/if (${bsmainhand}==${currentoff} && ${bsoffhand}==${currentmain}) {
		/if (${InvSlot[offhand].Item.ID}) /unequip offhand
		/if (${bsmainhand}) /exchange ${bsmainhand} mainhand
		/if (${bsoffhand}) /exchange ${bsoffhand} offhand
		/doability backstab
		/delay 3
		/unequip offhand
		/if (${currentmain}) /exchange ${currentmain} mainhand
		/if (${currentoff}) /exchange ${currentoff} offhand
	} else {
		/if (${bsmainhand}==${currentoff}) /exchange ${bsoffhand} offhand
		/if (${bsmainhand} && ${currentmain}!=${bsmainhand}) /exchange ${bsmainhand} mainhand
		/if (${bsoffhand} && ${currentoff}!=${bsoffhand}) /exchange ${bsoffhand} offhand
		/doability backstab
		/delay 3
		/if (${currentmain}!=${InvSlot[mainhand].Item.ID}) /exchange ${currentmain} mainhand
		/if (${currentoff}!=${InvSlot[offhand].Item.ID}) /exchange ${currentoff} offhand
	}
/return

Sub SaveState
	/varset oldtarget ${Target.ID}
	/if (${Stick.Active}) /squelch /stick off
/return

Sub RestoreState
	/if (${oldtarget} && ${Target.ID}!=${oldtarget} && ${Spawn[${oldtarget}].ID}) /target id ${oldtarget}
/return

Sub JustZoned
	/varset justzoned 5s
	/varset lastzone ${Zone.ID} 
	/varset doleash FALSE 
	/varset oldtarget 0
	/varset idle 0
	/varset idle1 1m
	/varset idle5 5m
	/varset debufflist
	/varset petminsize 0.0
	/varset doautofire FALSE
	/varset ignoreid 999999
	/varset autopull 0
	/varset domez FALSE
	/varset debuffAE FALSE
	/varset doscan FALSE
	/varset mezonly
	/varset debuffonly
	/varset dofocus FALSE
	/varset dodisarm FALSE
	/if (${battlerez}) /call BattleRezClear
	/if (${Defined[healae]}) /varset healae 0
	/if (${Me.Pet.ID}) /call DoPetGHold

	/varset curesomeone FALSE
	/call LoadCures
	/call ResetVars

	/if (!${Me.Running}) /keypress ctrl+r 
	/if (${driver}) /varset justzoned 1s
/return

sub ResetVars
	/declare i int
	
	/for i 1 to MAXDOTS
		/varset dotinuse[${i}] FALSE
	/next i
	/for i 1 to 10
		/varset feedlist[${i}] 0
		/varset feedcount[${i}] 0
	/next i
/return

Sub HealingIni
	/if (!${Defined[healset]}) {
		/declare healset string outer
		/declare healspam bool outer
		/declare healchannel string outer
		/declare battlerezdist int outer
		/declare battlerezlist string outer
		/declare dohotheal bool outer
		/declare hothealtimer timer outer
		/declare hotheal string outer
		/declare hothealmsg string outer
		/declare puller string outer
		/declare pullerrange int outer
		/declare maintank string outer
		/declare maintankdly int outer
		/declare maintankpct int outer
		/declare maintanktargeting bool outer
		/declare maintanktimer timer outer
		/declare tankingroup bool outer
		/declare curtank string outer
		/declare divarbme int outer
		/declare divarbmt int outer
		/declare divarbother int outer
		/declare divarbmsg string outer
		/declare epichealitem string outer
		/declare epicgroup int outer
		/declare epicsingle int outer
		/declare epiccount int outer
		/declare epicdelay int outer
		/declare epictimer timer outer
		/declare epichealmsg string outer
		/declare groupspell string outer
		/declare groupavg int outer
		/declare grouppct int outer
		/declare groupcnt int outer
		/declare groupmsg string outer

		/declare tankcnt int outer
		/declare tankspell[5] string outer
		/declare tankpct[5] int outer
		/declare tankabort[5] int outer -150
		/declare tankstop[5] int outer 100
		/declare tankmsg[5] string outer
		/declare healcnt int outer
		/declare healspell[5] string outer
		/declare healpct[5] int outer
		/declare healabort[5] int outer -150
		/declare healstop[5] int outer 100
		/declare healmsg[5] string outer

		/declare healae int outer 0
		/declare healaedelay int outer 1
		/declare healaerange int outer 100
		/declare healaeptr int outer 1
		/declare healaespell string outer "Ancient: Hallowed Light"
		
		/declare healburst bool outer FALSE
		/declare healburstspell string outer
	}
	/declare i int

	/call LoadIni Heal active dohealing ${dohealing}
	/call LoadIni Heal healset healset Heal
	/call LoadIni Heal spam healspam FALSE
	/call LoadIni Heal channel healchannel gsay
	/call LoadIni Heal puller puller nobody
	/call LoadIni Heal pullerrange pullerrange 50
	/call LoadIni Heal maintank maintank nobody
	/call LoadIni Heal maintankdly maintankdly 30
	/call LoadIni Heal maintankpct maintankpct 100
	/call LoadIni Heal healburst healburstspell
	
	/call LoadIni ${healset} battlerez battlerez FALSE
	/call LoadIni ${healset} battlerezdist battlerezdist 50

	/call LoadIni ${healset} hotheal dohotheal FALSE
	/call LoadIni ${healset} hotspell hotheal replacespellname
	/call LoadIni ${healset} hothealmsg hothealmsg "Hot Heal ->"

	/call LoadIni ${healset} divarbme divarbme 30
	/call LoadIni ${healset} divarbmt divarbmt 20
	/call LoadIni ${healset} divarbother divarbother 20
	/call LoadIni ${healset} divarbmsg divarbmsg "Divine Arbitration INCOMING...."
	/call GetAlias epic
	/if (${Macro.Return.NotEqual[NotFound]}) /varset epichealitem ${Macro.Return}
	/call LoadIni ${healset} epicgroup epicgroup 70
	/call LoadIni ${healset} epicsingle epicsingle 60
	/call LoadIni ${healset} epiccount epiccount 3
	/call LoadIni ${healset} epicdelay epicdelay 5
	/call LoadIni ${healset} epichealmsg epichealmsg "Clicking EPIC...."
	/call LoadIni ${healset} groupspell groupspell groupspellname
	/call LoadIni ${healset} groupavg groupavg 80
	/call LoadIni ${healset} grouppct grouppct 70
	/call LoadIni ${healset} groupcnt groupcnt 3
	/call LoadIni ${healset} groupmsg groupmsg "Group Heal Incoming..."
	
	/for i 1 to 5
		/varset healspell[${i}]
		/varset tankspell[${i}]
		/call LoadIni ${healset} healspell${i} healspell[${i}]
		/call LoadIni ${healset} healpct${i} healpct[${i}]
		/call LoadIni ${healset} healabort${i} healabort[${i}]
		/call LoadIni ${healset} healstop${i} healstop[${i}]
		/call LoadIni ${healset} healmsg${i} healmsg[${i}]
		/call LoadIni ${healset} tankspell${i} tankspell[${i}]
		/call LoadIni ${healset} tankpct${i} tankpct[${i}]
		/call LoadIni ${healset} tankabort${i} tankabort[${i}]
		/call LoadIni ${healset} tankstop${i} tankstop[${i}]
		/call LoadIni ${healset} tankmsg${i} tankmsg[${i}]
		/if (${healspell[${i}].Length}) /varset healcnt ${i}
		/if (${tankspell[${i}].Length}) /varset tankcnt ${i}
	/next i
/return

Sub DoHealing
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	/declare s int
	/declare b int
	/declare whid int 0
	/declare whpct int 100
	/declare spellname string
	/declare spellmsg string
	/declare spelltime int
	/declare spellabort int
	/declare spellstop int

	/varset curtank NULL
	/for i 1 to 9
		/if (!${maintank.Token[${i},|].Length}) /goto :healtop
		/if (${Spawn[pc ${maintank.Token[${i},|]}].ID} && ${Spawn[pc ${maintank.Token[${i},|]}].Distance}<250) {
			/varset curtank ${maintank.Token[${i},|]}
			/call InGroup ${curtank}
			/varset tankingroup ${Macro.Return}
			/goto :healtop
		}
	/next i
	/return FALSE

	:healtop
	/call CheckDivarb
	/if (${Macro.Return}) {
		/if (${healspam}) /docommand /gsay ${divarbmsg}
		/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${divarbmsg}[+x+]
		/alt activate ${AltAbility[Divine Arbitration].ID} 
		/delay 15s !${Me.Casting.ID}
		/varset epictimer ${epicdelay}
		/return TRUE
	}

	/call CheckEpicHeal
	/if (${Macro.Return}) {
		/if (${healspam}) /docommand /gsay ${epichealmsg}
		/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${epichealmsg}[+x+]
		/casting "${epichealitem}"|Item
		/delay 15s !${Me.Casting.ID}
		/varset epictimer ${epicdelay}
		/return TRUE
	}
	
	/call CheckGroupHeal
	/if (${Macro.Return}) {
		/if (${healspam}) /docommand /gsay ${groupmsg}
		/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${groupmsg} - <${Me.PctMana}m>[+x+]
		/casting "${groupspell}"
		/delay 15s !${Me.Casting.ID}
		/return TRUE
	}	

	/if (${maintankdly} && !${doautoassist} && ${curtank.NotEqual[NULL]}) {
		/if (!${tankingroup} && (!${Target.ID} || ${Target.Name.NotEqual[${curtank}]})) {
			/if (${maintanktargeting}) {
				/if (!${maintanktimer}) {
					/varset maintanktargeting FALSE
					/target pc ${curtank}
					/delay 1s ${Target.Name.Equal[${curtank}]}
				}
			} else /if (${curtank.NotEqual[${Target.Name}]} && ${maintankdly}) {
				/varset maintanktargeting TRUE
				/varset maintanktimer ${maintankdly}
			}
		}
	}

	/if (${dohotheal} && !${hothealtimer} && ${Me.CurrentMana}>=${Spell[${hotheal}].Mana}) {
		/if ((${Target.Name.Equal[${curtank}]} && ${Me.TargetOfTarget.Type.Equal[NPC]}) || (${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${curtank}]})) {
			/if (${Me.SpellReady[${hotheal}]} && ${Spawn[pc ${curtank}].Distance}<=${Spell[${hotheal}].MyRange}) {
				/if (${healspam}) /docommand /${healchannel} ${hothealmsg}${Target.Name}
				/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+O+]${hothealmsg}${curtank} - <${Me.PctMana}m>[+x+]
				/casting "${hotheal}"|gem9 -targetid|${Spawn[pc ${curtank}].ID}
				/call WaitCast
				/if (${Select[${Cast.Result},CAST_SUCCESS,CAST_TAKEHOLD]}) {
					/varcalc hothealtimer ${Spell[${hotheal}].Duration}*60*${focusbeni}
					/return TRUE
				}
			} else {
				/varset noyaulp 5
			}
		}
	}
	
	/if (${healburst} && (${Target.Name.Equal[${curtank}]} || ${tankingroup})) {
		/if (${Me.SpellReady[${healburstspell}]}  && ${Spawn[pc ${curtank}].Distance}<=${Spell[${healburstspell}].MyRange} && ${Me.CurrentMana}>=${Spell[${healburstspell}].Mana}) {
			/if (${healspam}) /docommand /${healchannel} BURST HEAL...${curtank}
			/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+O+]BURST HEAL...${curtank} - <${Me.PctMana}m>[+x+]
			/casting "${healburstspell}"|gem9 -targetid|${Spawn[pc ${curtank}].ID}
			/call WaitCast
			/return TRUE
		}
	}

	/if (${Target.ID} && ${Target.Type.Equal[PC]}) {
		/if (${Target.Name.Equal[${curtank}]} && ${Target.PctHPs}<=${maintankpct}) {
			/varset whid ${Target.ID}
			/varset whpct ${Target.PctHPs}
		} else {
			/varset whid ${Target.ID}
			/varset whpct ${Target.PctHPs}
		}
	}

	/for i 0 to ${Group}
		/if (${Spawn[pc ${Group.Member[${i}]}].ID} && ${Group.Member[${i}].Distance}<${Spell[${healspell[1]}].MyRange}) {
			/if (${Group.Member[${i}].Name.Equal[${puller}]}) {
				/if ((${Group.Member[${i}].Distance}<=${pullerrange} || ${Group.Member[${i}].Feigning}) && ${Group.Member[${i}].PctHPs}<${whpct}) {
					/varset whid ${Group.Member[${i}].ID}
					/varset whpct ${Group.Member[${i}].PctHPs}
				}
			} else /if (${Group.Member[${i}].Name.Equal[${curtank}]}) {
				/if (${Group.Member[${i}].PctHPs}<${maintankpct} && ${Group.Member[${i}].PctHPs}<${whpct}) {
					/varset whid ${Group.Member[${i}].ID}
					/varset whpct ${Group.Member[${i}].PctHPs}
				}
			} else /if (${Group.Member[${i}].PctHPs}<${whpct}) {
				/varset whid ${Group.Member[${i}].ID}
				/varset whpct ${Group.Member[${i}].PctHPs}
			}
		}
	/next i

	/if (!${whid}) /goto :doaeheal

	:nextspell
	/if (${Spawn[${whid}].Name.Equal[${curtank}]} && ${tankcnt}) {
		/for s 1 to ${tankcnt}
			/if (${Me.SpellReady[${tankspell[${s}]}]} && ${whpct}<=${tankpct[${s}]} && ${Spawn[${whid}].Distance}<=${Spell[${tankspell[${s}]}].MyRange} && ${Me.CurrentMana}>=${Spell[${tankspell[${s}]}].Mana}) {
				/varset spellname ${tankspell[${s}]}
				/varset spellmsg ${tankmsg[${s}]}
				/varset spellabort ${tankabort[${s}]}
				/varset spellstop ${tankstop[${s}]}
				/varset spelltime 500
				/varcalc s ${s}-1
				/if (!${s}) /goto :noabort
				/for b 1 to s
					/if (${Me.SpellReady[${tankspell[${b}]}]} && ${Spawn[${whid}].Distance}<=${Spell[${tankspell[${b}]}].MyRange} && ${Me.CurrentMana}>=${Spell[${tankspell[${b}]}].Mana}) /goto :castit
				/next b
				/goto :noabort
			}
		/next s
	} else /if (${healcnt}) {
		/for s 1 to ${healcnt}
			/if (${Me.SpellReady[${healspell[${s}]}]} && ${whpct}<=${healpct[${s}]} && ${Spawn[${whid}].Distance}<=${Spell[${healspell[${s}]}].MyRange} && ${Me.CurrentMana}>=${Spell[${healspell[${s}]}].Mana}) {
				/varset spellname ${healspell[${s}]}
				/varset spellmsg ${healmsg[${s}]}
				/varset spellabort ${healabort[${s}]}
				/varset spellstop ${healstop[${s}]}
				/varset spelltime 500
				/varcalc s ${s}-1
				/if (!${s}) /goto :noabort
				/for b 1 to s
					/if (${Me.SpellReady[${tankspell[${b}]}]} && ${Spawn[${whid}].Distance}<=${Spell[${tankspell[${b}]}].MyRange} && ${Me.CurrentMana}>=${Spell[${tankspell[${b}]}].Mana}) /goto :castit
				/next b
				/goto :noabort
			}
		/next s
	}
	/goto :doaeheal
	/return FALSE

	:noabort
	/varset spellabort -150
	:castit
	/casting "${spellname}" -targetid|${whid}
	/if (${healspam}) /docommand /${healchannel} ${spellmsg}${Spawn[${whid}].Name}
	/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${spellmsg}${Spawn[${whid}].Name} - <${Me.PctMana}m>[+x+]
	/if (${Me.TargetOfTarget.Type.Equal[NPC]}) /multiline ; /varset idle ${idleuser} ; /varset idle1 1m ; /varset idle5 5m
	/if (${Me.Mount.ID}) {
		/delay 20s ${Cast.Status.Equal[I]}
	} else {
		:top
		/delay 1
		/if (${Target.PctHPs}>=${spellstop}) /multiline ; /interrupt ; /return TRUE
		/if (${Cast.Timing}<=35 && ${Target.PctHPs}>=${spellstop}) /multiline ; /interrupt ; /return TRUE
		/if (${Cast.Timing}>=500) {
			/if (${Target.PctHPs}<=${spellabort}) /multiline ; /interrupt ; /goto :nextspell
			/call CheckDivarb
			/if (${Macro.Return}) {
				/interrupt
				/delay 2s ${Cast.Status.Equal[I]}
				/if (${healspam}) /docommand /gsay ${divarbmsg}
				/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${divarbmsg}[+x+]
				/alt activate ${AltAbility[Divine Arbitration].ID} 
				/delay 15s !${Me.Casting.ID}
				/varset epictimer ${epicdelay}
				/return TRUE
			}
			/call CheckEpicHeal
			/if (${Macro.Return}) {
				/interrupt
				/delay 2s ${Cast.Status.Equal[I]}
				/if (${healspam}) /docommand /gsay ${epichealmsg}
				/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+o+]${epichealmsg}[+x+]
				/casting "${epichealitem}"|Item
				/delay 15s !${Me.Casting.ID}
				/varset epictimer ${epicdelay}
				/return TRUE
			}
		}
		/if (${Cast.Status.Equal[C]}) /goto :top
	}
	/return TRUE

	:doaeheal
	/if (!${healae}) /return FALSE
	/if (!${Me.SpellReady[${healaespell}]} || ${Me.CurrentMana}<${Spell[${healaespell}].Mana}) /return FALSE

	/declare loopedonce bool FALSE
	/declare f int ${healaeptr}

	:aeloop
	/varset whid ${NearestSpawn[${healaeptr}, pc radius ${healaerange}].ID}
	/if (!${whid}) {
		/varset healaeptr 1
		/if (${loopedonce}) /return FALSE
		/varset loopedonce TRUE
		/goto :aenext
	}

	/call InGroup ${Spawn[${whid}].Name}
	/if (${Me.ID}!=${whid} && !${Macro.Return}) {
		/target id ${whid}
		/delay 5 ${whid}==${Target.ID} 
		/if (${Target.PctHPs}<=${healae}) {
			/varset spellname ${healaespell}
			/varset spellmsg AE Healing...
			/varset spellabort -150
			/varset spellstop 97
			/varset spelltime 500
			/goto :noabort
		}
		/delay ${healaedelay}
	}
	/varcalc healaeptr ${healaeptr}+1
	:aenext
	/if (${f}!=${healaeptr}) /goto :aeloop
/return FALSE

Sub CheckDivarb
	/if (!${Group.Members}>=1)	/return FALSE
	/if (${epictimer} || !${Me.AltAbilityReady[Divine Arbitration]}) /return FALSE
	
	/declare i int

	/if (${Me.PctHPs}<=${divarbme}) /return TRUE
	/if (!${Group}) /return FALSE	
	/for i 1 to ${Group}
		/if (${Spawn[pc ${Group.Member[${i}]}].ID}) {
			/if (${Group.Member[${i}].Name.Equal[${puller}]}) {
				/if (${Group.Member[${i}].PctHPs}<=${divarbother} && ${Group.Member[${i}].Distance}<=${pullerrange}) /return TRUE
			} else /if (${Group.Member[${i}].Name.Equal[${curtank}]}) {
				/if (${Group.Member[${i}].PctHPs}<=${divarbmt} && ${Group.Member[${i}].Distance}<=${Spell[divine arbitration].Range}) /return TRUE
			} else {
				/if (${Group.Member[${i}].PctHPs}<=${divarbother} && ${Group.Member[${i}].Distance}<=${Spell[divine arbitration].Range}) /return TRUE
			}
		}
	/next i
/return FALSE

Sub CheckEpicHeal
	/if (!${Group.Members}>=1)	/return FALSE
	/if (${epictimer} || !${FindItemCount[=${epichealitem}]} || ${FindItem[=${epichealitem}].Timer}) /return FALSE

	/declare i int
	/declare inepic int 0
	/declare avgepic int 0
	/declare hurtepic int 0

	/for i 0 to ${Group}
		/if (${Spawn[pc ${Group.Member[${i}]}].ID}) {
			/if (${Group.Member[${i}].Distance}<=100) {
				/varcalc inepic ${inepic}+1
				/varcalc avgepic ${avgepic}+${Group.Member[${i}].PctHPs}
				/if (${Group.Member[${i}].PctHPs}<=${epicsingle}) /varcalc hurtepic ${hurtepic}+1 
			}
		}
	/next i
	/if (${inepic}) /varcalc avgepic ${avgepic}/${inepic}
	/if (${avgepic}<=${epicgroup} || ${hurtepic}>=${epiccount}) /return TRUE
/return FALSE

Sub CheckGroupHeal
	/if (!${Group.Members}>=1)	/return FALSE
    /if (!${Me.SpellReady[${groupspell}]} || ${Me.CurrentMana}<${Spell[${groupspell}].Mana}) /return FALSE

    /declare i int
    /declare cnt int 0
    /declare avg int 0
    /declare hurt int 0

    /for i 0 to ${Group}
        /if (${Spawn[pc ${Group.Member[${i}]}].ID}) {
            /if (${Group.Member[${i}].PctHPs}>0 &&  ${Group.Member[${i}].Distance}<=${Spell[${groupspell}].AERange}) {
                /varcalc cnt ${cnt}+1
                /varcalc avg ${avg}+${Group.Member[${i}].PctHPs}
	/if (${Group.Member[${i}].PctHPs}<=${grouppct}) /varcalc hurt ${hurt}+1 
            }
        }
    /next i
    /if (${cnt}) /varcalc avg ${avg}/${cnt}
    /if (${avg}<=${groupavg} || ${hurt}>=${groupcnt}) /return TRUE
/return FALSE

Sub Event_SetHeal(string Line)
	/call HealingIni
	
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Heal${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset dohealing TRUE
		/call SetIni Heal active ${dohealing}
		/echo INFO: Heals are ON!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset dohealing FALSE
		/call SetIni Heal active ${dohealing}
		/echo INFO: Heals are OFF!
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset healspam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset healspam FALSE
		/echo INFO: Heal Spam is ${healspam}
		/call SetIni Heal Spam is ${healspam}
	} else /if (${Line.Arg[3].Equal[CHANNEL]}) {
		/varset healchannel ${Line.Arg[4]}
		/call SetIni Heal channel ${healchannel}
		/echo INFO: Heal Messages to Channel /${healchannel}
	} else /if (${Line.Arg[3].Equal[BATTLEREZ]} && ${Me.Class.Name.Equal[Cleric]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset battlerez TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset battlerez FALSE
		/if (${Line.Arg[5].Length}) /varset battlerezdist ${Line.Arg[5]}
		/echo INFO: Battle Rez is ${battlerez}, Max Distance is ${battlerezdist}
		/call SetIni ${healset} battlerez ${battlerez}
		/call SetIni ${healset} battlerezdist ${battlerezdist}
	} else /if (${Line.Arg[3].Equal[REZ]}) {
		/call AERez ${Line.Arg[4]} ${Line.Arg[5]}
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset healset Heal
		/if (${Line.Arg[4].Length}) /varset healset Heal${Line.Arg[4]}
		/echo INFO: Heal Set is now ${healset}
		/call SetIni Heal healset ${healset}
		/call HealingIni
	} else /if (${Line.Arg[3].Equal[HOT]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset dohotheal TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset dohotheal FALSE
		} else {
			/varset hotheal ${Me.Gem[${Line.Arg[4]}].Name}
		}
		/call SetIni ${healset} hotheal ${dohotheal}
		/call SetIni ${healset} hotspell "${hotheal}"
		/echo INFO: HoT Healing is ${dohotheal} (${hotheal})
	} else /if (${Line.Arg[3].Equal[burst]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/if (${healburstspell.NotEqual[NULL]}) /varset healburst TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset healburst FALSE
		} else {
			/varset healburstspell ${Me.Gem[${Line.Arg[4]}].Name}
		}
		/call SetIni Heal healburst "${healburstspell}"
		/echo INFO: Burst Healing is ${healburst} (${healburstspell})
	} else /if (${Line.Arg[3].Equal[PULLER]}) {
		/varset puller ${Line.Arg[4]} 
		/if (${Line.Arg[5].Length}) /varset pullerrange ${Line.Arg[5]}
		/echo INFO: Puller is now ${puller}, Range to Heal is ${pullerrange}
		/call SetIni Heal puller ${puller}
		/call SetIni Heal pullerrange ${pullerrange}
	} else /if (${Line.Arg[3].Equal[TANK]}) {
		/if (${Line.Arg[4].Length}>3) {
			/varset maintank ${Line.Arg[4]} 
			/if (${Line.Arg[5].Length}) /varset maintankpct ${Line.Arg[5]}
			/if (${Line.Arg[6].Length}) /varset maintankdly ${Line.Arg[6]}
			/echo INFO: Tank is now ${maintank}
			/if (${Line.Arg[5].Length}) /echo Percent to Heal is set to ${maintankpct}
			/call SetIni Heal maintank ${maintank}
			/call SetIni Heal maintankpct ${maintankpct}
			/call SetIni Heal maintankdly ${maintankdly}
		} else {
			/declare i int ${Line.Arg[4]}
			/varset tankspell[${i}] ${Me.Gem[${Line.Arg[5]}]}
			/varset tankabort[${i}] -150
			/varset tankstop[${i}] 100
			/if (${Line.Arg[6].Length}) /varset tankpct[${i}] ${Line.Arg[6]}
			/if (${Line.Arg[7].Length}) /varset tankabort[${i}] ${Line.Arg[7]}
			/if (${Line.Arg[8].Length}) /varset tankstop[${i}] ${Line.Arg[8]}
			/call SetIni ${healset} tankspell${i} "${tankspell[${i}]}"
			/call SetIni ${healset} tankpct${i} ${tankpct[${i}]}
			/call SetIni ${healset} tankabort${i} ${tankabort[${i}]}
			/call SetIni ${healset} tankstop${i} ${tankstop[${i}]}
			/call LoadIni ${healset} tankmsg${i} tankmsg[${i}] "Healing-->"
			/if (${i}>${tankcnt}) /varset tankcnt ${i}
			/echo INFO: tank${i} = ${tankspell[${i}]}, pct=${tankpct[${i}]}%, abort=${tankabort[${i}]}%, stop=${tankstop[${i}]}%, msg=${tankmsg[${i}]}
		}
	} else /if (${Line.Arg[3].Equal[GROUP]}) {
		/declare i int ${Line.Arg[4]}
		/if (${i}) {
			/varset healspell[${i}] ${Me.Gem[${Line.Arg[5]}]}
			/varset healabort[${i}] -150
			/varset healstop[${i}] 100
			/if (${Line.Arg[6].Length}) /varset healpct[${i}] ${Line.Arg[6]}
			/if (${Line.Arg[7].Length}) /varset healabort[${i}] ${Line.Arg[7]}
			/if (${Line.Arg[8].Length}) /varset healstop[${i}] ${Line.Arg[8]}
			/call SetIni ${healset} healspell${i} "${healspell[${i}]}"
			/call SetIni ${healset} healpct${i} ${healpct[${i}]}
			/call SetIni ${healset} healabort${i} ${healabort[${i}]}
			/call SetIni ${healset} healstop${i} ${healstop[${i}]}
			/call LoadIni ${healset} healmsg${i} healmsg[${i}] "Healing-->"
			/if (${i}>${healcnt}) /varset healcnt ${i}
			/echo INFO: heal${i} = ${healspell[${i}]}, pct=${healpct[${i}]}%, abort=${healabort[${i}]}%, stop=${healstop[${i}]}%, msg=${healmsg[${i}]}
		} else {
			/varset groupspell ${Me.Gem[${Line.Arg[5]}]}
			/if (${Line.Arg[6].Length}) /varset groupavg ${Line.Arg[6]}
			/if (${Line.Arg[7].Length}) /varset grouppct ${Line.Arg[7]}
			/if (${Line.Arg[8].Length}) /varset groupcnt ${Line.Arg[8]}
			/call SetIni ${healset} groupspell "${groupspell}"
			/call SetIni ${healset} groupavg ${groupavg}
			/call SetIni ${healset} grouppct ${grouppct}
			/call SetIni ${healset} groupcnt ${groupcnt}
			/echo INFO: Heal Group: ${groupspell}, avg=${groupavg}% OR ${groupcnt}+  @ ${grouppct}%
		}
	} else /if (${Line.Arg[3].Equal[DIVARB]}) {
		/if (${Line.Arg[4].Length}) /varset divarbme ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset divarbmt ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset divarbother ${Line.Arg[6]}
		/call SetIni ${healset} divarbme ${divarbme}
		/call SetIni ${healset} divarbmt ${divarbmt}
		/call SetIni ${healset} divarbother ${divarbother}
		/echo INFO: Divarb: me@${divarbme}%, mt@${divarbmt}%, other@${divarbother}%
	} else /if (${Line.Arg[3].Equal[EPIC]}) {
		/if (${Line.Arg[4].Length}) /varset epicgroup ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset epicsingle ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset epiccount ${Line.Arg[6]}
		/call SetIni ${healset} epicgroup ${epicgroup}
		/call SetIni ${healset} epicsingle ${epicsingle}
		/call SetIni ${healset} epiccount ${epiccount}
		/echo INFO: Epic: avg@${epicgroup}% or ${epiccount}@${epicsingle}%
	} else /if (${Line.Arg[3].Equal[AE]}) {
		/varset healae ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset healaedelay ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset healaerange ${Line.Arg[6]}
		/if (${Line.Arg[7].Length}) /varset healaespell ${Me.Gem[${Line.Arg[7]}]}
		/echo INFO: AE Healing MODE at ${healae}%, delay=${healaedelay}s, range=${healaerange}, spell=${healaespell}
	} else /if (${Line.Arg[3].Equal[LIST]}) {
		/call EchoHeals
	}
/return

Sub EchoHeals
	/declare i int
	
	/echo INFO: Healing = ${dohealing}
	/echo SLOT, SPELL, START, ABORT, STOP, MSG
	/if (${tankcnt}) {
		/echo ...Tank Heals
		/for i 1 to ${tankcnt}
			/echo ....${i}) ${tankspell[${i}]}, ${tankpct[${i}]}, ${tankabort[${i}]}, ${tankstop[${i}]}, ${tankmsg[${i}]}
		/next i
	}
	/if (${healcnt}) {
		/echo ...Other Heals
		/for i 1 to ${healcnt}
			/echo ....${i}) ${healspell[${i}]}, ${healpct[${i}]}, ${healabort[${i}]}, ${healstop[${i}]}, ${healmsg[${i}]}
		/next i
	}
/return

Sub BattleRez
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	/declare cnt int
	/declare corpseid int
	/declare tlist string
	
	/varset cnt ${SpawnCount[corpse radius 150 zradius 150]} 
	/if (${cnt}>0) {
		/for i 1 to ${cnt} 
			/varset corpseid ${NearestSpawn[${i},corpse radius 150 zradius 150].ID}
			/if (${Spawn[${corpseid}].Deity.ID} && !${battlerezlist.Find[${corpseid}]}) {
				/target id ${corpseid}
				/delay 2 ${Target.ID}==${corpseid}
				/if (!${Defined[battlerez${corpseid}]}) /declare battlerez${corpseid} timer outer 1m
				/if (!${Defined[battlecnt${corpseid}]}) /declare battlecnt${corpseid} int outer 1
				/varset battlerezlist ${battlerezlist}${corpseid}|
				/if (${Target.Distance3D}>${battlerezdist}) /corpse
				/delay 2 ${Target.Distance3D}<=${battlerezdist}
				/if (${Target.Distance3D}<=${battlerezdist}) {
					/if (${EQBC.Connected} && ${bcspam}) /docommand /bc [+t+]Battle Rezzing ... ${Spawn[${corpseid}].CleanName}[+x+]				
					/if (${Me.Sitting}) /stand
					/casting "Blessing of Resurrection"|alt
					/casting "Water Sprinkler of Nem Ankh"
					/delay 10s ${Cast.Status.Equal[I]}
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) /varset battlerez${corpseid} 3m
					/return
				}
			}
		/next i 
	}
	/for i 1 to 99
		/if (!${battlerezlist.Token[${i},|].Length}) {
			/varset battlerezlist ${tlist}
			/return
		}
		/varset corpseid ${battlerezlist.Token[${i},|]}
		/if (${Spawn[${corpseid}].ID} && ${Spawn[${corpseid}].Distance}<=150) {
			/varset tlist ${tlist}${corpseid}|
			/if (!${battlerez${corpseid}}) {
				/target id ${corpseid}
				/delay 2 ${Target.ID}==${corpseid}
				/varcalc battlecnt${corpseid} ${battlecnt${corpseid}}+1
				/varset battlerez${corpseid} ${battlecnt${corpseid}}m
				/if (${Target.Distance3D}>${battlerezdist}) /corpse
				/delay 2 ${Target.Distance3D}<=${battlerezdist}
				/if (${Target.Distance3D}<=${battlerezdist}) {
					/if (${EQBC.Connected} && ${bcspam}) /docommand /bc [+t+]Battle Rezzing ... ${Spawn[${corpseid}].CleanName} AGAIN[+x+]				
					/if (${Me.Sitting}) /stand
					/casting "Blessing of Resurrection"|alt
					/delay 10s ${Cast.Status.Equal[I]}
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) /varset battlerez${corpseid} 3m
					/return
				}
			}
		} else {
			/if (${Defined[battlerez${corpseid}]}) /deletevar battlerez${corpseid}
		}
	/next i
/return

Sub BattleRezClear
	/declare i int

	/for i 1 to 99
		/if (!${battlerezlist.Token[${i},|].Length}) {
			/varset battlerezlist
			/return
		}
		/if (${Defined[battlerez${battlerezlist.Token[${i},|]}]}) /deletevar battlerez${battlerezlist.Token[${i},|]}
	/next i
/return

Sub AERez(int distance, dosummon)
	/declare list string
	/declare count int
	/declare dist int
	/declare i int
	/declare summon bool TRUE
	/declare pccount int 0

	/if (!${distance}) {
		/varset dist 20
	} else {
		/varset dist ${distance}
	}
	/if (${dosummon.NotEqual[NULL]}) /varset summon FALSE

	/varset count ${SpawnCount[corpse radius ${dist} zradius 75]} 
	/if (${count}) {
		/for i 1 to ${count} 
			/if (${Spawn[${NearestSpawn[${i},corpse radius ${dist} zradius 75].ID}].Deity.ID}) {
				/varset list ${list}${NearestSpawn[${i},corpse radius ${dist} zradius 75].ID}|
				/varcalc pccount ${pccount}+1
			}
		/next i
	}
	/echo INFO: Rez/Dragging (dist=${dist}, count=${pccount}, drag=${summon})

	/for i 1 to 100
		/if (!${list.Token[${i},|].Length}) /return
		/if (${Window[RespawnWnd].Open}) /return
		/if (${Spawn[${list.Token[${i},|]}].ID}) {
			/target id ${list.Token[${i},|]}
			/delay 5 ${Target.ID}==${list.Token[${i},|]}
			/if (${summon}) /corpse
			/delay 5
			/casting "Water Sprinkler of Nem Ankh""
			/delay 13s ${Cast.Status.Equal[I]}
		}
	/next i
/return

Sub CureIni
	/declare i int

	/call LoadIni Cures active docures
	/call LoadIni Cures delay curedelay
	/call LoadIni Cures curer1 curer[1]
	/call LoadIni Cures curer2 curer[2]
	/call LoadIni Cures curer3 curer[3]
	/call LoadIni Cures curer4 curer[4]
	/call LoadIni Cures curer5 curer[5]

	/for i 1 to 30
		/if (!${Ini[${Me.Name}Settings.ini,Cures,buff${i}].Length}) /return
		/varcalc curebase ${curebase}+1
		/call LoadIni Cures buff${i} curebuff[${curebase}]
		/call LoadIni Cures spell${i} curespell[${curebase}]
		/call LoadIni Cures tell${i} curetell[${curebase}]
		/call LoadIni Cures priority${i} curepriority[${curebase}]
	/next i
/return

Sub LoadCures
	/declare i int

	/varset curetotal ${curebase}
	/for i 1 to 30
		/if (!${Ini[${Me.Name}Settings.ini,Cures${Zone.ShortName},buff${i}].Length}) /return
		/varcalc curetotal ${curetotal}+1
		/call LoadIni Cures${Zone.ShortName} buff${i} curebuff[${curetotal}]
		/call LoadIni Cures${Zone.ShortName} spell${i} curespell[${curetotal}]
		/call LoadIni Cures${Zone.ShortName} tell${i} curetell[${curetotal}]
		/call LoadIni Cures${Zone.ShortName} priority${i} curepriority[${curetotal}]
	/next i
/return

Sub CheckCures
	/if (${Me.Invis}) /return FALSE

	/declare i int
	/declare j int
	/declare telldelay int 1

	/for i 1 to 5
		/if (${curecurrentspell[${i}].NotEqual[NULL]} && !${Me.Buff[${curecurrentspell[${i}]}].ID}) {
			/for j 1 to 5
				/if (${curer[${j}].NotEqual[NULL]} && ${Spawn[pc ${curer[${j}]}].ID}) {
						/bct ${curer[${j}]} //cure remove ${Me.Name} ${curecurrenttell[${i}]}
				}
			/next j
			/varset curecurrentspell[${i}] NULL
		}
	/next i

	/for i 1 to ${curetotal}
		/if (${Me.Buff[${curebuff[${i}]}].ID}) {
			/if (${Me.Gem[${curespell[${i}]}]} && ${Me.CurrentMana}>${Spell[${curespell[${i}]}].Mana}) {
				/if (${Me.SpellReady[${curespell[${i}]}]}) {
					/call SetBandolier ${Spell[${curespell[${i}]}].ID}
					/casting "${curespell[${i}]}"|gem9 -targetid|${Me.ID} ${bandset}
					/delay 20s ${Cast.Status.Equal[I]}
				}
				/return TRUE
			} else /if (${FindItemCount[=${curespell[${i}]}]}) {
				/casting "${curespell[${i}]}"|Item -targetid|${Me.ID}
				/delay 20s ${Cast.Status.Equal[I]}
				/return TRUE
			} else {
				/if (${curetimer}) /return FALSE
				/varset curetimer ${curedelay}
				/for j 1 to 5
					/if (${Spawn[pc ${curer[${j}]}].ID}) {
						/bct ${curer[${j}]} //cure add ${Me.Name} ${curetell[${i}]} ${curepriority[${i}]}
					}
				/next j
				/for j 1 to 5
					/if (${curecurrentspell[${j}].Equal[${curebuff[${i}]}]}) /goto :inlistalready
				/next j
				/for j 1 to 5
					/if (${curecurrentspell[${j}].Equal[NULL]}) {
						/varset curecurrentspell[${j}] ${curebuff[${i}]}
						/varset curecurrenttell[${j}] ${curetell[${i}]}
						/goto :inlistalready
					}
				/next j
				:inlistalready
			}
		}
	/next i
/return FALSE

Sub CureSomeone
	/declare i int
	/declare position int 0
	/declare priority int 0

	/varset curesomeone FALSE
	/for i 1 to 30
		/if (${curelistid[${i}]}) {
			/if (!${Spawn[${curelistid[${i}]}].ID}) {
				/varset curelistid[${i}] 0
			} else /if (${Spawn[${curelistid[${i}]}].Distance}>300) {
				/varset curelistid[${i}] 0
			} else /if (${Spawn[${curelistid[${i}]}].Distance}<=100) {
				/if (${curelistpriority[${i}]}>${priority}) {
					/varset position ${i}
					/varset priority ${curelistpriority[${i}]}
					/varset curesomeone TRUE
				}
			}
		}
	/next i
	/if (!${position}) /return FALSE

	/for i 1 to 30
		/if (${curetell[${i}].Equal[${curelistspell[${position}]}]}) {
			/if (${Me.Gem[${curespell[${i}]}]}) {
				/if (!${Me.SpellReady[${curespell[${i}]}]}) /return FALSE
				/call SetBandolier ${Spell[${curespell[${i}]}].ID}
				/casting "${curespell[${i}]}"|gem9 -targetid|${curelistid[${position}]} ${bandset}
			} else /if (${FindItemCount[=${curespell[${i}]}]}) {
				/casting "${curespell[${i}]}"|Item -targetid|${curelistid[${position}]}
			} else {
				/echo ERROR: Didnt find spell loaded or Item to cast...${curespell[${i}]}
				/varset curelistid[${position}] 0
				/return FALSE
			}
			:cureloop
			/doevents SetCure
			/doevents Chat
			/if (!${curelistid[${position}]}) /interrupt
			/if (${Cast.Status.NotEqual[I]}) /goto :cureloop
			/varset curelistid[${position}] 0
			/return TRUE
		}
	/next i
	/varset curelistid[${position}] 0
/return FALSE

Sub AddCure(string name,string tell,int priority)
	/declare i int

	/varset curesomeone TRUE
	/for i 1 to 30
		/if (${curelistid[${i}]}==${Spawn[pc ${name}].ID} && ${curelistspell[${i}].Equal[${tell}]}) /return
	/next i
	/for i 1 to 30
		/if (!${curelistid[${i}]}) {
			/varset curelistid[${i}] ${Spawn[pc ${name}].ID}
			/varset curelistspell[${i}] ${tell}
			/varset curelistpriority[${i}] ${priority}
			/return
		}
	/next i
/return

Sub RemoveCure(string name, string spellname)
	/declare i int

	/for i 1 to 30
		/if (${curelistid[${i}]}==${Spawn[pc ${name}].ID} && ${curelistspell[${i}].Equal[${spellname}]}) {
			/varset curelistid[${i}] 0
			/return
		}
	/next i
/return

Sub DoCureNow(string name,string tell)
	/declare i int

	/for i 1 to 30
		/if (${curetell[${i}].Equal[${tell}]}) {
			/if (${Me.Gem[${curespell[${i}]}]}) {
				/delay 10s ${Cast.Ready[${curespell[${i}]}]}
				/if (!${Me.SpellReady[${curespell[${i}]}]}) /return
				/casting "${curespell[${i}]}"|gem9 -targetid|${Spawn[pc ${name}].ID}
			} else /if (${FindItemCount[=${curespell[${i}]}]}) {
				/casting "${curespell[${i}]}"|Item -targetid|${Spawn[pc ${name}].ID}
			} else {
				/echo ERROR: Didnt find spell loaded or Item to cast...${curespell[${i}]}
				/return
			}
			/delay 10s ${Cast.Status.NotEqual[I]}
			/return
		}
	/next i
/return

Sub Event_SetCure(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Cure${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset docures TRUE
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset docures FALSE
	} else /if (${Line.Arg[3].Equal[ADD]}) {
		/call AddCure ${Line.Arg[4]} ${Line.Arg[5]} ${Line.Arg[6]}
		/return
	} else /if (${Line.Arg[3].Equal[REMOVE]}) {
		/call RemoveCure ${Line.Arg[4]} ${Line.Arg[5]}
		/return
	} else {
		/varset curer[1] nobody
		/varset curer[2] nobody
		/varset curer[3] nobody
		/varset curer[4] nobody
		/varset curer[5] nobody

		/if (${Line.Arg[3].Length}) /varset curedelay ${Line.Arg[3]}s
		/if (${Line.Arg[4].Length}) /varset curer[1] ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset curer[2] ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset curer[3] ${Line.Arg[6]}
		/if (${Line.Arg[7].Length}) /varset curer[4] ${Line.Arg[7]}
		/if (${Line.Arg[8].Length}) /varset curer[5] ${Line.Arg[8]}

		/call SetIni Cures delay "${curedelay}"
		/call SetIni Cures curer1 "${curer[1]}"
		/call SetIni Cures curer2 "${curer[2]}"
		/call SetIni Cures curer3 "${curer[3]}"
		/call SetIni Cures curer4 "${curer[4]}"
		/call SetIni Cures curer5 "${curer[5]}"
	}
	/call EchoCureSettings
/return 

Sub EchoCureSettings
	/declare i int

	/echo INFO: Cure Active = ${docures}
	/echo INFO: Cure Delay = ${curedelay}
	/echo INFO: Curers = ${curer[1]}, ${curer[2]}, ${curer[3]}, ${curer[4]}, ${curer[5]}

	/if (!${curetotal}) /return
	/for i 1 to ${curetotal}
		/echo INFO: ...${curebuff[${i}]}, ${curespell[${i}]}, ${curetell[${i}]}, ${curepriority[${i}]}
	/next i
/return

Sub BuffingIni(string Line)
	/declare i int

	/call LoadIni Buffs active dobuffs
	/call LoadIni Buffs aggro buffaggro
	/call LoadIni Buffs buffset buffset
	/call LoadIni Buffs delay bufftimer
	/call LoadIni Buffs group2 buffgroup2
	/call LoadIni Buffs group3 buffgroup3
	/call LoadIni Buffs gem buffgem
	/call LoadIni Buffs reset buffreset
	/call LoadIni Buffs range buffrange

	/call LoadIni Buffs buffcombatonly1 buffcombatonly1
	/call LoadIni Buffs attackspell1 attackbuff1
	/call LoadIni Buffs attackdur1 attackdur1
	/call LoadIni Buffs mana1 attackmana1
	/call LoadIni Buffs attack1 attack1
	/call LoadIni Buffs attack2 attack2
	/call LoadIni Buffs attack3 attack3
	/call LoadIni Buffs attack4 attack4
	/call LoadIni Buffs attack5 attack5
	/call LoadIni Buffs attack6 attack6
	/call LoadIni Buffs attack7 attack7
	/call LoadIni Buffs attack8	attack8
	/call LoadIni Buffs attack9 attack9
	/call LoadIni Buffs attack10 attack10
	/call LoadIni Buffs buffcombatonly2 buffcombatonly2
	/call LoadIni Buffs attackspell2 attackbuff2
	/call LoadIni Buffs attackdur2 attackdur2
	/call LoadIni Buffs mana2 attackmana2
	/call LoadIni Buffs attack21 attack21
	/call LoadIni Buffs attack22 attack22
	/call LoadIni Buffs attack23 attack23
	/call LoadIni Buffs attack24 attack24
	/call LoadIni Buffs attack25 attack25
	/call LoadIni Buffs buffcombatonly3 buffcombatonly3
	/call LoadIni Buffs attackspell3 attackbuff3
	/call LoadIni Buffs attackdur3 attackdur3
	/call LoadIni Buffs mana3 attackmana3
	/call LoadIni Buffs attack31 attack31
	/call LoadIni Buffs attack32 attack32
	/call LoadIni Buffs attack33 attack33
	/call LoadIni Buffs attack34 attack34
	/call LoadIni Buffs attack35 attack35
	/if (${attackbuff1.NotEqual[NULL]} || ${attackbuff2.NotEqual[NULL]} || ${attackbuff3.NotEqual[NULL]}) /varset doattackbuff TRUE

	/call LoadIni Buffs gomspell buffgom
	/call LoadIni Buffs gompercent buffgompercent
	/call LoadIni Buffs gomtarget buffgomtarget
	/call LoadIni Buffs levcaster bufflever
	
	/call LoadIni Buffs buffrez buffrez
	/call LoadIni Buffs buffrezlist buffrezlist

	/for i 1 to 10
		/varset buffs[${i}] NULL
	/next i
	/varset buffcount 0
	/for i 1 to 10
		/if (${Ini[${Me.Name}Settings.ini,${buffset},buff${i}].Length}) {
			/varcalc buffcount ${buffcount}+1
			/varset buffblock[${buffcount}] NULL
			/varset buffwhen[${buffcount}] NULL
			/varset buffname[${buffcount}] NULL
			/varset buffvalue[${buffcount}] 0
			/call LoadIni ${buffset} buff${i} buffs[${buffcount}]
			/call LoadIni ${buffset} block${i} buffblock[${buffcount}]
			/call LoadIni ${buffset} when${i} buffwhen[${buffcount}]
			/call LoadIni ${buffset} name${i} buffname[${buffcount}]
			/call LoadIni ${buffset} value${i} buffvalue[${buffcount}]
		}
	/next i

	/call LoadIni BuffRequests setsingle buffsetsingle
	/call LoadIni BuffRequests setgroup buffsetgroup
	/call LoadIni BuffRequests setrez buffsetrez
	/for i 1 to MAXBUFFTELLS
		/call LoadIni BuffRequests alias${i} bufftellalias[${i}]
		/call LoadIni BuffRequests buff${i} bufftellspell[${i}]
		/call LoadIni BuffRequests auth${i} bufftellauth[${i}]
	/next i
	
	/varset blockcount 0
	/for i 1 to 10
		/if (${Ini[${Me.Name}Settings.ini,${buffset},remove${i}].Length}) {
			/varcalc blockcount ${blockcount}+1
			/varset buffremove[${blockcount}]
			/call LoadIni ${buffset} remove${i} buffremove[${blockcount}]
		}
	/next i
/return

Sub DoBuffs
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare cb int
	/declare cg int
	/declare ct int
	/declare mc int
	/declare ab int
	/declare ac int
	/declare bb int
	/declare bg int
	/declare ag int
	/declare br int
	/declare i int
	/declare z int

	/declare spellid int
	/declare spellname string
	/declare spellrange int 50
	/declare targetid int

	/varset bufftimer 1s
	
	/if (!${buffaggro} && ${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /goto :skipmem

	/for cb 1 to BUFFQUEUESIZE
		/if (!${bufftarget[${cb}]}) /goto :needmem

		/varset targetid ${bufftarget[${cb}]}
		/varset spellid ${buffspell[${cb}]}
		/varset spellname ${Spell[${spellid}].Name}

		/if (!${targetid} || !${spellid} || !${Spawn[${targetid}].ID}) {
			/call RemoveBuff ${cb}
			/return FALSE
		}

		/if (${Me.Gem[${spellname}]} && ${Me.CurrentMana}>=${Spell[${spellid}].Mana}) {
			/if (!${Me.SpellReady[${spellname}]}) {
				/varset noyaulp 5
				/continue
			}
			/if (${Spell[${spellid}].TargetType.Left[5].Equal[Group]}) {
				/varset spellrange ${Spell[${spellid}].AERange}
				/if (${buffrange} && ${targetid}==${Me.ID}) {
					/for cg 0 to ${Group} 
						/if (${Spawn[pc ${Group.Member[${cg}]}].ID} && ${Group.Member[${cg}].Distance}>${spellrange}) /continue
					/next cg
				}
			} else {
				/varset spellrange ${Spell[${spellid}].MyRange}
				/if (!${spellrange}) /varset spellrange 100
			}

			/if (${Spawn[${targetid}].Distance}<=${spellrange}) {
				/call SetBandolier ${spellid}
				/if (${spellname.Left[9].Equal[Illusion:]}) {
					/call InGroup ${Spawn[${targetid}].Name}
					/if (!${Macro.Return}) { 
						/call RemoveBuff ${cb}
						/return FALSE
					}
					/casting "Project Illusion"|Alt
					/delay 5s ${Cast.Status.Equal[I]}
				}
				/casting "${spellname}"|gem9 -targetid|${targetid} ${bandset}
				/call WaitCast
				/if (${Select[${Cast.Result},CAST_SUCCESS,CAST_RESIST,CAST_TAKEHOLD,CAST_OUTDOORS]}) {
					/call RemoveBuff ${cb}
					/if (${Cast.Result.Equal[CAST_TAKEHOLD]} && ${targetid}==${Me.ID} && !${Me.Buff[${spellname}].ID}) {
						/for ct 1 to 10
							/if (${buffs[${ct}].Equal[${spellname}]}) {
								/varset bufftimer${ct} 5m
								/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${spellname} wont hold, recast delay 5m[+x+]
								/return TRUE
							}
						/next ct
					}
				}
				/return TRUE
			}
		}
	/next cb

	:needmem
	/if (${bufftarget[1]}) {
		/if (${Me.Gem[${Spell[${buffspell[1]}]}]}) /goto :skipmem
		/varset spellid ${Spell[${Me.Gem[${buffgem.Right[-3]}]}].ID}
		/for mc 1 to BUFFQUEUESIZE
			/if (!${bufftarget[${mc}]}) /break
			/if (${buffspell[${mc}]}==${spellid}) /goto :skipmem
		/next mc
		:memit
		/memorize "${Spell[${buffspell[1]}]}"|${buffgem.Right[-3]}
		/delay 10s ${Cast.Status.Equal[I]}
		/return TRUE
	}

	:skipmem
	/if (!${dobuffs} || ${paused}) /return FALSE
	/for ab 1 to ${buffcount}
		/if (${bufftimer${ab}}) /continue
		/if (${Me.Buff[${buffs[${ab}]}].ID} || ${Me.Buff[${buffname[${ab}]}].ID}) /continue
		/if (${Me.Song[${buffs[${ab}]}].ID} || ${Me.Song[${buffname[${ab}]}].ID}) /continue
		/if ((${buffwhen[${ab}].Equal[IDLE]} && ${idle}) || (${buffwhen[${ab}].Equal[NOATTACK]} && ${Me.Combat}) || (${buffwhen[${ab}].Equal[COMBAT]} && !${idle})) /continue
		
		/for ac 1 to BUFFQUEUESIZE
			/if (${buffspell[${ac}]}==${Spell[${buffs[${ab}]}].ID} && ${bufftarget[${ac}]}==${Me.ID}) /goto :nextbuff
		/next ac

		/if (${buffblock[${ab}].NotEqual[NULL]}) {
			/for bb 1 to 5
				/if (!${buffblock[${ab}].Token[${bb},|].Length}) /break
				/for bg 1 to 21
					/if (${buffblock[${ab}].Token[${bb},|].Equal[${Me.Buff[${bg}].Spell}]}) /goto :nextbuff
				/next bg
			/next bb
		}

		/if (${buffwhen[${ab}].Equal[NPCTAP]} && ${Target.ID}!=${ignoreid}) {
			/if (${Target.Type.Equal[NPC]} && ${Target.PctHPs}<${assistpct} && ${Me.SpellReady[${buffs[${ab}]}]}) {
				/call SetBandolier ${Spell[${buffs[${ab}]}].ID}
				/casting "${buffs[${ab}]}"|gem1 ${bandset}
				/call WaitCast
				/return TRUE
			}
		} else /if (${Me.CombatAbility[${buffs[${ab}]}]}) {
			/if (!${Me.CombatAbilityTimer[${buffs[${ab}]}]} && ${Me.PctEndurance}>=${buffvalue[${ab}]}) {
				/if (${Spell[${buffs[${ab}]}].CastTime} && !${buffaggro} && ${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /continue
				/docommand /disc ${buffs[${ab}]}
				/delay 10s !${Me.Casting.ID}
				/return TRUE
			}
		} else /if (${Me.AltAbility[${buffs[${ab}]}]}) {
			/if (${Me.AltAbilityReady[${buffs[${ab}]}]}) {
				/if (${Spell[${buffs[${ab}]}].CastTime} && !${buffaggro} && ${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /continue
				/casting "${buffs[${ab}]}"|alt -targetid|${mobid}
				/delay 10s !${Me.Casting.ID}
				/return TRUE
			}
		} else /if (${bard}) {
			/if (${Spell[${buffs[${ab}]}].ID} && ${Me.PctMana}>=${buffvalue[${ab}]} && ${Me.CurrentMana}>=${Spell[${buffs[${ab}]}].Mana}) {
				/if (${Me.Sitting}) /stand
				/if (!${sitmedtwist}) /varset sitmedtwist ${Twist}
				/if (${Twist}) {
					/delay 10s !${Window[CastingWindow]}
					/squelch /twist stop
					/delay 1s !${Twist}
				}
				/if (${Me.Casting.ID}) /stopsong
				/if (!${Me.Gem[${buffs[${ab}]}]}) {
					/memorize "${buffs[${ab}]}"|${buffgem}
					/delay 30s ${Me.Gem[${buffs[${ab}]}]}
					/if (${Me.Gem[${buffs[${ab}]}]}) /return TRUE
				}
				/delay 1s ${Me.SpellReady[${buffs[${ab}]}]}
				/if (${Me.SpellReady[${buffs[${ab}]}]}) {
					/cast ${Me.Gem[${buffs[${ab}]}]}
					/delay 5 ${Me.Casting.ID}==${Spell[${buffs[${ab}]}].ID}
					/delay 30s !${Window[CastingWindow]}
					/delay 5
					/if (${Me.Buff[${buffs[${ab}]}].ID} || ${Me.Buff[${buffname[${ab}]}].ID} || ${Me.Song[${buffs[${ab}]}].ID} || ${Me.Song[${buffname[${ab}]}].ID}) /varcalc bufftimer${ab} ${Spell[${buffs[${ab}]}].RecastTime}*10
					/if (!${bufftimer${ab}}) /varset bufftimer${ab} 5s
					/if (${Me.Casting.ID}) /stopsong
				} else {
					/varset bufftimer${ab} 15s
				}
			}
		} else /if (${Spell[${buffs[${ab}]}].TargetType.Equal[Self]}) {
			/call AddBuff ${Me.ID} ${Spell[${buffs[${ab}]}].ID}
		} else /if (${Spell[${buffs[${ab}]}].TargetType.Equal[Unknown]}) {
			/if (${Me.Pet.ID}) /call AddBuff ${Me.Pet.ID} ${Spell[${buffs[${ab}]}].ID}
		} else {
			/call AddBuff ${Me.ID} ${Spell[${buffs[${ab}]}].ID}
			/call InGroup ${buffgroup2}
			/if (${buffwhen[${ab}].NotEqual[COMBAT]} && ${Spawn[pc ${buffgroup2}].ID} && !${Macro.Return}) /call AddBuff ${Spawn[pc ${buffgroup2}].ID} ${Spell[${buffs[${ab}]}].ID}
			/call InGroup ${buffgroup3}
			/if (${buffwhen[${ab}].NotEqual[COMBAT]} && ${Spawn[pc ${buffgroup3}].ID} && !${Macro.Return}) /call AddBuff ${Spawn[PC ${buffgroup3}].ID} ${Spell[${buffs[${ab}]}].ID}
		}
	:nextbuff	
	/next ab

	/if (${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /return FALSE
	/if (${bufftarget[1]}==0 && ${buffreset.NotEqual[NULL]}) {
		/if (!${Me.Gem[${buffreset}]}) {
			/memorize "${buffreset}"|${buffgem} 
			/delay 5s ${Cast.Status.Equal[I]}
		}
	}
	
	/for br 1 to 10 {
		/if (${Me.Buff[${buffremove[${br}]}].ID}) { 
			/varcalc z ${Me.Buff[${buffremove[${br}]}].ID}-1
			/nomodkey /notify BuffWindow buff${z} leftmouseup
			/echo INFO: Buff Blocking "${buffremove[${br}]}"
		}
	}
	/next br
/return FALSE

Sub BuffLev
	/declare i int
	/declare told bool FALSE
	
	/if (${bufflevtime}) /return
	/varset bufflevtime 5s
	/if (${Me.Buff[Levitation].ID}) /return
	/if (${Me.Buff[Flight of Eagles].ID} || ${Me.Buff[Spirit of Eagle].ID}) /return
	/if (${Me.Buff[Dead Men Floating].ID} || ${Me.Buff[Dead Man Floating].ID}) /return
	
	/for i 1 to 5
		/if (!${bufflever.Token[${i},|].Length}) /return
		/if (${Spawn[pc ${bufflever.Token[${i},|]}].ID} && ${Spawn[pc ${bufflever.Token[${i},|]}].Distance}<100) {
			/if (${told}) /delay 3s
			/tell ${bufflever.Token[${i},|]} lev
			/varset told TRUE
		}
	/next i
/return

Sub BuffRez
	/declare i int
	/declare told bool FALSE
	/declare cnt int
	/declare deadcount int
	/declare corpseid int

	/varset deadcount ${SpawnCount[corpse radius 50 zradius 50]} 
	/if (${deadcount}) {
		/for i 1 to ${deadcount} 
			/varset corpseid ${NearestSpawn[${i},corpse radius 50 zradius 50].ID}
			/if (${Spawn[${corpseid}].Deity.ID}) /varcalc cnt ${cnt}+1
		/next i 
	}
	/if (${cnt}>=5) /return

	/for i 1 to 5
		/if (!${buffrezlist.Token[${i},|].Length}) /return
		/if (${Spawn[pc ${buffrezlist.Token[${i},|]}].ID} && ${Spawn[pc ${buffrezlist.Token[${i},|]}].Distance}<150) {
			/if (${told}) /delay 3s
			/tell ${buffrezlist.Token[${i},|]} buff rez
			/varset told TRUE
		}
	/next i
/return

Sub DebugBuffs
	/declare i int
	/declare alive bool
	/declare ready bool
	
	/echo DEBUG: targetid/targetname/alive/distance/spellid/spellname/ready
	/for i 1 to BUFFQUEUESIZE
		/if (!${bufftarget[${i}]}) {
			/call WriteDebug BuffQueue ${i} ENDBUFFQUEUE
			/return
		}
		/echo ${i}: ${bufftarget[${i}]}/${Spawn[${bufftarget[${i}]}].Name}/${Spawn[${bufftarget[${i}]}].ID}/${Spawn[${bufftarget[${i}]}].Distance} - ${buffspell[${i}]}/${Spell[${buffspell[${i}]}]}/${Me.SpellReady[${Spell[${buffspell[${i}]}]}]}
		/call WriteDebug BuffQueue ${i} "${bufftarget[${i}]}/${Spawn[${bufftarget[${i}]}].Name}/${Spawn[${bufftarget[${i}]}].ID}/${Spawn[${bufftarget[${i}]}].Distance} - ${buffspell[${i}]}/${Spell[${buffspell[${i}]}]}/${Me.SpellReady[${Spell[${buffspell[${i}]}]}]}"
	/next i
/return

Sub RemoveBuff(int start)
	/declare i int
	/declare end int ${Math.Calc[BUFFQUEUESIZE-1]}

	/for i ${start} to ${end}
		/varset bufftarget[${i}] ${bufftarget[${Math.Calc[${i}+1]}]}
		/varset buffspell[${i}] ${buffspell[${Math.Calc[${i}+1]}]}
		/if (!${bufftarget[${i}]}) /return
	/next i
	/varset bufftarget[BUFFQUEUESIZE] 0
	/varset buffspell[BUFFQUEUESIZE] 0
/return

Sub AddBuff(int targetid, int spellid)
	/declare i int

	/if (!${targetid} || !${spellid}) /return
	
	/for i 1 to BUFFQUEUESIZE
		/if (${bufftarget[${i}]}==${targetid} && ${buffspell[${i}]}==${spellid}) /return
		/if (!${bufftarget[${i}]}) {
			/varset bufftarget[${i}] ${targetid}
			/varset buffspell[${i}] ${spellid}
			/return
		}
	/next i
/return

Sub DoRebuffs
	/declare i int
	/declare j int
	/declare f int

	/for i 1 to ${buffcount}
		/if (${Select[${buffwhen[${i}]},COMBAT,NPCTAP]}) /goto :nextbuff
		/if (${bard} || ${Me.CombatAbility[${buffs[${i}]}]}) /goto :nextbuff

		/for j 1 to BUFFQUEUESIZE
			/if (${buffspell[${j}]}==${Spell[${buffs[${i}]}].ID} && ${bufftarget[${j}]}==${Me.ID}) /goto :nextbuff
		/next j

		/if (${buffblock[${i}].NotEqual[NULL]}) {
			/for j 1 to 5
				/if (!${buffblock[${i}].Token[${j},|].Length}) /goto :notblocked
				/for f 1 to 21
					/if (${buffblock[${i}].Token[${j},|].Equal[${Me.Buff[${f}].Spell}]}) /goto :nextbuff
				/next f
			/next j
		}
		:notblocked

		/if (${Spell[${buffs[${i}]}].TargetType.Equal[Single]}) {
			/for f 0 to ${Group}
				/if (${Spawn[pc ${Group.Member[${f}]}].ID}) /call AddBuff ${Group.Member[${f}].ID} ${Spell[${buffs[${i}]}].ID}
			/next f 
			/if (${Me.Pet.ID}) /call AddBuff ${Me.Pet.ID} ${Spell[${buffs[${i}]}].ID}
		} else /if (${Spell[${buffs[${i}]}].TargetType.Equal[Self]}) {
			/call AddBuff ${Me.ID} ${Spell[${buffs[${i}]}].ID}
		} else /if (${Spell[${buffs[${i}]}].TargetType.Equal[Unknown]}) {
			/if (${Me.Pet.ID}) /call AddBuff ${Me.Pet.ID} ${Spell[${buffs[${i}]}].ID}
		} else {
			/call AddBuff ${Me.ID} ${Spell[${buffs[${i}]}].ID}
			/call InGroup ${buffgroup2}
			/if (${buffwhen[${i}].NotEqual[COMBAT]} && ${Spawn[pc ${buffgroup2}].ID} && !${Macro.Return}) /call AddBuff ${Spawn[pc ${buffgroup2}].ID} ${Spell[${buffs[${i}]}].ID}
			/call InGroup ${buffgroup3}
			/if (${buffwhen[${i}].NotEqual[COMBAT]} && ${Spawn[pc ${buffgroup3}].ID} && !${Macro.Return}) /call AddBuff ${Spawn[PC ${buffgroup3}].ID} ${Spell[${buffs[${i}]}].ID}
		}
		:nextbuff	
	/next i
/return

Sub Event_SetBuff(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Buff${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset dobuffs TRUE 
		/echo INFO: Auto Buffing ON!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset dobuffs FALSE 
		/echo INFO: Auto Buffing OFF!
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset buffset Buffs
		/if (${Line.Arg[4].Length}) /varset buffset Buffs${Line.Arg[4]}
		/echo INFO: Buff Set is now ${buffset}
		/call SetIni Buffs buffset ${buffset}
		/call BuffingIni
	} else /if (${Line.Arg[3].Equal[GOM]}) {
		/varset buffgom ${Me.Gem[${Line.Arg[4]}].Name}
		/varset buffgompercent ${Line.Arg[5]}
		/varset buffgomtarget ${Line.Arg[6]}
		/call SetIni Buffs gomspell "${buffgom}"
		/echo INFO: Gift of Mana - ${buffgom}
	} else /if (${Line.Arg[3].Equal[CLEAR]}) {
		/if (${Me.Buff[${Line.Arg[4]}].ID}) { 
			/declare i int
			/varcalc i ${Me.Buff[${Line.Arg[4]}].ID}-1
			/nomodkey /notify BuffWindow buff${i} leftmouseup
		} else /if (${Line.Arg[4].Equal[ALL]}) {
			/declare i int
			/declare j int
			/for i 1 to 40
				/varcalc j ${i}-1
				/if (${Me.Buff[${i}].ID}) /nomodkey /notify BuffWindow buff${j} leftmouseup
			/next i
		}
	} else /if (${Line.Arg[3].Equal[REBUFF]}) {
		/call DoRebuffs
	} else /if (${Line.Arg[3].Equal[LEV]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset bufflev TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset bufflev FALSE
		} else {
			/varset bufflever ${Line.Arg[4]}
		}
		/call SetIni Buffs levcaster ${bufflever}
		/echo INFO: Lev Buffing = ${bufflev} using ${bufflever}
	} else /if (${Line.Arg[3].Equal[REZ]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset buffrez TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset buffrez FALSE
		} else {
			/varset buffrezlist ${Line.Arg[4]}
		}
		/call SetIni Buffs buffrez ${buffrez}
		/call SetIni Buffs buffrezlist ${buffrezlist}
		/echo INFO: Rez Buffing = ${buffrez} using ${buffrezlist}
	} else /if (${Line.Arg[3].Equal[DEBUG]}) {
		/call DebugBuffs
		/return
	} else /if (${Line.Arg[3].Equal[LIST]}) {
		/declare i int
		/echo INFO: Buffs Listing [${buffset}]
		/echo INFO: Buffs = ${dobuffs}!
		/for i 1 to ${buffcount}
			/if (${buffs[${i}].NotEqual[NULL]}) {
				/if (${Me.Book[${buffs[${i}]}]}) {
					/echo ...buff${i}: ${buffs[${i}]}/${buffname[${i}]}, ${buffwhen[${i}]}, ${buffblock[${i}]} (Spell)
				} else /if (${Me.CombatAbility[${buffs[${i}]}]}) {
					/echo ...buff${i}: ${buffs[${i}]}/${buffname[${i}]}, ${buffwhen[${i}]}, ${buffblock[${i}]} (CA)
				} else {
					/echo ...buff${i}: ${buffs[${i}]}/${buffname[${i}]}, ${buffwhen[${i}]}, ${buffblock[${i}]} NOT FOUND IN SPELL BOOK!!!
				}
			}
		/next i
		/return
	} else /if (${Line.Arg[3].Equal[DELAY]}) {
		/echo INFO: Buffing delay on startup or after rez = ${Line.Arg[4]}s
		/call SetIni Buffs delay "${Line.Arg[4]}s"
	} else /if (${Line.Arg[3].Equal[RANGE]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset buffrange TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset buffrange FALSE
		}
		/echo INFO: Check if my group in buff range = ${buffrange}
		/call SetIni Buffs range ${buffrange}
	} else /if (${Line.Arg[3].Equal[ATTACK]}) {
		/if (${Line.Arg[4].Arg[1,:].Length}==1) {
			/call ParseOptions ${Line.Arg[4]}
			/varset attackbuff1 ${parsespell}
			/varset attackmana1 ${parsemana}
			/varcalc attackdur1 ${Spell[${attackbuff1}].Duration}*60
			/call LoadIni Buffs ${Spell[${attackbuff1}].ID} attackdur1
			/varcalc attackdur1 ${attackdur1}*${focusbeni}
			/varcalc attackdur1 ${attackdur1}-${attackdur1}/10
			/call SetIni Buffs attackspell1 "${attackbuff1}"
			/call SetIni Buffs buffcombatonly2 "${buffcombatonly2}"
			/call SetIni Buffs attackdur1 ${attackdur1}
			/call SetIni Buffs mana1 "${attackmana1}"
			/echo INFO: Attack Buff1 Spell set to ${attackbuff1}, mana>${attackmana1}% recast=${attackdur1}
			/varset doattackbuff TRUE
			/return
		}

		/varset attack1 nobody
		/varset attack2 nobody
		/varset attack3 nobody
		/varset attack4 nobody
		/varset attack5 nobody
		/if (${Line.Arg[4].Length}) /varset attack1 ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset attack2 ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset attack3 ${Line.Arg[6]}
		/if (${Line.Arg[7].Length}) /varset attack4 ${Line.Arg[7]}
		/if (${Line.Arg[8].Length}) /varset attack5 ${Line.Arg[8]}
		/call SetIni Buffs attack1 ${attack1}
		/call SetIni Buffs attack2 ${attack2}
		/call SetIni Buffs attack3 ${attack3}
		/call SetIni Buffs attack4 ${attack4}
		/call SetIni Buffs attack5 ${attack5}
		/echo INFO: ${attackbuff1} rotation set on ${attack1},${attack2},${attack3},${attack4},${attack5}
	} else /if (${Line.Arg[3].Equal[ATTACK2]}) {
		/if (${Line.Arg[4].Arg[1,:].Length}==1) {
			/call ParseOptions ${Line.Arg[4]}
			/varset attackbuff2 ${parsespell}
			/varset attackmana2 ${parsemana}
			/varcalc attackdur2 ${Spell[${attackbuff2}].Duration}*60
			/call LoadIni Buffs ${Spell[${attackbuff2}].ID} attackdur2
			/varcalc attackdur2 ${attackdur2}*${focusbeni}
			/varcalc attackdur2 ${attackdur2}-${attackdur2}/10
			/call SetIni Buffs buffcombatonly2 "${buffcombatonly2}"
			/call SetIni Buffs attackspell2 "${attackbuff2}"
			/call SetIni Buffs attackdur2 ${attackdur2}
			/call SetIni Buffs mana2 "${attackmana2}"
			/echo INFO: Attack Buff2 Spell set to ${attackbuff2}, mana>${attackmana2}% recast=${attackdur2}
			/varset doattackbuff TRUE
			/return
		}

		/varset attack21 nobody
		/varset attack22 nobody
		/varset attack23 nobody
		/varset attack24 nobody
		/varset attack25 nobody
		/if (${Line.Arg[4].Length}) /varset attack21 ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset attack22 ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset attack23 ${Line.Arg[6]}
		/if (${Line.Arg[7].Length}) /varset attack24 ${Line.Arg[7]}
		/if (${Line.Arg[8].Length}) /varset attack25 ${Line.Arg[8]}
		/call SetIni Buffs attack21 ${attack21}
		/call SetIni Buffs attack22 ${attack22}
		/call SetIni Buffs attack23 ${attack23}
		/call SetIni Buffs attack24 ${attack24}
		/call SetIni Buffs attack25 ${attack25}
		/echo INFO: ${attackbuff2} rotation set on ${attack21},${attack22},${attack23},${attack24},${attack25}
	} else /if (${Line.Arg[3].Equal[ATTACK3]}) {
		/if (${Line.Arg[4].Arg[1,:].Length}==1) {
			/call ParseOptions ${Line.Arg[4]}
			/varset attackbuff3 ${parsespell}
			/varset attackmana3 ${parsemana}
			/varcalc attackdur3 ${Spell[${attackbuff3}].Duration}*60
			/call LoadIni Buffs ${Spell[${attackbuff3}].ID} attackdur3
			/varcalc attackdur3 ${attackdur3}*${focusbeni}
			/varcalc attackdur3 ${attackdur3}-${attackdur3}/10
			/call SetIni Buffs buffcombatonly3 "${buffcombatonly3}"
			/call SetIni Buffs attackspell3 "${attackbuff3}"
			/call SetIni Buffs attackdur3 ${attackdur3}
			/call SetIni Buffs mana3 "${attackmana3}"
			/echo INFO: Attack Buff3 Spell set to ${attackbuff3}, mana>${attackmana3}% recast=${attackdur3}
			/varset doattackbuff TRUE
			/return
		}

		/varset attack31 nobody
		/varset attack32 nobody
		/varset attack33 nobody
		/varset attack34 nobody
		/varset attack35 nobody
		/if (${Line.Arg[4].Length}) /varset attack31 ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset attack32 ${Line.Arg[5]}
		/if (${Line.Arg[6].Length}) /varset attack33 ${Line.Arg[6]}
		/if (${Line.Arg[7].Length}) /varset attack34 ${Line.Arg[7]}
		/if (${Line.Arg[8].Length}) /varset attack35 ${Line.Arg[8]}
		/call SetIni Buffs attack31 ${attack31}
		/call SetIni Buffs attack32 ${attack32}
		/call SetIni Buffs attack33 ${attack33}
		/call SetIni Buffs attack34 ${attack34}
		/call SetIni Buffs attack35 ${attack35}
		/echo INFO: ${attackbuff3} rotation set on ${attack31},${attack32},${attack33},${attack34},${attack35}
	} else /if (${Line.Arg[3].Equal[GEM]}) {
		/varset buffgem gem${Line.Arg[4]}
		/varset buffreset ${Me.Gem[${Line.Arg[4]}].Name}
		/echo INFO: BuffGem=${buffgem}, Reload spell=${buffreset}
		/call SetIni Buffs gem ${buffgem}
		/call SetIni Buffs reset "${buffreset}"
	} else /if (${Line.Arg[3].Equal[GROUP]}) {
		/varset dobuffs TRUE 
		/varset buffgroup2 nobody
		/varset buffgroup3 nobody
		/if (${Line.Arg[4].Length}) /varset buffgroup2 ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset buffgroup3 ${Line.Arg[5]}
		/echo INFO: Doing group buffs on ${buffgroup2} & ${buffgroup3}
		/call SetIni Buffs group2 ${buffgroup2}
		/call SetIni Buffs group3 ${buffgroup3}
	} else /if (${Line.Arg[3].Length}<=2 && ${Line.Arg[4].Length}==1 && ${Line.Arg[5].Length}==1) {
		/declare i int

		/for i ${Line.Arg[4]} to ${Line.Arg[5]}
			/delay 1m ${Cast.Ready[${Me.Gem[${Line.Arg[3]}].Name}]}
			/if (${i}==6) {
				/casting ${Me.Gem[${Line.Arg[3]}].ID}|gem -targetid|${Group.Member[0].ID}
			} else {
				/casting ${Me.Gem[${Line.Arg[3]}].ID}|gem -targetid|${Group.Member[${i}].ID}
			}
			/delay 1m ${Cast.Status.Equal[I]}
		/next i
	}

	/call SetIni Buffs active ${dobuffs}
/return 

Sub DoBuffGom
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE
		/if (${Me.Song[Gift of Mana].ID} && ${Me.SpellReady[${buffgom}]}) {
			/if (${EQBC.Connected} && ${bcspam}) /docommand /bc [+t+]Gift of Mana [${buffgom}][+x+]
				/target ${Me}
				/delay 2
				/casting "${buffgom}"
				/call WaitCast
			/if (${Me.Class.Name.Equal[Cleric]}) /target ${curtank}
		}
		:buffgombottom
/return TRUE

Sub DoAttackBuff
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE
	
	/if (${Me.Class.Name.Equal[Beastlord]} || ${Me.Class.Name.Equal[Shaman]} || ${Me.Class.Name.Equal[Shadow Knight]}) /goto :attackbuffskip
	/if (!${idle}) /return FALSE
	:attackbuffskip
	
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE
	/if (${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /return FALSE

	/declare i int
	/declare targetid int ${Target.ID}
	/declare duration int
	/declare spelltarget int

	/if (${attackbuff1.Equal[NULL]} || !${Me.SpellReady[${attackbuff1}]}) /goto :check2
	/if (${Me.CurrentMana}<${Spell[${attackbuff1}].Mana}) /goto :check2
	/if (${Me.PctMana}<${attackmana1}) /goto :check2
	/if (!${idle} && ${buffcombatonly1}) /goto :check2

	/for i 1 to 10
		/if (${attack${i}.Equal[NULL]}) /goto :check2

		/varset spelltarget 0
		/if (${attack1.Equal[GROUP]}) {
			/varset spelltarget ${Group.Member[${i}].ID}
			/if (${Spawn[${spelltarget}].Class.PureCaster}) /varset spelltarget 0
		} else {
			/varset spelltarget ${Spawn[pc ${attack${i}}].ID}
		}

		/if (${spelltarget} && !${attack1timer${i}} && ${Spawn[${spelltarget}].Distance}<=${Spell[${attackbuff1}].MyRange}) {
			/call SaveState
			/call SetBandolier ${Spell[${attackbuff1}].ID}
			/casting "${attackbuff1}"|9 -targetid|${spelltarget} ${bandset}
			/call WaitCast
			/varset attack1timer${i} 200
			/if (${Cast.Result.Equal[CAST_SUCCESS]}) /varset attack1timer${i} ${attackdur1}
			/call RestoreState
			/return TRUE
		}
	/next i

	:check2
	/if (${attackbuff2.Equal[NULL]} || !${Me.SpellReady[${attackbuff2}]}) /goto :check3
	/if (${Me.CurrentMana}<${Spell[${attackbuff2}].Mana}) /goto :check3
	/if (${Me.PctMana}<${attackmana2}) /goto :check3
	/if (!${idle} && ${buffcombatonly2}) /goto :check3

	/for i 1 to 5
		/if (${attack2${i}.Equal[NULL]}) /goto :check3

		/varset spelltarget 0
		/if (${attack21.Equal[GROUP]}) {
			/varset spelltarget ${Group.Member[${i}].ID}
			/if (${Spawn[${spelltarget}].Class.PureCaster}) /varset spelltarget 0
		} else {
			/varset spelltarget ${Spawn[pc ${attack2${i}}].ID}
		}

		/if (${spelltarget} && !${attack2timer${i}} && ${Spawn[${spelltarget}].Distance}<=${Spell[${attackbuff2}].MyRange}) {
			/call SaveState
			/call SetBandolier ${Spell[${attackbuff2}].ID}
			/casting "${attackbuff2}"|9 -targetid|${spelltarget} ${bandset}
			/call WaitCast
			/varset attack2timer${i} 200
			/if (${Cast.Result.Equal[CAST_SUCCESS]}) /varset attack2timer${i} ${attackdur2}
			/call RestoreState
			/return TRUE
		}
	/next i

	:check3
	/if (${attackbuff3.Equal[NULL]} || !${Me.SpellReady[${attackbuff3}]}) /return FALSE
	/if (${Me.CurrentMana}<${Spell[${attackbuff3}].Mana}) /return FALSE
	/if (${Me.PctMana}<${attackmana3}) /return FALSE
	/if (!${idle} && ${buffcombatonly3}) /return FALSE

	/for i 1 to 5
		/if (${attack3${i}.Equal[NULL]}) /return FALSE

		/varset spelltarget 0
		/if (${attack31.Equal[GROUP]}) {
			/varset spelltarget ${Group.Member[${i}].ID}
			/if (${Spawn[${spelltarget}].Class.PureCaster}) /varset spelltarget 0
		} else {
			/varset spelltarget ${Spawn[pc ${attack3${i}}].ID}
		}

		/if (${spelltarget} && !${attack3timer${i}} && ${Spawn[${spelltarget}].Distance}<=${Spell[${attackbuff3}].MyRange}) {
			/call SaveState
			/call SetBandolier ${Spell[${attackbuff3}].ID}
			/casting "${attackbuff3}"|9 -targetid|${spelltarget} ${bandset}
			/call WaitCast
			/varset attack3timer${i} 200
			/if (${Cast.Result.Equal[CAST_SUCCESS]}) /varset attack3timer${i} ${attackdur3}
			/call RestoreState
			/return TRUE
		}
	/next i
/return  FALSE

Sub MezIni
	/call LoadIni mez spam mezspam
	/call LoadIni mez channel mezchannel

	/call LoadIni Mez spell mezspell
	/call LoadIni Mez min mezminlevel
	/call LoadIni Mez max mezmaxlevel
	/call LoadIni Mez distance mezdistance
	/call LoadIni Mez hp mezhp
	/call LoadIni Mez delay mezmainwait
	/call LoadIni Mez clicky mezclicky
	/call LoadIni Mez clickymax mezclickymax
	/call LoadIni Mez clickyuse mezclickyuse

	/call LoadIni Mez msgmezzed mezmsgmez
	/call LoadIni Mez msgresist mezmsgresist
	/call LoadIni Mez msgimmune mezmsgimmune
	/call LoadIni Mez msgremez mezmsgremez
/return

Sub DoMez
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	/declare j int
	/declare duration int
	/declare testmob int
	/declare starthp int
	/declare diff int

	/if (!${bard} && ${Me.CurrentMana}<${Spell[${mezspell}].Mana}) /return

	:top
	/if (${SpawnCount[npc radius ${mezdistance} zradius 50 range ${mezminlevel} ${mezmaxlevel}]}) {
		/for i 1 to ${SpawnCount[npc radius ${mezdistance} zradius 50 range ${mezminlevel} ${mezmaxlevel}]}

			/if (${Window[RespawnWnd].Open}) /return TRUE
			/varset testmob ${NearestSpawn[${i},npc radius ${mezdistance} zradius 50 range ${mezminlevel} ${mezmaxlevel}].ID}
			/if (!${Spawn[${testmob}].LineOfSight} || ${testmob}==${ignoreid} || ${Spawn[${testmob}].Body.Name.Equal[Giant]}) /goto :nexti
			/if (${testmob}==${mezmainid} && ${mezmaindly}) {
				/if (${mezmaindly}>50000) /varset mezmaindly ${mezmainwait}
				/goto :nexti
			}

			/if (${mezonly.Length}) {
				/for j 1 to 10
					/if (!${mezonly.Token[${j},|].Length}) /goto :nexti
					/if (${Spawn[${testmob}].CleanName.Find[${mezonly.Token[${j},|]}]}) /goto :mezit
				/next j
				/goto :nexti
				:mezit
			}

			/if (!${mezlist.Find[${Spawn[${testmob}].ID}]} && !${mezignore.Find[${Spawn[${testmob}].ID}]}) {
				/if (${Me.Combat}) /attack off
				/if (${Stick.Active}) /squelch /stick off
				/target id ${testmob}
				/delay 3 ${Target.ID}==${testmob}
				/if (${Target.ID}==${testmob} && ${Target.PctHPs}>=${mezhp}) {

					/varset starthp ${Target.PctHPs}
					/if (${bard}) {
						/call BardCast "${mezspell}" ${testmob} ${mezhp}
						/varset debuffsdone FALSE
						/if (${Macro.Return.Equal[CAST_SUCCESS]}) {
							/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgmez}${Spawn[${testmob}].CleanName}
							/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgmez}${Spawn[${testmob}].CleanName}[+x+]
							/varset mezlist ${mezlist}${testmob}|
							/if (!${Defined[meztimer${testmob}]}) /declare meztimer${testmob} timer outer
							/varset meztimer${testmob} 12s
						} else /if (${Select[${Macro.Return},CAST_TAKEHOLD,CAST_IMMUNE]}) {
							/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgimmune}${Spawn[${testmob}].CleanName}
							/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgimmune}${Spawn[${testmob}].CleanName}[+x+]
							/varset mezignore ${mezignore}${testmob}|
						} else /if (${Macro.Return.Equal[CAST_RESIST]}) {
							/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgresist}${Spawn[${testmob}].CleanName}
							/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+Y+]${mezmsgresist}${Spawn[${testmob}].CleanName}[+x+]
						}
						/varset leashtimer 30
						/goto :top
					} else /if (${mezclickyuse} && ${Target.Level}<=${mezclickymax} && ${FindItemCount[=${mezclicky}]} && !${FindItem[=${mezclicky}].Timer}) {
						/casting "${mezclicky}"|Item -targetid|${testmob}
						/varset duration ${Math.Calc[${FindItem[=${mezclicky}].Spell.Duration}*60]}
						/varset duration ${Math.Calc[${duration}-${duration}/5]}
					} else {
						/delay 3s ${Cast.Ready[${mezspell}]}
						/casting "${mezspell}"|gem9 -targetid|${testmob}
						/varset duration ${Math.Calc[${Spell[${mezspell}].Duration}*60*${focusdetr}]}
						/varset duration ${Math.Calc[${duration}-${duration}/5]}
					}
					:mez1
					/delay 1
					/varcalc diff ${starthp}-${Target.PctHPs}
					/if (${Cast.Status.NotEqual[I]} && ${diff}>2) {
						/if (${Cast.Status.NotEqual[I]}) /interrupt
						/varset mezignore ${mezignore}${testmob}|
						/goto :top
					}
					/if (${Cast.Status.NotEqual[I]} && ${Target.PctHPs}>=${mezhp}) /goto :mez1

					/varset debuffsdone FALSE
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
						/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgmez}${Spawn[${testmob}].CleanName}
						/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgmez}${Spawn[${testmob}].CleanName} - <${Me.PctMana}m>[+x+]
						/varset mezlist ${mezlist}${testmob}|
						/if (!${Defined[meztimer${testmob}]}) /declare meztimer${testmob} timer outer
						/varset meztimer${testmob} ${duration}
					} else /if (${Select[${Cast.Result},CAST_TAKEHOLD,CAST_IMMUNE]}) {
						/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgimmune}${Spawn[${testmob}].CleanName}
						/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgimmune}${Spawn[${testmob}].CleanName} - <${Me.PctMana}m>[+x+]
						/varset mezignore ${mezignore}${testmob}|
					} else /if (${Cast.Result.Equal[CAST_RESIST]}) {
						/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgresist}${Spawn[${testmob}].CleanName}
						/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+Y+]${mezmsgresist}${Spawn[${testmob}].CleanName} - <${Me.PctMana}m>[+x+]
					}

				} else {
					/if (${Target.PctHPs}<${mezhp}) /varset mezignore ${mezignore}${testmob}|
				}
				/goto :top
			}
			:nexti
		/next i
	}

	/for i 1 to 10
		/if (${Window[RespawnWnd].Open}) /return
		/if (${mezlist.Token[${i},|].Length}) {
			/if (${Spawn[${mezlist.Token[${i},|]}].ID} && ${Spawn[${mezlist.Token[${i},|]}].Type.NotEqual[CORPSE]}) {
				/if (!${meztimer${mezlist.Token[${i},|]}} && ${Spawn[${mezlist.Token[${i},|]}].Distance}<=${Math.Calc[${mezdistance}*1.25]}) {
					/if (${Me.Combat}) /attack off
					/if (${Stick.Active}) /squelch /stick off
					/target id ${mezlist.Token[${i},|]}
					/delay 3 ${Target.ID}==${mezlist.Token[${i},|]}
					/if (${Target.ID}==${mezlist.Token[${i},|]} && ${Target.PctHPs}>=${mezhp}) {
						/if (${bard}) {
							/call BardCast "${mezspell}" ${mezlist.Token[${i},|]} ${mezhp}
							/if (${Macro.Return.Equal[CAST_SUCCESS]}) {
								/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgremez}${Spawn[${mezlist.Token[${i},|]}].CleanName}
								/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgremez}${Spawn[${mezlist.Token[${i},|]}].CleanName}[+x+]
								/varset meztimer${mezlist.Token[${i},|]} 13s
							}
						} else {
							/if (${mezclickyuse} && ${Target.Level}<=${mezclickymax} && ${FindItemCount[=${mezclicky}]} && !${FindItem[=${mezclicky}].Timer}) {
								/casting "${mezclicky}"|Item -targetid|${testmob}
								/varset duration ${Math.Calc[${FindItem[=${mezclicky}].Spell.Duration}*60]}
								/varset duration ${Math.Calc[${duration}-${duration}/5]}
							} else {
								/delay 3s ${Cast.Ready[${mezspell}]}
								/casting "${mezspell}"|gem9 -targetid|${testmob}
								/varset duration ${Math.Calc[${Spell[${mezspell}].Duration}*60*${focusdetr}]}
								/varset duration ${Math.Calc[${duration}-${duration}/5]}
							}
							/delay 5s ${Cast.Status.Equal[I]}
							/varset debuffsdone FALSE
							/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
								/if (${mezspam} && (${mezchannel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${mezchannel} ${mezmsgremez}${Spawn[${mezlist.Token[${i},|]}].CleanName}
								/if (${EQBC.Connected} && ${bcspam}) /docommand /${bctell} [+y+]${mezmsgremez}${Spawn[${mezlist.Token[${i},|]}].CleanName} - <${Me.PctMana}m>[+x+]
								/varset meztimer${mezlist.Token[${i},|]} ${duration}
							}
						}
					} else /if (${Target.ID}==${mezlist.Token[${i},|]} && ${Target.PctHPs}<${mezhp}) {
						/varset meztimer${mezlist.Token[${i},|]} 30m
					}
				}
			}
		}
	/next i

	/declare mezlist2 string
	/declare mezignore2 string

	/for i 1 to 10
		/if (${mezlist.Token[${i},|].Length}) {
			/if (${Spawn[${mezlist.Token[${i},|]}].ID} && ${Spawn[${mezlist.Token[${i},|]}].Type.NotEqual[CORPSE]} && ${Spawn[${mezlist.Token[${i},|]}].Distance}<${Math.Calc[${mezdistance}*1.25]}) {
				/varset mezlist2 ${mezlist2}${mezlist.Token[${i},|]}|
			} else {
				/if (${Defined[meztimer${mezlist.Token[${i},|]}]}) /deletevar meztimer${mezlist.Token[${i},|]}
			}
		}
		/if (${mezignore.Token[${i},|].Length}) {
			/if (${Spawn[${mezignore.Token[${i},|]}].ID} && ${Spawn[${mezignore.Token[${i},|]}].Type.NotEqual[CORPSE]} && ${Spawn[${mezignore.Token[${i},|]}].Distance}<${mezdistance}) {
				/varset mezignore2 ${mezignore2}${mezignore.Token[${i},|]}|
			}
		}
	/next i
	/varset mezlist ${mezlist2}
	/varset mezignore ${mezignore2}
/return

Sub Event_SetMez(string Line)
	/declare i int

	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Mez${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset domez TRUE
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset domez FALSE
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset mezspam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset mezspam FALSE
		/echo INFO: Mez Spam=${mezspam}
		/call SetIni Mez spam ${mezspam}
	} else /if (${Line.Arg[3].Equal[CHANNEL]}) {
		/varset mezchannel ${Line.Arg[4]}
		/call SetIni Mez channel ${mezchannel}
	} else /if (${Line.Arg[3].Equal[SPELL]}) {
		/varset mezspell ${Me.Gem[${Line.Arg[4]}].Name}
		/call SetIni Mez spell "${mezspell}"
	} else /if (${Line.Arg[3].Equal[RANGE]}) {
		/varset mezminlevel ${Line.Arg[4]}
		/varset mezmaxlevel ${Line.Arg[5]}
		/call SetIni Mez min ${mezminlevel}
		/call SetIni Mez max ${mezmaxlevel}
	} else /if (${Line.Arg[3].Equal[DELAY]}) {
		/varset mezmainwait ${Line.Arg[4]}
		/call SetIni Mez delay ${mezmainwait}
	} else /if (${Line.Arg[3].Equal[DISTANCE]}) {
		/varset mezdistance ${Line.Arg[4]}
		/call SetIni Mez distance ${mezdistance}
	} else /if (${Line.Arg[3].Equal[HP]}) {
		/varset mezhp ${Line.Arg[4]}
		/call SetIni Mez hp ${mezhp}
	} else /if (${Line.Arg[3].Equal[ONLY]}) {
		/varset mezonly ${Line.Arg[4]}
	} else /if (${Line.Arg[3].Equal[CLICKY]}) {
		/if (${Line.Arg[4].Equal[SET]}) {
			/varset mezclicky ${Cursor.Name}
			/varset mezclickymax ${Line.Arg[5]}
			/varset mezclickyuse TRUE
		} else /if (${Line.Arg[4].Equal[ON]}) {
			/varset mezclickyuse TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset mezclickyuse FALSE
		}
		/call SetIni Mez clicky "${mezclicky}"
		/call SetIni Mez clickymax ${mezclickymax}
		/call SetIni Mez clickyuse ${mezclickyuse}
	}

	/echo >>>>>>>>>>>>>>>>>>>>>>>><<<<<<<<<<<<<<<<<<<<<<<<
	/echo INFO: Auto-mezzing = ${domez}
	/echo INFO: Mez spell = ${mezspell}
	/echo INFO: Stop mezzing when below ${mezhp}% hp
	/echo INFO: Mezzing mobs betweeen levels ${mezminlevel} and ${mezmaxlevel}
	/echo INFO: Mezzing mobs within ${mezdistance} feet
	/echo INFO: Mezzing MT pull after ${mezmainwait}
	/if (${mezonly.Length}) /echo INFO: Mezzing only mobs with ${mezonly}
	/if (${mezclicky.Length}) /echo INFO: Mez clicky=${mezclicky}, max level=${mezclickymax}, use=${mezclickyuse}
/return

Sub DebuffIni
	/declare d int

	/call LoadIni Debuffs active dodebuffs
	/call LoadIni Debuffs set debuffset
	/call LoadIni Debuffs spam debuffspam
	/call LoadIni Debuffs channel debuffchannel
	/call LoadIni Debuffs AEdistance debuffAEdistance
	
	/call LoadIni ${debuffset} mode debuffmode
	/call LoadIni ${debuffset} retry debuffretry
	/call LoadIni ${debuffset} normalpct debuffnormalpct
	/call LoadIni ${debuffset} bosspct debuffbosspct
	/for d 1 to 10
		/call LoadIni ${debuffset} debuff${d} debuff[${d}]
		/if (${debuff[${d}].Length}==1) /varset debuff[${d}] ${Me.Gem[${debuff[${d}]}]}
		/call LoadIni ${debuffset} mana${d} debuffmana[${d}]
		/call LoadIni ${debuffset} endur${d} debuffendur[${d}]
		/call LoadIni ${debuffset} pct${d} debuffpct[${d}]
		/call LoadIni ${debuffset} dist${d} debuffdist[${d}]
		/call LoadIni ${debuffset} npc${d} debuffnpc[${d}]
		/call LoadIni ${debuffset} cast${d} debuffcast[${d}]
		/call LoadIni ${debuffset} once${d} debuffonce[${d}]
		/call LoadIni ${debuffset} ready${d} debuffready[${d}]
		/call LoadIni ${debuffset} boss${d} debuffboss[${d}]
		/call FindMsgNum "${debuff[${d}]}"
		/varset debuffmsg[${d}] ${Macro.Return}
	/next d
	/call DebuffRangeCheck
	/if (${dodebuffs}) /echo INFO: Debuffs Are ON!
/return

Sub DebuffRangeCheck
	/declare i int
	/declare dist int

	/varset debuffrange 9999

	/for i 1 to MAXARGS
		/if (${Me.Ability[${debuff[${i}]}]}) {
			/varset dist 0
		} else /if (${Me.AltAbility[${debuff[${i}]}]}) {
			/varset dist ${Spell[${debuff[${i}]}].Range}
		} else /if (${Me.CombatAbility[${debuff[${i}]}]}) {
			/varset dist ${Spell[${debuff[${i}]}].Range}
		} else /if (${FindItemCount[=${debuff[${i}]}]}) {
			/varset dist ${FindItem[=${debuff[${i}]}].Spell.Range}
		} else /if (${Spell[${debuff[${i}]}].ID}) {
			/varset dist ${Spell[${debuff[${i}]}].MyRange}
		} else {
			/varset dist 0
		}
		/if (${dist} && ${dist}<${debuffrange}) /varset debuffrange ${dist}
	/next i
/return

Sub DoDebuffs
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	/declare j int
	/declare k int
	/declare q int
	/declare mobid int
	/declare try int 1
	/declare result string

	/if (${Target.Type.Equal[NPC]} && ${Target.LineOfSight} && ${Target.ID}!=${ignoreid} && ${Target.Distance}<=${debuffrange} && (${Target.PctHPs}<=${debuffnormalpct} && !${debufflist.Find[${Target.ID}]} || !${debufflist.Find[${Target.ID}]} && (${Target.Level}>=${bosslevel} && ${Target.PctHPs}<=${debuffbosspct}))) {
		/if (!${debufflist.Find[${Target.ID}]}) /varset debufflist ${debufflist}${Target.ID}|
	}
	/if (${Me.TargetOfTarget.Type.Equal[NPC]} && ${Me.TargetOfTarget.LineOfSight} && ${Me.TargetOfTarget.ID}!=${ignoreid} && ${Me.TargetOfTarget.Distance}<=${debuffrange} && (${Me.TargetOfTarget.PctHPs}<=${debuffnormalpct} && !${debufflist.Find[${Me.TargetOfTarget.ID}]} || !${debufflist.Find[${Me.TargetOfTarget.ID}]} && (${Me.TargetOfTarget.Level}>=${bosslevel} && ${Me.TargetOfTarget.PctHPs}<=${debuffbosspct}))) {
		/if (!${debufflist.Find[${Me.TargetOfTarget.ID}]}) /varset debufflist ${debufflist}${Me.TargetOfTarget.ID}|
	}

	/if (${debuffAE} && ${SpawnCount[npc radius ${debuffAEdistance} zradius 50]}) {
		/for k 1 to ${SpawnCount[npc radius ${debuffAEdistance} zradius 50]}
			/varset mobid ${NearestSpawn[${k},npc radius ${debuffAEdistance} zradius 50].ID}
			
			/if (${Spawn[${mobid}].LineOfSight} && ${mobid}!=${ignoreid} && !${debufflist.Find[${mobid}]}) {
				/target id ${mobid}
				/delay 3 ${Target.ID}==${mobid}
				/delay 3
				/if (${Me.TargetOfTarget.Type.Equal[PC]}) /varset debufflist ${debufflist}${Target.ID}|
			}
		/next k
	}

	/for i 1 to 50
		/if (!${debufflist.Token[${i},|].Length}) {
			/for q 1 to 50
				/if (${debufflist.Token[${q},|].Length}) {
					/if (${Spawn[${debufflist.Token[${q},|]}].ID} && ${Spawn[${debufflist.Token[${q},|]}].Type.NotEqual[CORPSE]}) {
						/varset debufflist2 ${debufflist2}${debufflist.Token[${q},|]}|
					}
				} else {
					/varset debufflist ${debufflist2}
					/varset debufflist2
					/return FALSE
				}
			/next q
		}

		/varset mobid ${debufflist.Token[${i},|]}
		/for j 1 to 10
			:nexttry
			/if (${Window[RespawnWnd].Open}) /return TRUE

			/if (${debuff[${j}].Equal[NULL]}) /break
			/if (!${Spawn[${mobid}].ID} || ${Spawn[${mobid}].Type.Equal[CORPSE]}) /break
			/if (!${Spawn[${mobid}].LineOfSight} || ${Spawn[${mobid}].Distance}>${debuffrange}) /break

			/if (${debuffboss[${j}]} && ${Spawn[${mobid}].Level}<${bosslevel}) /continue
			/if (${Spawn[${mobid}].PctHPs}>${debuffpct[${j}]}) /continue
			/if (${debuffnpc[${j}]} && ${SpawnCount[NPC radius 75]}<${debuffnpc[${j}]}) /continue

			/multiline ; /varset idle ${idleuser} ; /varset idle1 1m ; /varset idle5 5m

 			/if (${Me.Gem[${debuff[${j}]}]}) {
 				/if (${Me.PctMana}<${debuffmana[${j}]}) /continue
				/call DottedAlready ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return} || ${Me.CurrentMana}<${Spell[${debuff[${j}]}].Mana}) /continue
				/call ResistCheck ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/varset debuffsdone FALSE
				/if (!${bard}) {
					/call SetBandolier ${Spell[${debuff[${j}]}].ID}
					/casting "${debuff[${j}]}" -targetid|${mobid} ${bandset}
					/call ResistCastWait ${mobid}
					/call ResistResult ${mobid} ${Spell[${debuff[${j}]}].ID} ${Cast.Result}
					/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
					/varcalc try ${try}+1
					/if (${try}<=${debuffretry} && !${Select[${Cast.Result},CAST_SUCCESS,CAST_TAKEHOLD,CAST_IMMUNE]}) /goto :nexttry
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${debuff[${j}]}].ID} "${debuff[${j}]}" ${Math.Calc[${Spell[${debuff[${j}]}].Duration}*60*${focusdetr}*0.90]}
					/call DisplayMsg ${debuffspam} ${debuffchannel} ${Cast.Result} ${debuffmsg[${j}]} ${mobid}
					/return TRUE
				} else {
					/call Bardcast "${debuff[${j}]}" ${mobid} 10
					/call ResistResult ${mobid} ${Spell[${debuff[${j}]}].ID} ${castresult}
					/if (${castresult.Equal[CAST_NOTARGET]}) /return TRUE
					/varcalc try ${try}+1
					/if (${try}<=${debuffretry} && !${Select[${castresult},CAST_SUCCESS,CAST_TAKEHOLD,CAST_IMMUNE]}) /goto :nexttry
					/if (${castresult.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${debuff[${j}]}].ID} "${debuff[${j}]}" ${Math.Calc[${Spell[${debuff[${j}]}].Duration}*60*0.90]}
					/call DisplayMsg ${debuffspam} ${debuffchannel} ${castresult} ${debuffmsg[${j}]} ${mobid}
					/return TRUE
				}
			} else /if (${FindItemCount[=${debuff[${j}]}]} && !${FindItem[=${debuff[${j}]}].Timer}) {
				/call DottedAlready ${mobid} ${FindItem[=${debuff[${j}]}].Spell.ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/call ResistCheck ${mobid} ${FindItem[=${debuff[${j}]}].Spell.ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/varset debuffsdone FALSE
				/casting "${debuff[${j}]}"|item -targetid|${mobid}
				/call ResistCastWait ${mobid}
				/call ResistResult ${mobid} ${FindItem[=${debuff[${j}]}].Spell.ID} ${Cast.Result}
				/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
				/varcalc try ${try}+1
				/if (${try}<=${debuffretry} && !${Select[${Cast.Result},CAST_SUCCESS,CAST_TAKEHOLD,CAST_IMMUNE]}) /goto :nexttry
				/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${FindItem[=${debuff[${j}]}].Spell.ID} "${debuff[${j}]}" ${Math.Calc[${FindItem[=${debuff[${j}]}].Spell.Duration}*54]}
				/call DisplayMsg ${debuffspam} ${debuffchannel} ${Cast.Result} ${debuffmsg[${j}]} ${mobid}
				/return TRUE
			} else /if (${Me.AltAbility[${debuff[${j}]}]} && ${Me.AltAbilityReady[${debuff[${j}]}]}) {
				/call DottedAlready ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/call ResistCheck ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/varset debuffsdone FALSE
				/casting "${debuff[${j}]}"|alt -targetid|${mobid}
				/call ResistCastWait ${mobid}
				/call ResistResult ${mobid} ${Spell[${debuff[${j}]}].ID} ${Cast.Result}
				/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
				/varcalc try ${try}+1
				/if (${try}<=${debuffretry} && !${Select[${Cast.Result},CAST_SUCCESS,CAST_TAKEHOLD,CAST_IMMUNE]}) /goto :nexttry
				/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${debuff[${j}]}].ID} "${debuff[${j}]}" ${Math.Calc[${Spell[${debuff[${j}]}].Duration}*54]}
				/call DisplayMsg ${debuffspam} ${debuffchannel} ${Cast.Result} ${debuffmsg[${j}]} ${mobid}
				/return TRUE
 			} else /if (${Me.CombatAbility[${debuff[${j}]}]} && !${Me.CombatAbilityTimer[${debuff[${j}]}]}) {
 				/if (${Me.PctEndurance}<${debuffendur[${j}]}) /continue
				/call DottedAlready ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/call ResistCheck ${mobid} ${Spell[${debuff[${j}]}].ID} ${debuffretry}
				/if (${Macro.Return}) /continue
				/varset debuffsdone FALSE
				/call ZCastCA "${debuff[${j}]}" ${mobid}
				/varset result ${Macro.Return}
				/call ResistResult ${mobid} ${Spell[${debuff[${j}]}].ID} ${result}
				/if (${result.Equal[CAST_NOTARGET]}) /return TRUE
				/varcalc try ${try}+1
				/if (${try}<=${debuffretry} && !${Select[${result},CAST_SUCCESS,CAST_TAKEHOLD,CAST_IMMUNE]}) /goto :nexttry
				/if (${result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${debuff[${j}]}].ID} "${debuff[${j}]}" ${Math.Calc[${Spell[${debuff[${j}]}].Duration}*54]}
				/call DisplayMsg ${debuffspam} ${debuffchannel} ${result} ${debuffmsg[${j}]} ${mobid}
				/return TRUE
 			} else /if (${Me.Ability[${debuff[${j}]}]}) {
				|do stuff?
			}
		/next j
	/next i
/return FALSE

Sub Event_SetDebuff(Line)
	/declare i int
	
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Debuff${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset dodebuffs TRUE
		/if (${Line.Arg[4].Length}) /varset debuffmode ${Line.Arg[4]}
		/call SetIni Debuffs active ${dodebuffs}
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset dodebuffs FALSE
		/call SetIni Debuffs active ${dodebuffs}
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset debuffset Debuffs
		/if (${Line.Arg[4].Length}) /varset debuffset Debuffs${Line.Arg[4]}
		/echo INFO: Debuff Set is now ${debuffset}
		/call SetIni Debuffs set ${debuffset}
		/call DebuffIni
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset debuffspam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset debuffspam FALSE
		/echo INFO: Debuff Spam=${debuffspam}
		/call SetIni Debuffs spam ${debuffspam}
	} else /if (${Line.Arg[3].Equal[CHANNEL]}) {
		/varset debuffchannel ${Line.Arg[4]}
		/call SetIni Debuffs channel ${debuffchannel}
	} else /if (${Line.Arg[3].Equal[RETRY]}) {
		/varset debuffretry ${Line.Arg[4]}
		/call SetIni ${debuffset} retry ${debuffretry}
	} else /if (${Line.Arg[3].Equal[AE]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset debuffAE TRUE 
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset debuffAE FALSE 
		} else { 
			/varset debuffAEdistance ${Line.Arg[4]}
		} 
		/call SetIni Debuffs aedistance ${debuffAEdistance}
	} else /if (${Line.Arg[3].Equal[ONLY]}) {
		/varset debuffonly ${Line.Arg[4]}
	} else /if (${Line.Arg[3].Equal[PCT]}) {
		/if (${Line.Arg[4].Length}) /varset debuffnormalpct ${Line.Arg[4]} 
		/if (${Line.Arg[5].Length}) /varset debuffbosspct ${Line.Arg[5]} 
		/varset dodebuffs TRUE
		/call SetIni Debuffs active ${dodebuffs}
		/call SetIni ${debuffset} normalpct ${debuffnormalpct}
		/call SetIni ${debuffset} bosspct ${debuffbosspct}
	} else {
		/varset dodebuffs TRUE
		/call SetIni Debuffs active ${dodebuffs}
		/for i 1 to MAXARGS
			/call ParseOptions ${Line.Arg[${Math.Calc[2+${i}]}]}
			/varset debuff[${i}] ${parsespell}
			/varset debuffmana[${i}] ${parsemana}
			/varset debuffendur[${i}] ${parseendur}
			/varset debuffpct[${i}] ${parsepct}
			/varset debuffdist[${i}] ${parsedist}
			/varset debuffnpc[${i}] ${parsenpc}
			/varset debuffcast[${i}] ${parsecast}
			/varset debuffready[${i}] ${parseready}
			/varset debuffonce[${i}] ${parseonce}
			/varset debuffboss[${i}] ${parseboss}
			/call FindMsgNum "${debuff[${i}]}"
			/varset debuffmsg[${i}] ${Macro.Return}
			/call SetIni ${debuffset} debuff${i} "${debuff[${i}]}"
			/call SetIni ${debuffset} mana${i} "${debuffmana[${i}]}"
			/call SetIni ${debuffset} endur${i} "${debuffendur[${i}]}"
			/call SetIni ${debuffset} dist${i} "${debuffdist[${i}]}"
			/call SetIni ${debuffset} npc${i} "${debuffnpc[${i}]}"
			/call SetIni ${debuffset} pct${i} "${debuffpct[${i}]}"
			/call SetIni ${debuffset} cast${i} "${debuffcast[${i}]}"
			/call SetIni ${debuffset} once${i} "${debuffonce[${i}]}"
			/call SetIni ${debuffset} ready${i} "${debuffready[${i}]}"
			/call SetIni ${debuffset} boss${i} "${debuffboss[${i}]}"
		/next i
		/call DebuffRangeCheck
	}
	/call EchoDebuffSettings
/return

Sub EchoDebuffSettings
	/declare i int
	
	/echo >>>>>>>>>>>>>>>>>>>>>>>><<<<<<<<<<<<<<<<<<<<<<<<

	/echo Debuffing=${dodebuffs}, mode=${debuffmode}
	/if (${debuffAE}) /echo AE Debuffing=${debuffAE}, range=${debuffAEdistance}
	/if (${debuffspam}) /echo Debuff spam going to channel=${debuffchannel}
	/if (${debuffonly.Length}) /echo Debuffing only mobs with ${debuffonly}
	/echo Debuffing @ ${debuffnormalpct}%/${debuffbosspct}%, distance=${debuffrange}, with ${debuffretry} retries.
	/for i 1 to MAXARGS
		/if (${debuff[${i}].NotEqual[NULL]}) {
			/call PrepEchoOptions ${debuffpct[${i}]} ${debuffdist[${i}]} ${debuffnpc[${i}]} ${debuffcast[${i}]} ${debuffmana[${i}]} ${debuffendur[${i}]} ${debuffonce[${i}]} ${debuffready[${i}]} ${debuffboss[${i}]}
			/echo ...${debuff[${i}]}${Macro.Return}
			/if (${Ini[${Me.Name}Settings.ini,Messages,success${debuffmsg[${i}]}].Length}) /echo ......success=${Ini[${Me.Name}Settings.ini,Messages,success${debuffmsg[${i}]}]}
			/if (${Ini[${Me.Name}Settings.ini,Messages,fail${debuffmsg[${i}]}].Length}) /echo ......fail=${Ini[${Me.Name}Settings.ini,Messages,fail${debuffmsg[${i}]}]}
		}
	/next i
/return

Sub DotIni
	/declare i int

	/call LoadIni dots active dodots
	/call LoadIni dots spam dotspam
	/call LoadIni dots channel dotchannel
	/call LoadIni dots mode dotmode
	/call LoadIni dots retry dotretry
	/call LoadIni dots normalpct dotnormalpct
	/call LoadIni dots bosspct dotbosspct
	/for i 1 to MAXARGS
		/call LoadIni dots dot${i} dot[${i}]
		/if (${dot[${i}].Length}==1) /varset dot[${i}] ${Me.Gem[${dot[${i}]}]}
		/call LoadIni dots mana${i} dotmana[${i}]
		/call LoadIni dots endur${i} dotendur[${i}]
		/call LoadIni dots pct${i} dotpct[${i}]
		/call LoadIni dots dist${i} dotdist[${i}]
		/call LoadIni dots npc${i} dotnpc[${i}]
		/call LoadIni dots cast${i} dotcast[${i}]
		/call LoadIni dots once${i} dotonce[${i}]
		/call LoadIni dots ready${i} dotready[${i}]
		/call LoadIni dots boss${i} dotboss[${i}]
		/call FindMsgNum "${dot[${i}]}"
		/varset dotmsg[${i}] ${Macro.Return}
	/next i

	/if (${dodots}) /echo INFO: Dots are ON!
/return

Sub DoDots
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	/declare spellid int
	/declare spellname string
	/declare itemname string
	/declare mobid int
	/declare result string

	/for i 1 to MAXDOTS
		/if (${dotinuse[${i}]}) {
			/if (!${Spawn[${dotid[${i}]}].ID} || ${Spawn[${dotid[${i}]}].Type.Equal[CORPSE]} || ${Spawn[${dotid[${i}]}].Distance}>400) {
				/varset dotinuse[${i}] FALSE
			} else /if (!${dottimer${i}} && ${Spawn[${dotid[${i}]}].LineOfSight}) {
				/if (${Me.Ability[${dotspell[${i}]}]} && ${Me.AbilityReady[${dotspell[${i}]}]}) {
				} else /if (${Me.CombatAbility[${dotspell[${i}]}]} && !${Me.CombatAbilityTimer[${dotspell[${i}]}]}) {
				} else /if (${Me.AltAbility[${dotspell[${i}]}]} && ${Me.AltAbilityReady[[${dotspell[${i}]}]}) {
				} else /if (${FindItemCount[=${dotspell[${i}]}]} && !${FindItem[=${dotspell[${i}]}].Timer}) {
					/casting "${dotspell[${i}]}"|Item -targetid|${dotid[${i}]}
					/call WaitCast
					/if (${FindItem[=${dotspell[${i}]}].WornSlot[1].Name.Equal[ranged]}) {
						/varset itemname ${InvSlot[mainhand].Item.Name}
						/unequip mainhand
						/exchange "${itemname}" mainhand
					}
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
						/varset dottimer${i} ${dotduration[${i}]}
					} else /if (${Cast.Result.Equal[CAST_TAKEHOLD]}) {
						/varset dotinuse[${i}] FALSE
					}
					/return TRUE
				} else /if (!${bard} && ${Me.SpellReady[${dotspell[${i}]}]}) {
					/call SetBandolier ${Spell[${dotspell[${i}]}].ID}
					/casting "${dotspell[${i}]}" -targetid|${dotid[${i}]} ${bandset}
					/call WaitCast
					/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
						/varset dottimer${i} ${dotduration[${i}]}
					} else /if (${Cast.Result.Equal[CAST_TAKEHOLD]}) {
						/varset dotinuse[${i}] FALSE
					}
					/return TRUE
				} else /if (${bard}) {
					/if (${Me.Gem[${dotspell[${i}]}]} && ${Target.ID}==${dotid[${i}]}) {
						/call bardcast "${dotspell[${i}]}" ${dotid[${i}]} 10
						/if (${castresult.Equal[CAST_SUCCESS]}) {
							/varset dottimer${i} ${dotduration[${i}]}
						} else /if (${castresult.Equal[CAST_TAKEHOLD]}) {
							/varset dotinuse[${i}] FALSE
						}
					} else {
						/varset dotinuse[${i}] FALSE
					}
				}
			}
		}
		:nexti
	/next i

	/if (!${dodots}) /return FALSE

	/if (${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${dotnormalpct} && ${Target.LineOfSight} && ${Target.ID}!=${ignoreid}) {
		/multiline ; /varset idle ${idleuser} ; /varset idle1 1m ; /varset idle5 5m
		/varset mobid ${Target.ID}

		/for i 1 to MAXARGS
			/if (${dot[${i}].Equal[NULL]}) /return FALSE
			/if (${Me.Gem[${dot[${i}]}]} && ${Me.SpellReady[${dot[${i}]}]}) {
				/call DottedAlready ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/if (${Spawn[${mobid}].PctHPs}>${dotpct[${i}]} || ${Me.CurrentMana}<${Spell[${dot[${i}]}].Mana} || ${Me.PctMana}<${dotmana[${i}]}) /goto :nextii
				/call ResistCheck ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/call SetBandolier ${Spell[${dot[${i}]}].ID}
				/casting "${dot[${i}]}" -targetid|${mobid} ${bandset}
				/call ResistCastWait ${mobid}
				/call ResistResult ${mobid} ${Spell[${dot[${i}]}].ID} ${Cast.Result}
				/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
				/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${dot[${i}]}].ID} "${dot[${i}]}" ${Math.Calc[${Spell[${dot[${i}]}].Duration}*60*${focusdetr}]}
				/call DisplayMsg ${dotspam} ${dotchannel} ${Cast.Result} ${dotmsg[${i}]} ${mobid}
				/return TRUE
			} else /if (${FindItemCount[=${dot[${i}]}]} && !${FindItem[=${dot[${i}]}].Timer}) {
				/call DottedAlready ${mobid} ${FindItem[=${dot[${i}]}].Spell.ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/if (${Spawn[${mobid}].PctHPs}>${dotpct[${i}]}) /goto :nextii
				/call ResistCheck ${mobid} ${FindItem[=${dot[${i}]}].Spell.ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/casting "${dot[${i}]}"|item -targetid|${mobid}
				/call ResistCastWait ${mobid}
				/call ResistResult ${mobid} ${Spell[${dot[${i}]}].ID} ${Cast.Result}
				/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
				/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${FindItem[=${dot[${i}]}].Spell.ID} "${dot[${i}]}" ${Math.Calc[${FindItem[=${dot[${i}]}].Spell.Duration}*60]}
				/call DisplayMsg ${dotspam} ${dotchannel} ${Cast.Result} ${dotmsg[${i}]} ${mobid}
				/return TRUE
			} else /if (${Me.AltAbility[${dot[${i}]}]} && ${Me.AltAbilityReady[${dot[${i}]}]}) {
				/if (${Spawn[${mobid}].PctHPs}>${dotpct[${i}]}) /goto :nextii
				/call DottedAlready ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/call ResistCheck ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/casting "${dot[${i}]}"|alt -targetid|${mobid}
				/call ResistCastWait ${mobid}
				/call ResistResult ${mobid} ${Spell[${dot[${i}]}].ID} ${Cast.Result}
				/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
				/if (${Cast.Result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${dot[${i}]}].ID} "${dot[${i}]}" ${Math.Calc[${Spell[${dot[${i}]}].Duration}*60]}
				/call DisplayMsg ${dotspam} ${dotchannel} ${Cast.Result} ${dotmsg[${i}]} ${mobid}
				/return TRUE
			} else /if (${Me.CombatAbility[${dot[${i}]}]} && !${Me.CombatAbilityTimer[${dot[${i}]}]}) {
				/if (${Spawn[${mobid}].PctHPs}>${dotpct[${i}]} || ${Me.PctEndurance}<${dotendur[${i}]}) /goto :nextii
				/call DottedAlready ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/call ResistCheck ${mobid} ${Spell[${dot[${i}]}].ID} ${dotretry}
				/if (${Macro.Return}) /goto :nextii
				/call ZCastCA "${dot[${i}]}" ${mobid}
				/varset result ${Macro.Return}
				/call ResistResult ${mobid} ${Spell[${dot[${i}]}].ID} ${result}
				/if (${result.Equal[CAST_NOTARGET]}) /return TRUE
				/if (${result.Equal[CAST_SUCCESS]}) /call AddDot ${mobid} ${Spell[${dot[${i}]}].ID} "${dot[${i}]}" ${Math.Calc[${Spell[${dot[${i}]}].Duration}*60]}
				/call DisplayMsg ${dotspam} ${dotchannel} ${result} ${dotmsg[${i}]} ${mobid}
				/return TRUE
			}
			:nextii
		/next i
	}
/return FALSE

Sub Event_SetDot(string Line) 
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp dot${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset dodots TRUE
		/if (${Line.Arg[4].Length}) /varset dotmode ${Line.Arg[4]}
		/call SetIni dots active ${dodots}
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset dodots FALSE
		/call SetIni dots active ${dodots}
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset dotspam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset dotspam FALSE
		/echo INFO: dot Spam=${dotspam}
		/call SetIni dots spam ${dotspam}
	} else /if (${Line.Arg[3].Equal[CHANNEL]}) {
		/varset dotchannel ${Line.Arg[4]}
		/call SetIni dots channel ${dotchannel}
	} else /if (${Line.Arg[3].Equal[RETRY]}) {
		/varset dotretry ${Line.Arg[4]}
		/call SetIni dots retry ${dotretry}
	} else /if (${Line.Arg[3].Equal[PCT]}) {
		/if (${Line.Arg[4].Length}) /varset dotnormalpct ${Line.Arg[4]} 
		/if (${Line.Arg[5].Length}) /varset dotbosspct ${Line.Arg[5]}
		/varset dodots TRUE
		/call SetIni dots active ${dodots}
		/call SetIni dots normalpct ${dotnormalpct}
		/call SetIni dots bosspct ${dotbosspct}
	} else {
		/declare i int
		/varset dodots TRUE
		/call SetIni dots active ${dodots}
		/for i 1 to MAXARGS
			/call ParseOptions ${Line.Arg[${Math.Calc[2+${i}]}]}
			/varset dot[${i}] ${parsespell}
			/varset dotmana[${i}] ${parsemana}
			/varset dotendur[${i}] ${parseendur}
			/varset dotpct[${i}] ${parsepct}
			/varset dotdist[${i}] ${parsedist}
			/varset dotnpc[${i}] ${parsenpc}
			/varset dotcast[${i}] ${parsecast}
			/varset dotready[${i}] ${parseready}
			/varset dotonce[${i}] ${parseonce}
			/varset dotboss[${i}] ${parseboss}
			/call FindMsgNum "${dot[${i}]}"
			/varset dotmsg[${i}] ${Macro.Return}
			/call SetIni dots dot${i} "${dot[${i}]}"
			/call SetIni dots mana${i} "${dotmana[${i}]}"
			/call SetIni dots endur${i} "${dotendur[${i}]}"
			/call SetIni dots dist${i} "${dotdist[${i}]}"
			/call SetIni dots npc${i} "${dotnpc[${i}]}"
			/call SetIni dots pct${i} "${dotpct[${i}]}"
			/call SetIni dots cast${i} "${dotcast[${i}]}"
			/call SetIni dots once${i} "${dotonce[${i}]}"
			/call SetIni dots ready${i} "${dotready[${i}]}"
			/call SetIni dots boss${i} "${dotboss[${i}]}"
		/next i
	}
	/call EchoDotSettings
/return 

Sub EchoDotSettings
	/declare i int

	/echo >>>>>>>>>>>>>>>>>>>>>>>><<<<<<<<<<<<<<<<<<<<<<<<
	/echo Dotting=${dodots}, mode=${dotmode}
	/if (${dotspam}) /echo Dot spam going to channel=${dotchannel}
	/echo Dotting @ ${dotnormalpct}/${dotbosspct}% with ${dotretry} retries.
	/for i 1 to MAXARGS
		/if (${dot[${i}].NotEqual[NULL]}) {
			/call PrepEchoOptions ${dotpct[${i}]} ${dotdist[${i}]} ${dotnpc[${i}]} ${dotcast[${i}]} ${dotmana[${i}]} ${dotendur[${i}]} ${dotonce[${i}]} ${dotready[${i}]} ${dotboss[${i}]}
			/echo ...${dot[${i}]}${Macro.Return}
			/if (${Ini[${Me.Name}Settings.ini,Messages,success${dotmsg[${i}]}].Length}) /echo ......succes=${Ini[${Me.Name}Settings.ini,Messages,success${dotmsg[${i}]}]}
			/if (${Ini[${Me.Name}Settings.ini,Messages,fail${dotmsg[${i}]}].Length}) /echo ......fail=${Ini[${Me.Name}Settings.ini,Messages,fail${dotmsg[${i}]}]}
		}
	/next i
/return

Sub NukeIni
	/declare i int

	/call LoadIni Nukes active donukes
	/call LoadIni Nukes concactive concactive
	/call LoadIni Nukes concspell concspell
	/call LoadIni Nukes normalpct nukenormalpct
	/call LoadIni Nukes bosspct nukebosspct
	/call LoadIni Nukes retry nukeretry
	/call LoadIni Nukes delay nukedelay
	/call LoadIni Nukes gomspell nukegom
	/call LoadIni Nukes gomtrigger nukegomtrigger
	/if (${nukegom.Length}==1) /varset nukegom ${Me.Gem[${nukegom}]}

	/for i 1 to MAXARGS
		/call LoadIni Nukes nuke${i} nuke[${i}]
		/if (${nuke[${i}].Length}==1) /varset nuke[${i}] ${Me.Gem[${nuke[${i}]}]}
		/call LoadIni Nukes pct${i} nukepct[${i}]
		/call LoadIni Nukes mana${i} nukemana[${i}]
		/call LoadIni Nukes endur${i} nukeendur[${i}]
		/call LoadIni Nukes dist${i} nukedist[${i}]
		/call LoadIni Nukes npc${i} nukenpc[${i}]
		/call LoadIni Nukes cast${i} nukecast[${i}]
		/call LoadIni Nukes once${i} nukeonce[${i}]
		/call LoadIni Nukes ready${i} nukeready[${i}]
		/call LoadIni Nukes boss${i} nukeboss[${i}]
		/call FindMsgNum "${nuke[${i}]}"
		/varset nukemsg[${i}] ${Macro.Return}
	/next i

	/if (${donukes}) /echo INFO: Nuking is ON!
/return

Sub DoNukes
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE
	/if (${nuketimer} || !${Target.ID} || ${Target.Type.NotEqual[NPC]}) /return FALSE

	/declare i int

	/if (${Target.LineOfSight} && ${Target.ID}!=${ignoreid} && (${Target.PctHPs}<=${nukenormalpct} || (${Target.Level}>=${bosslevel} && ${Target.PctHPs}<=${nukebosspct}))) {
		/multiline ; /varset idle ${idleuser} ; /varset idle1 1m ; /varset idle5 5m
		/varset nuketarget ${Target.ID}

		/if (${nukegomtrigger.Length} && ${Me.SpellReady[${nukegom}]}) {
			/for i 1 to 10
				/if (!${nukegomtrigger.Token[${i},|].Length}) /goto :donegom

				/if (${Me.Song[${nukegomtrigger.Token[${i},|]}].ID}) {
					/call SetBandolier ${Spell[${nukegom}].ID}
					/if (${EQBC.Connected} && ${bcspam}) /docommand /bc [+t+]Gift of Mana [${nukegom}][+x+]
					/casting "${nukegom}"|gem9 ${bandset}
					/call WaitCast
					/return TRUE
				}
			/next i
		}
		:donegom

		/for i 1 to MAXARGS
			/if (${nuke[${i}].NotEqual[NULL]} && ${Target.PctHPs}<=${nukepct[${i}]}) {
				/if (${Me.SpellReady[${nuke[${i}]}]} && ${Me.CurrentMana}>=${Spell[${nuke[${i}]}].Mana} && ${Me.PctMana}>=${nukemana[${i}]}) {
					/if (${nukeonce[${i}]} && ${Spell[${nuke[${i}]}].ID}==${nukelast}) /goto :nexti
					/call ResistCheck ${nuketarget} ${Spell[${nuke[${i}]}].ID} ${nukeretry}
					/if (${Macro.Return}) /goto :nexti
					/call SetBandolier ${Spell[${nuke[${i}]}].ID}
					/casting "${nuke[${i}]}" -targetid|${nuketarget} ${bandset}
					/call ResistCastWait ${nuketarget}
					/call ResistResult ${nuketarget} ${Spell[${nuke[${i}]}].ID}
					/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
					/call DisplayMsg ${nukespam} ${nukechannel} ${Cast.Result} ${nukemsg[${i}]} ${nuketarget}
					/varset nuketimer ${nukedelay}
					/varset petcombatnuketimer 150
					/varset nukelast ${Spell[${nuke[${i}]}].ID}
					/if (${concactive})	{
						/varset justnuked TRUE
						/call DoConc
					}
					/return TRUE
				} else /if (${FindItemCount[=${nuke[${i}]}]} && !${FindItem[=${nuke[${i}]}].Timer}) {
					/if (${nukeonce[${i}]} && ${FindItem[=${nuke[${i}]}].Spell.ID}==${nukelast}) /goto :nexti
					/call ResistCheck ${nuketarget} ${FindItem[=${nuke[${i}]}].Spell.ID} ${nukeretry}
					/if (${Macro.Return}) /goto :nexti
					/casting "${nuke[${i}]}" -targetid|${nuketarget}
					/call ResistCastWait ${nuketarget}
					/call ResistResult ${nuketarget} ${FindItem=[${nuke[${i}]}].Spell.ID}
					/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
					/call DisplayMsg ${nukespam} ${nukechannel} ${Cast.Result} ${nukemsg[${i}]} ${nuketarget}
					/varset nuketimer ${nukedelay}
					/varset petcombatnuketimer 150
					/varset nukelast ${FindItem[=${nuke[${i}]}].Spell.ID}
					/if (${concactive})	{
						/varset justnuked TRUE
						/call DoConc
					}
					/return TRUE
				}
			}
			:nexti
		/next i
	}
/return FALSE

Sub DoConc
	/if (${Me.Invis} || ${Me.Moving} || !${justnuked} || !${concactive}) /return FALSE
	/if (!${Target.ID} || ${Target.Type.NotEqual[NPC]}) /return FALSE
	
		/if (${Target.LineOfSight} && ${Target.ID}!=${ignoreid} && (${Target.PctHPs}<=${nukenormalpct} || (${Target.Level}>=${bosslevel} && ${Target.PctHPs}<=${nukebosspct}))) {
			/casting "${concspell}" -targetid|${nuketarget} ${bandset}
			/if (${Cast.Result.Equal[CAST_NOTARGET]}) /return TRUE
			/varset justnuked FALSE
			}
/return

Sub Event_SetNuke(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp nuke${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset donukes TRUE
		/if (${Line.Arg[4].Length}) /varset nukemode ${Line.Arg[4]}
		/call SetIni nukes active ${donukes}
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset donukes FALSE
		/call SetIni nukes active ${donukes}
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset nukespam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset nukespam FALSE
		/echo INFO: nuke Spam=${nukespam}
		/call SetIni nukes spam ${nukespam}
	} else /if (${Line.Arg[3].Equal[CHANNEL]}) {
		/varset nukechannel ${Line.Arg[4]}
		/call SetIni nukes channel ${nukechannel}
	} else /if (${Line.Arg[3].Equal[RETRY]}) {
		/varset nukeretry ${Line.Arg[4]}
		/call SetIni nukes retry ${nukeretry}
	} else /if (${Line.Arg[3].Equal[PCT]}) {
		/if (${Line.Arg[4].Length}) /varset nukenormalpct ${Line.Arg[4]} 
		/if (${Line.Arg[5].Length}) /varset nukebosspct ${Line.Arg[5]} 
		/varset donukes TRUE
		/call SetIni nukes active ${donukes}
		/call SetIni nukes normalpct ${nukenormalpct}
		/call SetIni nukes bosspct ${nukebosspct}
	} else /if (${Line.Arg[3].Equal[DELAY]}) {
		/varset nukedelay ${Line.Arg[4]}
		/call SetIni Nukes delay ${nukedelay}
	} else /if (${Line.Arg[3].Equal[GOM]}) {
		/varset nukegom ${Me.Gem[${Line.Arg[4]}].Name}
		/call SetIni Nukes gomspell "${nukegom}"
		/call LoadIni Nukes gomtrigger nukegomtrigger "Gift of Mana"
	} else {
		/declare i int

		/varset donukes TRUE
		/call SetIni Nukes active "${donukes}"
		/for i 1 to MAXARGS
			/call ParseOptions ${Line.Arg[${Math.Calc[2+${i}]}]}
			/varset nuke[${i}] ${parsespell}
			/varset nukemana[${i}] ${parsemana}
			/varset nukeendur[${i}] ${parseendur}
			/varset nukenpc[${i}] ${parsenpc}
			/varset nukepct[${i}] ${parsepct}
			/varset nukedist[${i}] ${parsedist}
			/varset nukecast[${i}] ${parsecast}
			/varset nukeready[${i}] ${parseready}
			/varset nukeonce[${i}] ${parseonce}
			/varset nukeboss[${i}] ${parseboss}
			/call FindMsgNum "${nuke[${i}]}"
			/varset nukemsg[${i}] ${Macro.Return}
			/call SetIni Nukes nuke${i} "${nuke[${i}]}"
			/call SetIni Nukes mana${i} "${nukemana[${i}]}"
			/call SetIni Nukes npc${i} "${nukenpc[${i}]}"
			/call SetIni Nukes pct${i} "${nukepct[${i}]}"
			/call SetIni Nukes cast${i} "${nukecast[${i}]}"
			/call SetIni Nukes endur${i} "${nukeendur[${i}]}"
			/call SetIni Nukes dist${i} "${nukedist[${i}]}"
			/call SetIni Nukes ready${i} "${nukeready[${i}]}"
			/call SetIni Nukes once${i} "${nukeonce[${i}]}"
			/call SetIni Nukes boss${i} "${nukeboss[${i}]}"
		/next i
	}
	/call EchoNukeSettings
/return 

Sub EchoNukeSettings
	/declare i int

	/echo >>>>>>>>>>>>>>>>>>>>>>>><<<<<<<<<<<<<<<<<<<<<<<<
	/echo Nuking=${donukes}, mode=${nukemode}
	/echo Nuking @ ${nukenormalpct}/${nukebosspct}% with ${nukeretry} retries.
	/if (${nukespam}) /echo Nuke spam going to channel=${nukechannel}
	/echo Nuke Delay = ${nukedelay}
	/echo Nuke GOM = ${nukegom}
	/echo Nuke GOM triggers = ${nukegomtrigger}
	/for i 1 to MAXARGS
		/if (${nuke[${i}].NotEqual[NULL]}) {
			/call PrepEchoOptions ${nukepct[${i}]} ${nukedist[${i}]} ${nukenpc[${i}]} ${nukecast[${i}]} ${nukemana[${i}]} ${nukeendur[${i}]} ${nukeonce[${i}]} ${nukeready[${i}]} ${nukeboss[${i}]}
			/echo ...${nuke[${i}]}${Macro.Return}
			/if (${Ini[${Me.Name}Settings.ini,Messages,success${nukemsg[${i}]}].Length}) /echo ......succes=${Ini[${Me.Name}Settings.ini,Messages,success${nukemsg[${i}]}]}
			/if (${Ini[${Me.Name}Settings.ini,Messages,fail${nukemsg[${i}]}].Length}) /echo ......fail=${Ini[${Me.Name}Settings.ini,Messages,fail${nukemsg[${i}]}]}
		}
	/next i
/return

Sub ParseOptions(Line)
	/declare i int

	/varset parsespell NULL
	/varset parsemana 0
	/varset parseendur 0
	/varset parsepct 100
	/varset parsenpc 0
	/varset parsecast 99
	/varset parsedist 999
	/varset parseready FALSE
	/varset parseonce FALSE
	/varset parseboss FALSE

	/if (${Line.Equal[NULL]} || ${Line.Length}==0) {
		/return
	} else /if (${Line.Arg[1,:].Length}==1) {
		/varset parsespell ${Me.Gem[${Line.Arg[1,:]}].Name}
	} else {
		/call GetAlias "${Line.Arg[1,:]}"
		/if (${Macro.Return.Equal[NotFound]}) {
			/echo ERROR: parsing alias >>>${Line.Arg[1,:]}<<< not found 
			/return
		}
		/varset parsespell ${Macro.Return}
	}

	/for i 2 to 50
		/if (${Line.Arg[${i},:].Length}==0) /return

		/if (${Line.Arg[${i},:].Left[1].Equal[M]}) {
			/varset parsemana ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[E]}) {
			/varset parseendur ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[N]}) {
			/varset parsenpc ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[P]}) {
			/varset parsepct ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[C]}) {
			/varset parsecast ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[D]}) {
			/varset parsedist ${Line.Arg[${i},:].Right[-1]}
		} else /if (${Line.Arg[${i},:].Left[1].Equal[R]}) {
			/varset parseready TRUE
		} else /if (${Line.Arg[${i},:].Left[1].Equal[O]}) {
			/varset parseonce TRUE
		} else /if (${Line.Arg[${i},:].Left[1].Equal[B]}) {
			/varset parseboss TRUE
		} else {
			/echo ERROR: unrecognized option ${Line.Arg[${i},:]}
		}
	/next i
/return

Sub PrepEchoOptions(int pct, int dist, int cnt, int casts, int mana, int endur, bool once, bool ready, bool boss)
	/declare s string
	
	/if (${pct}!=100) /varset s ${s}::HP<=${pct}%
	/if (${dist}!=999) /varset s ${s}::Dist<=${dist}
	/if (${cnt}) /varset s ${s}::MobCount>=${cnt}
	/if (${casts}!=99) /varset s ${s}::MaxRst=${casts}
	/if (${mana}) /varset s ${s}::Mana>=${mana}%
	/if (${endur}) /varset s ${s}::Endur>=${endur}%
	/if (${once}) /varset s ${s}::CastOnce
	/if (${ready}) /varset s ${s}::OnlyIfReady
	/if (${boss}) /varset s ${s}::BOSS
/return ${s}

Sub BardCast(string songname, int mobid, int stophp)
	/if (${Me.Sitting}) /stand
	/if (${mobid} && ${Target.ID}!=${mobid}) {
		/target id ${mobid}
		/delay 3 ${Target.ID}==${mobid}
		/if (${Target.ID}!=${mobid}) /return CAST_NOTARGET
	}
	/varset spelltext ${Target.CleanName}${Spell[${songname}].CastOnAnother}
	/varset castresult CAST_FAILED

	/if (!${sitmedtwist}) /varset sitmedtwist ${Twist}

	/if (${Twist}) {
|		/delay 5s !${Window[CastingWindow]}
		/squelch /twist stop
		/delay 1s !${Twist}
	}
	/if (${Me.Casting.ID}) /stopsong
	
	/delay 1s ${Me.SpellReady[${songname}]}
	/cast ${Me.Gem[${songname}]}
	/delay 1s ${Me.Casting.ID}==${Spell[${songname}].ID}

	:waitcast
	/delay 3
	/doevents CACast
	/doevents CAResist
	/doevents CAImmune
	/doevents CAPartial
	/doevents CATakeHold
	/if (${Target.PctHPs}<=${stophp}) /multiline ; /varset castresult CAST_INTERRUPTED ; /goto :exit
	/if (${mobid} && !${Target.ID}) /multiline ; /varset castresult CAST_NOTARGET ; /goto :exit
	/if (${Window[CastingWindow]}) /goto :waitcast
	/declare t timer 1s
	:waitresult
	/delay 3
	/doevents CACast
	/doevents CAResist
	/doevents CAImmune
	/doevents CAPartial
	/doevents CATakeHold
	/if (${mobid} && !${Target.ID}) /multiline ; /varset castresult CAST_NOTARGET ; /goto :exit
	/if (${t} && ${castresult.Equal[CAST_FAILED]}) /goto :waitresult
	:exit
	/if (${Me.Casting.ID}) /stopsong
	/if (${sitmedtwist}) /multiline ; /squelch /twist start ; /varset sitmedtwist FALSE
/return ${castresult}

Sub ZCastCA(string ca, int mobid)
	/varset spelltext ${Target.CleanName}${Spell[${ca}].CastOnAnother}
	/varset castresult CAST_FAILED

	/target id ${mobid}
	/delay 5 ${Target.ID}==${mobid}
	/docommand /disc ${ca}
	:waitcast
	/delay 2
	/doevents CACast
	/doevents CAResist
	/doevents CAImmune
	/doevents CAPartial
	/doevents CATakeHold
	/if (${Me.Casting}) /goto :waitcast
	/declare t timer 1s
	:waitresult
	/delay 2
	/doevents CACast
	/doevents CAResist
	/doevents CAImmune
 	/doevents CAPartial
	/doevents CATakeHold
	/if (${t} && ${castresult.Equal[CAST_FAILED]}) /goto :waitresult
/return ${castresult}

Sub Event_CACast
	/doevents flush CACast
	/varset castresult CAST_SUCCESS
/return

Sub Event_CAImmune
	/varset castresult CAST_IMMUNE
/return

Sub Event_CAResist
	/varset castresult CAST_RESIST
/return

Sub Event_CAPartial
	/varset castresult CAST_SUCCESS
/return

Sub Event_CATakeHold
	/varset castresult CAST_TAKEHOLD
/return

Sub DottedAlready(int mobid, int spellid, int maxtries)
	/declare i int

	/for i 1 to MAXDOTS
		/if (${dotid[${i}]}==${mobid} && ${dotspellid[${i}]}==${spellid}) /return TRUE
	/next i

	/for i 1 to MAXRESISTS
		/if (${resistmob[${i}]}==${mobid} && ${resistspell[${i}]}==${spellid}) {
			/if (${resistcount[${i}]}>=${maxtries}) {
				/return TRUE
			} else {
				/return FALSE
			}
		}
	/next i
/return FALSE

Sub AddDot(int targetid, int spellid, string name, int duration)
	/declare i int

	/if (!${duration}) /return
	/for i 1 to MAXDOTS
		/if (!${dotinuse[${i}]}) {
			/varset dotinuse[${i}] TRUE
			/varset dotid[${i}] ${targetid}
			/varset dotspell[${i}] ${name}
			/varset dotspellid[${i}] ${spellid}
			/varset dotduration[${i}] ${duration}
			/varset dottimer${i} ${duration}
			/return
		}
	/next i
	/echo ERROR: Max dot space used, cant save!!!!
/return

Sub ResistClear
	/declare i int

	/for i 1 to MAXRESISTS
		/if (${resistmob[${i}]} && (!${Spawn[${resistmob[${i}]}].ID} || ${Spawn[${resistmob[${i}]}].Distance}>300)) /varset resistmob[${i}] 0
	/next i
/return

Sub ResistCheck(int mobid, int spellid, int resistmax)
	/declare i int

	/for i 1 to MAXRESISTS
		/if (${resistmob[${i}]}==${mobid} && ${resistspell[${i}]}==${spellid}) {
			/if (${resistcount[${i}]}>=${resistmax}) {
				/return TRUE
			} else {
				/return FALSE
			}
		}
	/next i
	/return FALSE
/return

Sub ResistCastWait(int mobid)
	/delay 5
	/if (${Me.Mount.ID}) {
		/call WaitCast
	} else {
		:top
		/delay 5
		/if (!${Spawn[${mobid}].ID} || ${Spawn[${mobid}].Type.Equal[CORPSE]}) /interrupt
		/if (${Cast.Status.NotEqual[I]}) /goto :top
	}
	/delay 5
/return

Sub ResistResult(int mobid, int spellid, string result)
	/declare i int

	/for i 1 to MAXRESISTS
		/if (${resistmob[${i}]}==${mobid} && ${resistspell[${i}]}==${spellid}) {
			/if (${result.Equal[CAST_SUCCESS]}) {
				/varset resistmob[${i}] 0
			} else /if (${result.Equal[CAST_RESIST]}) {
				/varcalc resistcount[${i}] ${resistcount[${i}]}+1
			} else /if (${Select[${result},CAST_IMMUNE,CAST_TAKEHOLD]}) {
				/varset resistcount[${i}] 9999
			}
			/return
		}
	/next i
	
	/if (${result.Equal[CAST_SUCCESS]}) /return CAST_SUCCESS

	/for i 1 to MAXRESISTS
		/if (!${resistmob[${i}]}) {
			/if (${result.Equal[CAST_RESIST]}) {
				/varset resistmob[${i}] ${mobid}
				/varset resistspell[${i}] ${spellid}
				/varset resistcount[${i}] 1
			} else /if (${Select[${result},CAST_IMMUNE,CAST_TAKEHOLD]}) {
				/varset resistmob[${i}] ${mobid}
				/varset resistspell[${i}] ${spellid}
				/varset resistcount[${i}] 9999
			}
			/return
		}
	/next i
/return

Sub DoClassStuff
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE

	/declare i int
	
	/if (${forage} && !${Me.Combat} && !${Me.AutoFire} && ${Me.AbilityReady[Forage]} && ${Me.Standing}) {
		/doability forage
		/delay 5 ${Cursor.ID}
		/call HandleItem
		/return TRUE
	}

	/if (${Me.Class.Name.Equal[Cleric]} && ${autoyaulp} && !${noyaulp}) {
		/if (${Me.Sitting} && ${Me.CombatState.Equal[RESTING]}) /return FALSE
		/if (${SpawnCount[NPC radius ${sitmedrange} zradius 30]}==0 && ${Me.PctMana}<${sitmed}) /return FALSE

		/declare f int 0
		/for f 0 to ${Group}
			/if (${Spawn[${Group.Member[${f}]}].ID} && ${Group.Member[${f}].State.NotEqual[DEAD]} && ${Group.Member[${f}].PctHPs}<70) /return FALSE
		/next f 

		/if (${Me.PctMana}<${yaulppct} && !${Me.Sitting} && !${Me.Mount.ID}) {
			/if (${Me.SpellReady[${yaulpspell}]}) /casting "${yaulpspell}"|gem9
			/delay 5s ${Cast.Status.Equal[I]}
			/return TRUE
		}
	} else /if (${Me.Class.Name.Equal[Shaman]} && ${autocanni}) {
		|/if (${Me.Sitting} && ${Me.CombatState.Equal[RESTING]}) /return FALSE

		/if (${Me.AltAbilityReady[Cannibalization]} && ${Me.PctMana}<${bigcannipct} && ${Me.CurrentHPs}>${bigcannihp}) {
			/casting ${AltAbility[Cannibalization].ID}|alt
			/call WaitCast
			/return TRUE
		} else /if (${Me.PctMana}<${cannipct} && ${Me.CurrentHPs}>${smallcannihp}) {
			/if (${Me.SpellReady[${cannispell}]}) /casting "${cannispell}"|gem9
			/call WaitCast
			/return TRUE
		}
	} else /if (${Me.Class.Name.Equal[Necromancer]}) {
		/if (${Me.PctMana}==100 && !${idle} && ${Me.Buff[${yaulpspell}].ID}) {
			/varcalc i ${Me.Buff[${yaulpspell}].ID}-1
			/nomodkey /notify BuffWindow buff${i} leftmouseup
		} else /if (${autoyaulp} && ${Me.PctMana}<${yaulppct} && !${Me.Buff[${yaulpspell}].ID}) {
			/call SetBandolier ${Spell[${yaulpspell}].ID}
			/casting "${yaulpspell}"|gem9 ${bandset}
			/return TRUE
		}

		/if (${Me.SpellReady[Sedulous Subversion]} && ${Me.CurrentMana}>${Spell[Sedulous Subversion].Mana}) {
			/for i ${feedpos} to 10
				/if (${feedcount[${i}]}) {
					/if (!${Spawn[${feedlist[${i}]}].ID}) {
						/varset feedcount[${i}] 0
					} else /if (${Spawn[${feedlist[${i}]}].Distance}<=${Spell[Sedulous Subversion].MyRange}) {
						/casting "Sedulous Subversion" -targetid|${feedlist[${i}]}
						/call WaitCast
						/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
							/varcalc feedcount[${i}] ${feedcount[${i}]}-1
						}
						/if (${i}==10) {
							/varset feedpos 1
						} else {
							/varcalc feedpos ${i}+1
						}
						/return
					}
				}
			/next i
			/varset feedpos 1
		}
	} else /if (${Me.Class.Name.Equal[Wizard]} && ${autoharvest}) {
		/if (${Me.Sitting} && ${Me.CombatState.Equal[RESTING]}) /return FALSE

		/if (${Me.PctMana}<${harvestpct} && ${Me.SpellReady[${harvestspell}]}) {
			/varcalc i ${Me.PctMana}+10
			/casting "${harvestspell}"|gem9
			/call WaitCast
			/if (${Cast.Result.Equal[CAST_SUCCESS]}) {
				/if (${EQBC.Connected}) /docommand /${bctell} [+t+]Harvesting Start... ${Time} (${Me.PctMana}m)[+x+]
				/echo INFO: Harvesting Start... ${Time} (${Me.PctMana}m)
				/delay ${harvestwait} ${Me.PctMana}>=${i}
				/if (${EQBC.Connected}) /docommand /${bctell} [+t+]Harvesting End... ${Time} (${Me.PctMana}m)[+x+]
				/echo INFO: Harvesting End... ${Time} (${Me.PctMana}m)
			}
			/return TRUE
		}
	} else /if (${Me.Class.Name.Equal[Rogue]} && !${Me.Combat} && !${Me.AutoFire} && ${autohide}) {
		/if (${hidetimer}>50) {
			/varset hidetimer 2s
			/return
		}
		/if (${hidetimer}) /return

		/if (${Me.Sneaking}) /doability sneak
		/if (${Me.AbilityReady[hide]} && ${Me.AbilityReady[sneak]}) {
			/doability hide
			/doability sneak
			/varset hidetimer 9999m
			/varset strikeready 5s
		}
		/return FALSE
	}
/return FALSE

Sub Event_SetYaulp(string Line)
	/if (${Line.Arg[3].Length}==0) {
		/echo USAGE /yaulp
		/echo .../yaulp ON|OFF
		/echo .../yaulp <mana%>
		/echo .../yaulp <gem#> (set yaulp spell to what loaded in gem#)
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset autoyaulp TRUE 
		/echo INFO: ZBot will Auto Yaulp!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset autoyaulp FALSE 
		/echo INFO: ZBot will NOT Auto Yaulp!
	} else /if (${Line.Arg[3].Length}==1) {
		/varset yaulpspell ${Me.Gem[${Line.Arg[3]}].Name}
		/call SetIni General yaulpspell "${yaulpspell}"
		/echo INFO: Yaulp Spell set to ${yaulpspell}
	} else {
		/varset yaulppct ${Line.Arg[3]}
		/call SetIni General yaulppct ${yaulppct}
		/echo INFO: Yaulp set to ${yaulppct}% mana
	}
	/call SetIni General autoyaulp ${autoyaulp}
/return 

Sub Event_SetCanni(string Line)
	/if (${Line.Arg[3].Length}==0) {
		/call EchoHelp Canni${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset autocanni TRUE 
		/echo INFO: ZBot will Auto Canni!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset autocanni FALSE 
		/echo INFO: ZBot will NOT Auto Canni!
	} else /if (${Line.Arg[3].Length}==1) {
		/varset cannispell ${Me.Gem[${Line.Arg[3]}].Name}
		/if (${Line.Arg[4].Length}) /varset smallcannihp ${Line.Arg[4]}
		/call SetIni General smallcannihp ${smallcannihp}
		/call SetIni General cannispell "${cannispell}"
		/echo INFO: Canni Spell set to ${cannispell}
		/echo INFO: Canni HP required ${smallcannihp}
	} else {
		/varset cannipct ${Line.Arg[3]}
		/if (${Line.Arg[4].Length}) /varset bigcannipct ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset bigcannihp ${Line.Arg[5]}
		/call SetIni General cannipct ${cannipct}
		/call SetIni General bigcannipct ${bigcannipct}
		/call SetIni General bigcannihp ${bigcannihp}
		/echo INFO: casting ${cannispell} @ ${cannipct}% mana, Cannibalization @ ${bigcannipct}% mana/${bigcannihp} hp
	}
	/call SetIni General autocanni ${autocanni}
/return 

Sub Event_SetHarvest(string Line)
	/if (${Line.Arg[3].Length}==0) {
		/call EchoHelp harvest${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset autoharvest TRUE 
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset autoharvest FALSE 
	} else /if (${Line.Arg[3].Length}==1) {
		/varset harvestspell ${Me.Gem[${Line.Arg[3]}].Name}
		/varset autoharvest TRUE 
		/call SetIni General harvestspell "${harvestspell}"
	} else {
		/varset autoharvest TRUE 
		/varset harvestpct ${Line.Arg[3]}
		/if (${Line.Arg[4].Length}) /varset harvestwait ${Line.Arg[4]}
		/call SetIni General harvestpct ${harvestpct}
		/call SetIni General harvestwait ${harvestwait}
	}
	/echo INFO: ZBot Auto harvest = ${autoharvest}
	/echo INFO: Harvesting set with ${harvestspell} @ ${harvestpct}% waiting ${harvestwait}
	/call SetIni General autoharvest ${autoharvest}
/return 

Sub FeedCheck
	/if (${Me.PctMana}<${feedperc} && !${feedtimer} && ${Spawn[pc ${feedperson}].ID} && ${Spawn[pc ${feedperson}].Distance}<100) {
		/tell ${feedperson} feed
		/varset feedtimer 2m
	}
/return

Sub EventIni
	/declare i int

	/call LoadIni Events active doevents
	/call LoadIni Events events eventset
	/call LoadIni Events eventmsg1 trigger1
	/call LoadIni Events eventmsg2 trigger2
	/call LoadIni Events eventmsg3 trigger3
	/call LoadIni Events eventmsg4 trigger4
	/call LoadIni Events eventmsg5 trigger5

	/varset eventcount 0
	/for i 1 to 30
		/if (!${Ini[${Me.Name}Settings.ini,${eventset},event${i}].Length}) /return

		/varset eventcount ${i}
		/call LoadIni ${eventset} event${i} event[${i}]
		/call LoadIni ${eventset} when${i} eventwhen[${i}]
		/call LoadIni ${eventset} value${i} eventvalue[${i}]
		/call LoadIni ${eventset} thresh${i} eventthresh[${i}]
		/call LoadIni ${eventset} type${i} eventtype[${i}]
		/varset eventecho[${i}] FALSE
		/call LoadIni ${eventset} echo${i} eventecho[${i}]
		/if (!${eventtype[${i}].Length}) {
			/if (${event[${i}].Left.Equal[\]}) {
				/varset eventtype[${i}] SLASH
			} else /if (${FindItemCount[=${event[${i}]}]}) {
				/varset eventtype[${i}] ITEM
			} else /if (${Me.Gem[${event[${i}]}]}) {
				/varset eventtype[${i}] SPELL
			} else /if (${Me.CombatAbility[${event[${i}]}]}) {
				/varset eventtype[${i}] COMBAT
			} else /if (${Me.Ability[${event[${i}]}]}) {
				/varset eventtype[${i}] ABILITY
			} else /if (${Me.AltAbility[${event[${i}]}]}) {
				/varset eventtype[${i}] ALT
			}
		}

		/call GetAlias "${event[${i}]}"
		/if (${Macro.Return.NotEqual[NotFound]}) {
			/varset event[${i}] ${Macro.Return}
		}

		/if (${eventwhen[${i}].Equal[COMBAT]}) {
			/varset eventsub[${i}] EventCOMBAT
		} else /if (${eventwhen[${i}].Equal[AUTOFIRE]}) {
			/varset eventsub[${i}] EventAUTOFIRE
		} else /if (${eventwhen[${i}].Equal[BOSS]}) {
			/varset eventsub[${i}] EventBOSS
		} else /if (${eventwhen[${i}].Equal[ALWAYS]}) {
			/varset eventsub[${i}] EventALWAYS
		} else /if (${eventwhen[${i}].Equal[TOTNPC]}) {
			/varset eventsub[${i}] EventTOTNPC
		} else /if (${eventwhen[${i}].Equal[GATE]}) {
			/varset eventsub[${i}] EventGATE
		} else /if (${eventwhen[${i}].Equal[AGGRO]}) {
			/varset eventsub[${i}] EventAGGRO
		} else /if (${eventwhen[${i}].Equal[BOSSAGGRO]}) {
			/varset eventsub[${i}] EventBOSSAGGRO
		} else /if (${eventwhen[${i}].Equal[NOTANK]}) {
			/varset eventsub[${i}] EventNOTANK
		} else /if (${eventwhen[${i}].Equal[NEEDTANK]}) {
			/varset eventsub[${i}] EventNEEDTANK
		} else /if (${eventwhen[${i}].Equal[HURT]}) {
			/varset eventsub[${i}] EventHURT
		} else /if (${eventwhen[${i}].Equal[HURTCOMBAT]}) {
			/varset eventsub[${i}] EventHURTCOMBAT
		} else /if (${eventwhen[${i}].Equal[HURTAGGRO]}) {
			/varset eventsub[${i}] EventHURTAGGRO
		} else /if (${eventwhen[${i}].Equal[NPC]}) {
			/varset eventsub[${i}] EventNPC
		} else /if (${eventwhen[${i}].Equal[IDLE]}) {
			/varset eventsub[${i}] EventIDLE
		} else /if (${eventwhen[${i}].Equal[IDLE1]}) {
			/varset eventsub[${i}] EventIDLE1
		} else /if (${eventwhen[${i}].Equal[IDLE5]}) {
			/varset eventsub[${i}] EventIDLE5
		} else /if (${eventwhen[${i}].Equal[NOCOMBAT]}) {
			/varset eventsub[${i}] EventNOCOMBAT
		} else /if (${eventwhen[${i}].Equal[BEHIND]}) {
			/varset eventsub[${i}] EventBEHIND
		} else /if (${eventwhen[${i}].Equal[MAX]}) {
			/varset eventsub[${i}] EventMAX
		} else /if (${eventwhen[${i}].Equal[MOB]}) {
			/varset eventsub[${i}] EventMOB
		} else /if (${eventwhen[${i}].Equal[PETHP]}) {
			/varset eventsub[${i}] EventPETHP
		} else /if (${eventwhen[${i}].Equal[GROUPAVG]}) {
			/varset eventsub[${i}] EventGROUPAVG
		} else /if (${eventwhen[${i}].Equal[BUFF]}) {
			/varset eventsub[${i}] EventBUFF
		} else /if (${eventwhen[${i}].Equal[SONG]}) {
			/varset eventsub[${i}] EventSONG
		} else /if (${eventwhen[${i}].Equal[MANA]}) {
			/varset eventsub[${i}] EventMANA
		} else /if (${eventwhen[${i}].Equal[ENDUR]}) {
			/varset eventsub[${i}] EventENDUR
		} else {
			/varset eventsub[${i}] EventNEVER
			/echo ERROR: Invalid EVENT attribute on ${event[${i}]}="${eventwhen[${i}]}"
			/return FALSE
		}
	/next i
/return

Sub DoEvents
|	/if (${Me.Invis} || ${Me.Moving} || ${eventtimer}) /return FALSE
	/if (${Me.Invis} || ${eventtimer}) /return FALSE
	/if (!${bard} && ${Me.Casting.ID}) /return FALSE

	/declare i int

	/if (${Target.ID}==${ignoreid}) /return FALSE

	/if (${dotrigger} && !${triggertimer}) {
		/if (${idle}) {
			/for i 1 to 10
				/if (${triggerlist[${i}].NotEqual[NULL]}) {
					/if (${FindItem[=${triggerlist[${i}]}].ID}) {
						/if (!${FindItem[=${triggerlist[${i}]}].Timer} && ${Spell[${FindItem[=${triggerlist[${i}]}].Spell}].Stacks}) {
							/if (${bard} && ${Twist}) /call StopTwist
							/casting "${triggerlist[${i}]}"|Item
							/varset triggertimer EVENTDELAY
							/return TRUE
						}
					} else /if (${triggerlist[${i}].Left[1].Equal[/]}) {
						/if (${bard} && ${Twist}) /call StopTwist
						/docommand ${triggerlist[${i}]} 
						/varset eventtimer EVENTDELAY
						/delay 5s !${Me.Casting.ID}
						/return TRUE
					} else /if (${Me.CombatAbility[${triggerlist[${i}]}]}) {
						/if (!${Me.CombatAbilityTimer[${triggerlist[${i}]}]} && ${Spell[${triggerlist[${i}]}].Stacks}) {
							/if (${bard} && ${Twist}) /call StopTwist
							/docommand /disc ${triggerlist[${i}]}
							/delay 5s !${Me.Casting.ID}
							/varset triggertimer EVENTDELAY
							/return TRUE
						}
					} else /if (${Me.AltAbility[${triggerlist[${i}]}]}) {
						/if (${bard} && ${triggerlist[${i}].Equal[Dance of Blades]} && ${Me.AltAbilityReady[${triggerlist[${i}]}]}) { 
							/goto :bardaltskip
						}
						/if (${Me.AltAbilityReady[${triggerlist[${i}]}]} && ${Spell[${triggerlist[${i}]}].Stacks}) {
							:bardaltskip
							/if (${bard} && ${Twist}) /call StopTwist
							/casting "${triggerlist[${i}]}"|alt
							/varset triggertimer EVENTDELAY
							/return TRUE
						}
					} else /if (${Spell[${triggerlist[${i}]}].ID}) {
						/if (${Me.SpellReady[${triggerlist[${i}]}]} && ${Spell[${triggerlist[${i}]}].Stacks}) {
							/if (${bard} && ${Twist}) /call StopTwist
							/casting "${triggerlist[${i}]}"|gem9
							/varset triggertimer EVENTDELAY
							/return TRUE
						}
					}
				}
			/next i
		} else {
			/varset dotrigger FALSE
		}
	}

	/if (!${eventcount}) /return FALSE
	/for i 1 to ${eventcount}
		/if (${eventtype[${i}].Equal[ITEM]}) {
			/if (!${FindItem[=${event[${i}]}].Timer} && ${Spell[${FindItem[=${event[${i}]}].Spell}].Stacks}) {
				/call ${eventsub[${i}]} ${eventvalue[${i}]}
				/if (${Macro.Return}) {
					/call DottedAlready ${Me.TargetOfTarget.ID} "${event[${i}]}" 3
					/if (!${Macro.Return}) {
						/declare curid ${Target.ID}
						/target id ${Me.TargetOfTarget.ID}
						/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(ITEM)...${event[${i}]}/${eventsub[${i}]}[+x+]
						/call ResistCast "${event[${i}]}" Item
						/if (${Macro.Return.Equal[CAST_SUCCESS]}) {
							/call AddDot ${Target.ID} "${event[${i}]}" ${Math.Calc[${FindItem[${event[${i}]}].Spell.Duration}*60]}
						}
						/target id ${curid}
						/return TRUE
					}
				}
			}
		} else /if (${eventtype[${i}].Equal[SPELL]}) {
			/if (${Me.SpellReady[${event[${i}]}]} && ${Spell[${event[${i}]}].Stacks}) {
				/call ${eventsub[${i}]} ${eventvalue[${i}]}
				/if (${Macro.Return}) {
					/call SetBandolier ${Spell[${event[${i}]}].ID}
					/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(SPELL)...${event[${i}]}/${eventsub[${i}]}[+x+]
					/casting "${event[${i}]}|gem9 ${bandset}
					/varset eventtimer EVENTDELAY
					/delay 30s !${Me.Casting.ID}
					/return TRUE
				}
			}
		} else /if (${eventtype[${i}].Equal[COMBAT]}) {
			/if (!${Me.CombatAbilityTimer[${event[${i}]}]} && ${Spell[${event[${i}]}].Stacks} && ${Me.PctEndurance}>=${eventthresh[${i}]}) {
				/call ${eventsub[${i}]} ${eventvalue[${i}]}
				/if (${Macro.Return}) {
					/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(CA)...${event[${i}]}/${eventsub[${i}]}[+x+]
					/docommand /disc ${event[${i}]}
					/varset eventtimer EVENTDELAY
					/delay 5s !${Me.Casting.ID}
					/return TRUE
				}
			}
		} else /if (${eventtype[${i}].Equal[ABILITY]}) {
			/if (${Me.AbilityReady[${event[${i}]}]}) {
				/call ${eventsub[${i}]} ${eventvalue[${i}]}
				/if (${Macro.Return}) {
					/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(ABILITY)...${event[${i}]}/${eventsub[${i}]}[+x+]
					/docommand /doability "${event[${i}]}"
					/varset eventtimer EVENTDELAY
					/delay 5s !${Me.Casting.ID}
					/return TRUE
				}
			}
		} else /if (${eventtype[${i}].Equal[ALT]}) {
			/if (${Me.AltAbilityReady[${event[${i}]}]} && ${Spell[${event[${i}]}].Stacks}) {
				/if (${Me.AltAbility[${event[${i}]}].Spell.Range} && ${Target.Distance}>${Me.AltAbility[${event[${i}]}].Spell.Range}) /goto :trynextevent
				/call ${eventsub[${i}]} ${eventvalue[${i}]}
				/if (${Macro.Return}) {
					/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(AA)...${event[${i}]}/${eventsub[${i}]}[+x+]
					/docommand /aa act ${event[${i}]} 
					/varset eventtimer EVENTDELAY
					/delay 5s !${Me.Casting.ID}
					/return TRUE
				}
			}
		} else /if (${eventtype[${i}].Equal[SLASH]}) {
			/call ${eventsub[${i}]} ${eventvalue[${i}]}
			/if (${Macro.Return}) {
				/if (${EQBC.Connected} && ${eventecho[${i}]}) /docommand /${bctell} [+t+]Event Fire(AA)...${event[${i}]}/${eventsub[${i}]}[+x+]
				/docommand ${event[${i}]} 
				/varset eventtimer EVENTDELAY
				/delay 5s !${Me.Casting.ID}
				/return TRUE
			}
		}
		:trynextevent
	/next i
	
	/if (${bard} && ${retwist}) /call Retwist
/return FALSE
	
Sub StopTwist
	/if (!${Twist}) /return
		/varset retwist TRUE
		/twist stop
		/call WaitCast
/return

Sub Retwist
	/if (${Twist}) /return
		/twist start
		/varset retwist FALSE
/return

Sub EventCOMBAT(value)
/if (${value}) /return (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.LineOfSight} && ${Target.Distance}<=${value})
/return (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.LineOfSight})

Sub EventAUTOFIRE(value)
/if (${value}) /return (${Me.AutoFire} && ${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.LineOfSight} && ${Target.Distance}<=${value})
/return (${Me.AutoFire} && ${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.LineOfSight})

Sub EventALWAYS(value)
/return TRUE

Sub EventNEVER(value)
/return FALSE

Sub EventTOTNPC(value)
/return (${Me.TargetOfTarget.Type.Equal[NPC]} && ${Me.TargetOfTarget.PctHPs}<=${value})

Sub EventNOTANK(value)
	/if (${Me.TargetOfTarget.ID}!=${lasttankid}) {
		/varset lasttankid ${Me.TargetOfTarget.ID}
		/return FALSE
	}
	/if (${value}) /return (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Target.Distance}<=${value} && (${Me.TargetOfTarget.ID}==${Me.ID} || (${Me.TargetOfTarget.Class.ShortName.NotEqual[WAR]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[PAL]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[SHD]})))
/return (${Me.Combat} && ${Target.Type.Equal[NPC]} && (${Me.TargetOfTarget.ID}==${Me.ID} || (${Me.TargetOfTarget.Class.ShortName.NotEqual[WAR]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[PAL]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[SHD]})))

Sub EventNEEDTANK(value)
	/if (${Me.TargetOfTarget.ID}!=${lasttankid}) {
		/varset lasttankid ${Me.TargetOfTarget.ID}
		/return FALSE
	}
	/if (${value}) /return (${Target.Type.Equal[NPC]} && ${Target.Distance}<=${value} && (${Me.TargetOfTarget.Class.ShortName.NotEqual[WAR]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[PAL]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[SHD]}))
/return (${Target.Type.Equal[NPC]} && (${Me.TargetOfTarget.Class.ShortName.NotEqual[WAR]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[PAL]} && ${Me.TargetOfTarget.Class.ShortName.NotEqual[SHD]}))

Sub EventGATE(value)
/return ${gating}

Sub EventAGGRO(value)
	/if (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.ID}==${Me.ID}) /return TRUE
/return FALSE

Sub EventBOSSAGGRO(value)
/return (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.ID}==${Me.ID} && ${Target.Level}>=${bosslevel})

Sub EventHURT(value)
/return (${Me.PctHPs}<=${value})

Sub EventHURTCOMBAT(value)
/return (${Me.PctHPs}<=${value} && ${Me.Combat})

Sub EventHURTAGGRO(value)
/return (${Me.PctHPs}<=${value} && ${Me.TargetOfTarget.ID}==${Me.ID})

Sub EventBOSS(value)
/return (${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${value} && ${Target.Level}>=${bosslevel} && ${Target.LineOfSight})

Sub EventNPC(value)
	/if (${value}) /return (${Target.Type.Equal[NPC]} && ${Target.Distance}<=${value})
/return ${Target.Type.Equal[NPC]}

Sub EventIDLE(value)
/return !${Me.Combat}

Sub EventIDLE1(value)
/return !${Me.Combat}

Sub EventIDLE2(value)
/return !${Me.Combat}

Sub EventNOCOMBAT(value)
/return (${Target.Type.Equal[NPC]} && !${Me.Combat})

Sub EventBEHIND(value)
/if (!${Me.Combat} || !${Target.Type.Equal[NPC]} || ${Target.Distance}>${Math.Calc[${Target.MaxRangeTo}*150/100]}) /return FALSE
/call CheckBehind 
/return ${Macro.Return} 

Sub EventMOB(value)
/return (${Me.Combat} && ${Target.Type.Equal[NPC]} && ${Target.Distance}<${Math.Calc[${Target.MaxRangeTo}*150/100]} && ${SpawnCount[NPC radius 75]}>=${value} && ${Target.LineOfSight})

Sub EventPETHP(value)
/return (${Me.Pet.ID} && ${Me.Pet.PctHPs}<=${value})

Sub EventGROUPAVG(value)
	/declare avg int 0
	/declare i int
	/declare count int 0

	/for i 0 to ${Group}
		/if (${Group.Member[${i}].PctHPs}) {
			/varcalc avg ${avg}+${Group.Member[${i}].PctHPs}
			/varcalc count ${count}+1
		}
	/next i
	/varcalc avg ${avg}/${count}
/return (${avg}<=${value})

Sub EventMANA(value)
/return (${Me.PctMana}<=${value})

Sub EventENDUR(value)
/return (${Me.Endurance}>300 && ${Me.PctEndurance}<=${value})

Sub EventBUFF(value)
/return (${Me.Buff[${value}].ID})

Sub EventSONG(value)
/return (${Me.Song[${value}].ID})

Sub Event_SetEvents(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Events${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset doevents TRUE 
		/echo INFO: Events are  ON!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset doevents FALSE 
		/echo INFO: Events are OFF!
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset eventset Events
		/if (${Line.Arg[4].Length}) /varset eventset Events${Line.Arg[4]}
		/varset doevents TRUE
		/echo INFO: Event Set is now ${eventset}
		/call SetIni Events events ${eventset}
		/call EventIni
		/return
	} else /if (${Line.Arg[3].Equal[LIST]}) {
		/declare i int
		/echo INFO: Events Listing [${eventset}]
		/echo INFO: Events = ${doevents}!
		/if (${eventcount}) {
				/echo INFO: event, type, when, value, thresh, echo
			/for i 1 to ${eventcount}
				/echo ...${i}: ${event[${i}]}, ${eventtype[${i}]}, ${eventwhen[${i}]}, ${eventvalue[${i}]}, ${eventthresh[${i}]}, ${eventecho[${i}]}
			/next i
		}
		/return
	}

	/call SetIni Events active ${doevents}
/return 

Sub Event_Trigger1
	/call AddTrigger 1
/return
Sub Event_Trigger2
	/call AddTrigger 2
/return
Sub Event_Trigger3
	/call AddTrigger 3
/return
Sub Event_Trigger4
	/call AddTrigger 4
/return
Sub Event_Trigger5
	/call AddTrigger 5
/return

Sub AddTrigger(int set)
	/declare i int local
	/declare Item string local

	/varset dotrigger TRUE
	/for i 1 to 10
		/varset Item ${Ini[${Me.Name}Settings.ini,Events,eventset${set}].Token[${i},|]}
		/if (${Item.Length}) {
			/if (${Item.Equal[epic]} && ${FindItem[${epic}].ID}) {
				/varset triggerlist[${i}] ${epic}
			} else {
				/varset triggerlist[${i}] ${Item}
			}
		} else {
			/varset triggerlist[${i}] NULL
		}
	/next i
/return

Sub GearIni
	/declare i int

	/call LoadIni Gear active dogear
	/call LoadIni Gear gear gearset
	/call LoadIni Gear delay geardelay

	/for i 1 to 21
		/if (${Ini[${Me.Name}Settings.ini,${gearset},${i}].Length}) {
			/varset gear[${i}] ${FindItem[=${Ini[${Me.Name}Settings.ini,${gearset},${i}]}].ID}
		} else {
			/varset gear[${i}] 0
		}
	/next i
/return

Sub CheckGear
	/declare i int

	/if (${geartimer} || ${Cursor.ID} || ${Me.Casting.ID}) /return

	/for i 1 to 21
		/if (${gear[${i}]} && ${InvSlot[${i}].Item.ID}!=${gear[${i}]}) {
			/if (${FindItemCount[=${Ini[${Me.Name}Settings.ini,${gearset},${i}]}]}) {
				/exchange ${gear[${i}]} ${i}
			}
		}
	/next i

	/varset geartimer ${geardelay}
/return

Sub SetBandolier(int spellid)
	/declare i int

	/varset bandset 

	/for i 1 to 50
		/if (!${spellsid[${i}]}) /return
		/if (${spellid}==${spellsid[${i}]}) {
			/varset bandset -bandolier|${spellsband[${i}]}
			/return
		}
	/next i
/return

Sub Event_SetGear(string Line)
	/declare i int

	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Gear${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset dogear TRUE 
		/echo INFO: Gear checks are  ON!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset dogear FALSE 
		/echo INFO: Gear checks are OFF!
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset gearset Gear
		/if (${Line.Arg[4].Length}) /varset gearset Gear${Line.Arg[4]}
		/varset dogear TRUE
		/echo INFO: Gear Set loaded ${gearset}
		/call SetIni Gear gear ${gearset}
		/for i 1 to 21
			/if (${Ini[${Me.Name}Settings.ini,${gearset},${i}].Length}) {
				/varset gear[${i}] ${FindItem[=${Ini[${Me.Name}Settings.ini,${gearset},${i}]}].ID}
			} else {
				/varset gear[${i}] 0
			}
		/next i
	} else /if (${Line.Arg[3].Equal[SAVE]}) {
		/if (!${Line.Arg[4].Length}) {
			/varset gearset Gear
		} else {
			/varset gearset Gear${Line.Arg[4]}
		}

		/varset dogear TRUE
		/echo INFO: Gear Set saved to ${gearset}
		/call SetIni Gear gear ${gearset}
		/for i 1 to 21
			/if (${InvSlot[${i}].Item.ID}) {
				/varset gear[${i}] ${InvSlot[${i}].Item.ID}
				/call SetIni ${gearset} ${i} "${InvSlot[${i}].Item}"
			} else {
				/varset gear[${i}] 0
			}
		/next i
	} else /if (${Line.Arg[3].Equal[TIME]}) {
		/if (!${Line.Arg[4].Length}) /varset geardelay ${Line.Arg[4]}
		/echo INFO: Gear checks every ${geardelay}
		/call SetIni Gear delay ${geardelay}
		/return
	} else /if (${Line.Arg[3].Equal[LINK]}) {
		/for i 1 to 50
			/if (!${Ini[${Me.Name}Settings.ini,Spells,spell${i}].Length}) {
				/call SetIni Spells spell${i} "${Me.Gem[${Line.Arg[4]}]}"
				/call SetIni Spells band${i} "${Line.Arg[5]}"
				/varset spellsid[${i}] ${Me.Gem[${Line.Arg[4]}].ID}
				/varset spellsband[${i}] ${Line.Arg[5]}
				/return
			}
		/next i
		/return
	}

	/call SetIni Gear active ${dogear}
/return 

Sub PetIni
	/declare i int
	/declare j int

	/call LoadIni Pet active doautopet
	/call LoadIni Pet summon petsummon
	/call LoadIni Pet summonAA petsummonAA
	/call LoadIni Pet shrink petshrink
	/call LoadIni Pet healpct pethealpct
	/call LoadIni Pet aapct petaahealpct
	/call LoadIni Pet healspell pethealspell
	/call LoadIni Pet gem petgem
	/call LoadIni Pet combatbuff petcombatbuff

	/for i 1 to 5
		/if (${Ini[${Me.Name}Settings.ini,Pet,buff${i}].NotEqual[NULL]}) /varset petbuff[${i}] ${Ini[${Me.Name}Settings.ini,Pet,buff${i}]} 
		/if (${Ini[${Me.Name}Settings.ini,Pet,name${i}].NotEqual[NULL]}) /varset petname[${i}] ${Ini[${Me.Name}Settings.ini,Pet,name${i}]} 
	/next i
	
	/for j 1 to 5
		/if (${Ini[${Me.Name}Settings.ini,Pet,clicky${j}].NotEqual[NULL]}) /varset petclicky[${j}] ${Ini[${Me.Name}Settings.ini,Pet,clicky${j}]} 
		/if (${Ini[${Me.Name}Settings.ini,Pet,clickyname${j}].NotEqual[NULL]}) /varset petclickyname[${j}] ${Ini[${Me.Name}Settings.ini,Pet,clickyname${j}]}
	/next j
/return

Sub DoPetGHold	
	/if (${Me.Pet.ID}) {
		/pet ghold on
		/pet no taunt
	}
/return

Sub DoPetStuff
	/if (${Me.Invis} || ${Me.Moving}) /return FALSE
	/if (${Target.Type.Equal[NPC]} && ${Me.TargetOfTarget.Name.Equal[${Me}]}) /return FALSE

	/declare i int
	/declare j int
	
	/if ((${Me.Buff[${petsummon}].ID} || ${Me.Buff[${petsummonAA}].ID}) && ${Me.Class.Name.Equal[Wizard]}) {
		/if (${Me.Pet.ID}) /pet get lost
		/return FALSE
	}
	
	/if (!${Me.Pet.ID}) { 
		/if (${petsummon.Equal[NULL]} && ${petsummonAA.Equal[NULL]}) {
			/echo ERROR: no pet summon spell defined, disabling autopet
			/varset doautopet FALSE
			/return FALSE
		}
		/if (${Me.AltAbilityReady[${petsummonAA}]}) {
			/docommand /aa act ${petsummonAA}
			/call WaitCast
			/return TRUE
		}
		/if (${Spell[${petsummon}].Mana}>${Me.CurrentMana}) /return FALSE
		/call SetBandolier ${Spell[${petsummon}].ID}
		/casting "${petsummon}"|${petgem} ${bandset}
		/call WaitCast
		/delay 1s ${Me.Pet.ID}
		/pet no taunt
		/pet ghold on
		/varset petcombat FALSE
		/return TRUE
	}
	
	/if (${Me.Pet.PctHPs}<=${petaahealpct} && ${Me.AltAbilityReady[Mend Companion]} && ${Me.Pet.Distance}<=${Spell[Mend Companion].MyRange}) {
		/aa act Mend Companion
		/return TRUE
	}
	
	/if (${Me.Pet.PctHPs}<=${pethealpct} && ${Me.Pet.Distance}<=${Spell[${pethealspell}].MyRange}) {
		/if (${Me.CurrentMana}<${Spell[${pethealspell}].Mana}) /return FALSE
		/call SaveState
		/call SetBandolier ${Spell[${pethealspell}].ID}
		/casting "${pethealspell}"|${petgem} -targetid|${Me.Pet.ID} ${bandset}
		/call WaitCast
		/call RestoreState
		/return TRUE
	}

	/if (!${Me.Combat}) {
		/if (!${petminsize} && ${Ini[ZShrink.ini,${Zone.ShortName},pet${Me.Class.ShortName}].Length}) /varset petminsize ${Ini[ZShrink.ini,${Zone.ShortName},pet${Me.Class.ShortName}]}

		/if (${Me.Pet.Height}>${petminsize} && ${petshrink.NotEqual[NULL]} && ${Me.Pet.LineOfSight}) {
			/declare old float ${Me.Pet.Height}
			/if (${FindItemCount[=${petshrink}]} && ${Me.Pet.Distance}<=${FindItem[=${petshrink}].Spell.Range}) {
				/casting "${petshrink}"|Item -targetid|${Me.Pet.ID}
				/call WaitCast
				/if (${Cast.Result.Equal[CAST_SUCCESS]} && ${Me.Pet.Height}==${old}) {
					/varset petminsize ${Me.Pet.Height}
					/if (!${Ini[ZShrink.ini,${Zone.ShortName},pet${Me.Class.ShortName}].Length}) /ini "ZShrink.ini" "${Zone.ShortName}" "pet${Me.Class.ShortName}" "${petminsize}" 
				}
				/return TRUE
			} else {
				/if (${Spell[${petshrink}].Mana}>${Me.CurrentMana} || ${Me.Pet.Distance}>${Spell[${petshrink}].MyRange}) /return FALSE
				/casting "${petshrink}"|${petgem} -targetid|${Me.Pet.ID}
				/call WaitCast
				/if (${Cast.Result.Equal[CAST_SUCCESS]} && ${Me.Pet.Height}==${old}) {
					/varset petminsize ${Me.Pet.Height}
					/if (!${Ini[ZShrink.ini,${Zone.ShortName},pet${Me.Class.ShortName}].Length}) /ini "ZShrink.ini" "${Zone.ShortName}" "pet${Me.Class.ShortName}" "${petminsize}" 
				}
				/return TRUE
			}
		}
	}
	
	/for j 1 to 5
		/if (${petclicky[${j}].Equal[NULL]}) /break
		/if (${Me.PetBuff[${petclicky[${j}]}]} || ${Me.PetBuff[${petclickyname[${j}]}]}) /continue
		/if (${FindItemCount[=${petclicky[${j}]}]} && !${FindItem[=${petclicky[${j}]}].Timer} && ${Me.Pet.Distance}<=${FindItem[=${petclicky[${j}]}].Spell.Range}) { 
			/call SaveState
			/call SetBandolier ${Spell[${petclicky[${j}]}].ID}
			/casting "${petclicky[${j}]}" -targetid|${Me.Pet.ID} ${bandset}
			/call WaitCast
			/call RestoreState
			/return TRUE
		}
	/next j
	
	/for i 1 to 5
		/if (!${petcombatbuff} && ${Me.Combat}) /break
		/if (!${petcombatbuff} && ${petcombatnuketimer}) /break
		/if (${petbuff[${i}].Equal[NULL]}) /break
		/if (${Me.PetBuff[${petbuff[${i}]}]} || ${Me.PetBuff[${petname[${i}]}]}) /continue
		/if (${Me.Gem[${petbuff[${i}]}]}) /goto :skippetmem
			/memorize "${petbuff[${i}]}"|${petgem}
		:skippetmem
		/if (!${Cast.Ready[${petbuff[${i}]}]}) /break
		/if (${Spell[${petbuff[${i}]}].Mana}<=${Me.CurrentMana} && ${Me.Pet.Distance}<=${Spell[${petbuff[${i}]}].Range}) { 
			/call SaveState
			/call SetBandolier ${Spell[${petbuff[${i}]}].ID}
			/casting "${petbuff[${i}]}"|${petgem} -targetid|${Me.Pet.ID} ${bandset}
			/call WaitCast
			/call RestoreState
			/return TRUE
		}
	/next i
/return FALSE

Sub ManagePet
	/if (${dpspaused}) {
		/if (!${dofocus} || !${SpawnCount[npc ${focuslist} radius ${focusrng} zradius 30]}) {
			/if (${petcombat}) {
				/pet back off
				/pet ghold on
				/varset petcombat FALSE
			}
			/return
		}
	}
	
	/if (!${petcombat}) {
		/if (${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.PctHPs}>${stoppct} && ${Target.ID}!=${ignoreid} && !${enraged}) {
			/pet attack
			/varset pettarget ${Target.ID}
			/varset petcombat TRUE
		}
	} else {
		/if (${enraged}) {
			/declare behind FALSE 
			/declare i int
			/declare dir int
			/for i -3 to 3
				/varcalc dir (${Spawn[${pettarget}].Heading.Clock}+${i})%12 
				/if (${dir}<1) /varcalc dir ${dir}+12 
				/if (${dir}>12) /varcalc dir ${dir}-12 
				/if (${dir}==${Me.Pet.Heading.Clock}) /varset behind TRUE 
			/next i
			/if (!${behind}) {
				/pet back off
				/pet ghold on
				/varset petcombat FALSE
			}
		} else {
			/if (${Target.Type.Equal[NPC]} && ${Target.PctHPs}<=${assistpct} && ${Target.PctHPs}>${stoppct} && ${Target.ID}!=${pettarget} && ${Target.ID}!=${ignoreid}) {
				/pet back off
				/varset pettarget ${Target.ID}
				/varset petcombat TRUE
				/pet attack
			}
		}
	}
/return

Sub Event_SetAutoPet(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Autopet${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset doautopet TRUE 
	} else /if (${Line.Arg[3].Equal[GIVE]}) {
		/call GearPet
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset doautopet FALSE 
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset petgem gem${Line.Arg[4]}
		/varset petsummon ${Me.Gem[${Line.Arg[5]}].Name}
		/varset petshrink ${Me.Gem[${Line.Arg[6]}].Name}
		/varset pethealspell ${Me.Gem[${Line.Arg[7]}].Name}
		/echo INFO: Autopet: gem=${petgem}|summon=${petsummon}|shrink=${petshrink}|heal=${pethealspell}
		/call SetIni Pet gem ${petgem}
		/call SetIni Pet summon "${petsummon}"
		/call SetIni Pet shrink "${petshrink}"
		/call SetIni Pet healspell "${pethealspell}"
		/declare i int
		/declare j int 8
		/for i 1 to 5
			/varset petbuff[${i}] ${Me.Gem[${Line.Arg[${j}]}].Name}
			/if (${petbuff[${i}].NotEqual[NULL]}) {
				/echo INFO ...buff${i}=${petbuff[${i}]}
				/call SetIni Pet buff${i} "${petbuff[${i}]}"
			}
			/varcalc j ${j}+1
		/next i
		/return
	} else /if (${Line.Arg[3].Equal[HEAL]}) {
		/varset pethealpct ${Line.Arg[4]}
		/echo INFO: Healing Pet at ${pethealpct}%
	} else /if (${Line.Arg[3].Equal[COMBATBUFF]} && ${Line.Arg[4].Equal[ON]}) {
		/varset petcombatbuff TRUE
		/call SetIni Pet combatbuff TRUE
		/echo INFO: Auto-Pet will now buff during COMBAT.
	} else /if (${Line.Arg[3].Equal[COMBATBUFF]} && ${Line.Arg[4].Equal[OFF]}) {
		/varset petcombatbuff FALSE
		/call SetIni Pet combatbuff FALSE
		/echo INFO: Auto-Pet will no longer buff during COMBAT.
	}

	/if (${doautopet}) { 
		/echo INFO: Auto-Pet is ON!
	} else { 
		/echo INFO: Auto-Pet is OFF!
	} 

	/call SetIni Pet active ${doautopet}
	/call SetIni Pet healpct ${pethealpct}
/return

Sub Event_SetMisc(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Misc${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[SITMED]}) {
		/varset sitmed ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset sitmedrange ${Line.Arg[5]}
		/echo INFO: Sit Medding at ${sitmed}% if no mobs in ${sitmedrange} range.
		/call SetIni General sitmed ${sitmed}
		/call SetIni General sitmedrange ${sitmedrange}
	} else /if (${Line.Arg[3].Equal[IGNORE]}) {
		/varset ignoreid ${Target.ID}
		/echo INFO: Ignoring ${Spawn[${ignoreid}].CleanName}
	} else /if (${Line.Arg[3].Equal[FEED]}) {
		/varset feedperson ${Line.Arg[4]}
		/if (${Line.Arg[5].Length}) /varset feedperc ${Line.Arg[5]}
		/echo INFO: Necro feeds from ${feedperson} @ ${feedperc}% mana
		/call SetIni ModRod feedperson ${feedperson}
		/call SetIni ModRod feedperc ${feedperc}
	} else /if (${Line.Arg[3].Equal[FDSTAND]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset fdstand TRUE
		/if (${Line.Arg[4].Equal[OFF]}) /varset fdstand FALSE
		/echo INFO: FeignDeath standing = ${fdstand}
		/call SetIni General fdstand ${fdstand}
	} else /if (${Line.Arg[3].Equal[YellMana]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset yellmana TRUE
		/if (${Line.Arg[4].Equal[OFF]}) /varset yellmana FALSE
		/echo INFO: Yelling Mana to /rs below 20% = ${yellmana}
		/call SetIni General yellmana ${yellmana}
	} else /if (${Line.Arg[3].Equal[AUTOREZ]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset autorez TRUE
		/if (${Line.Arg[4].Equal[OFF]}) /varset autorez FALSE
		/echo INFO: Auto Rez Accept mode = ${autorez}
		/call SetIni General autorez ${autorez}
	} else /if (${Line.Arg[3].Equal[FORAGE]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset forage TRUE
		/if (${Line.Arg[4].Equal[OFF]}) /varset forage FALSE
		/echo INFO: Auto Forage mode = ${forage}
		/call SetIni General forage ${forage}
	} else /if (${Line.Arg[3].Equal[FOCUS]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset dofocus TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset dofocus FALSE
		} else {
			/varset focuslist ${Line.Arg[4]}
			/varset dofocus TRUE
			/if (${Line.Arg[5].Length}) /varset focusrng ${Line.Arg[5]}
		}
		/echo INFO: Focus mode = ${dofocus} (${focuslist}) rng=${focusrng}
	} else /if (${Line.Arg[3].Equal[DISARM]}) {
		/if (${Line.Arg[4].Equal[ON]}) {
			/varset dodisarm TRUE
		} else /if (${Line.Arg[4].Equal[OFF]}) {
			/varset dodisarm FALSE
		} else {
			/varset disarmlist ${Line.Arg[4]}
			/varset dodisarm TRUE
			/if (${Line.Arg[5].Length}) /varset disarmrng ${Line.Arg[5]}
		}
		/echo INFO: Disarm mode = ${dodisarm} (${disarmlist}) rng=${disarmrng}
	} else /if (${Line.Arg[3].Equal[MODROD]}) {
		/varset modrod ${Line.Arg[4]}
		/echo INFO: ModRod clicks at ${modrod}%
		/call SetIni ModRod modrod ${modrod}
	} else /if (${Line.Arg[3].Equal[BC]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset bcspam TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset bcspam FALSE
		/echo INFO: BC Spam = ${bcspam}
		/call SetIni General bcspam ${bcspam}
	} else /if (${Line.Arg[3].Equal[BCTELL]}) {
		/varset bctell bct ${Line.Arg[4]}
		/echo INFO: BC Spam set to /${bctell}
		/call SetIni General bctell "${bctell}"
	} else /if (${Line.Arg[3].Equal[BCNAMES]}) {
		/varset bclist ${Line.Right[-21]}
		/echo INFO: BC List set to ( ${bclist} )
		/call SetIni General bclist "${bclist}"
	} else /if (${Line.Arg[3].Equal[BCCMD]}) {
		/declare i int
		/for i 1 to ${Group}
			/bct ${Group.Member[${i}].Name} ${Line.Right[-20]}
		/next i
	} else /if (${Line.Arg[3].Equal[EVADE]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset autoevade TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset autoevade FALSE
		/call SetIni General autoevade ${autoevade}
		/echo INFO: Rogue auto evade mode = ${autoevade}
	} else /if (${Line.Arg[3].Equal[sos]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset autohide TRUE 
		/if (${Line.Arg[4].Equal[OFF]}) /varset autohide FALSE 
		/call SetIni General autohide ${autohide}
		/echo INFO: Rogue autohide (sos) mode = ${autohide}
	} else /if (${Line.Arg[3].Equal[CLICKDOOR]}) {
		/declare oldzone int ${Zone.ID}
		/declare zonetimer timer 20s
		/if (${Line.Arg[4].Length}) /varset zonetimer timer ${Line.Arg[4]}s
		/declare oldx float
		/declare oldy float
		/if (${Stick.Status.Equal[ON]}) /squelch /stick off
		/squelch /doortarget
		:movedoor
		/squelch /face fast door
		/varset oldx ${Me.X}
		/varset oldy ${Me.Y}
		/keypress USE hold
		/delay 2 ${oldzone}!=${Zone.ID}
		/keypress USE
		/if (${oldzone}!=${Zone.ID} || ${DoorTarget.Distance}>75 || !${zonetimer} || ${Math.Distance[${Me.Y},${Me.X}:${oldy},${oldx}]}>15) {
			/echo ${Time} flushing ALL events
			/doevents flush
			/keypress HOME
			/return
		}
		/if (${DoorTarget.Distance}>10) {
			/keypress forward hold
			/delay 2
			/keypress forward
		} else /if (${DoorTarget.Distance}>2) {
			/keypress forward hold
			/delay 1
			/keypress forward
		} else /if (${DoorTarget.Distance}<2) {
			/keypress back hold
			/delay 5
			/keypress back
		}
		/goto :movedoor
	} else /if (${Line.Arg[3].Equal[RESTOCK]}) {
		/call DoSummonItems TRUE ${Line.Arg[4]}
	} else /if (${Line.Arg[3].Equal[SHRINK]}) {
		/if (${Line.Arg[4].Equal[SET]}) {
			/if (${Line.Arg[5].Length}==1) {
				/call SaveAlias shrink "${Me.Gem[${Line.Arg[5]}].Name}"
				/echo INFO: Shrink set to "${Me.Gem[${Line.Arg[5]}].Name}"
			} else /if (${Cursor.ID}) {
				/call SaveAlias shrink "${Cursor.Name}"
				/echo INFO: Shrink set to "${Cursor.Name}"
			} else {
				/echo ERROR: must specify gem# or have shrink Item on cursor!
			}
			/return
		}
		/if (!${Me.Invis}) /call DoShrinks
		/return
	} else /if (${Line.Arg[3].Equal[ALIAS]}) {
		/if (${Line.Arg[4].Equal[SET]}) {
			/if (${Cursor.ID}) {
				/call SaveAlias ${Line.Arg[5]} "${Cursor.Name}"
				/echo INFO: Alias[${Line.Arg[5]}] set to "${Cursor.Name}"
			} else /if (${Line.Arg[6].Length}==1) {
				/call SaveAlias ${Line.Arg[5]} "${Me.Gem[${Line.Arg[6]}].Name}"
				/echo INFO: Alias[${Line.Arg[5]}] set to "${Me.Gem[${Line.Arg[6]}].Name}"
			} else {
				/call SaveAlias ${Line.Arg[5]} "${Line.Arg[6]}"
				/echo INFO: Alias[${Line.Arg[5]}] set to "${Line.Arg[6]}"
			}
			/return
		} else {
			/call ListAliases
		}
	} else /if (${Line.Arg[3].Equal[BOSS]}) {
		/varset bosslevel ${Line.Arg[4]}
		/echo INFO: boss level set at ${bosslevel}
		/call SetIni General bosslevel ${bosslevel}
	} else /if (${Line.Arg[3].Equal[WATCH]}) {
		/varset watchlist
		/if (${Line.Arg[4].Length}) /varset watchlist ${Line.Arg[4]}
		/varset watchcmd
		/if (${Line.Arg[5].Length}) /varset watchcmd ${Line.Arg[5]}
		/echo Info: Watching for mobs (${watchlist})
		/if (${watchlist.Length}) /varset watchtimer 1m
		/if (${watchcmd.Length}) /echo Info: Executing /${watchcmd}
	} else /if (${Line.Arg[3].Equal[DEBUG]}) {
		/varset debug ${Line.Arg[4]}
		/echo DEBUG: Debug level set to ${debug}!
	} else {
		/echo ERROR: unknown arg /misc ${Line.Arg[3]}!!!
	}
/return 

Sub DoSummonItems(bool mode, int value)
	/declare i int
	/declare when string
	/declare count int
	/declare regent string
	/declare what string
	/declare how string
	/declare thresh int

	/varset summontimer 2s
	/if ((${Me.Class.Name.NotEqual[Rogue]} && ${Me.Invis}) || ${Me.Moving} || ${Cursor.ID}) /return FALSE
	/if (${Me.Class.Name.Equal[Rogue]} && ${Me.Invis} && (!${autohide} || ${SpawnCount[NPC radius ${sitmedrange} zradius 30]})) /return FALSE

	/for i 1 to 9999
		/if (!${Ini[${Me.Name}Settings.ini,Summon,Item${i}].Length}) /return

		/varset when ${Ini[${Me.Name}Settings.ini,Summon,when${i}]}
		/if (${mode} || ${when.Equal[ALWAYS]} || (${when.Equal[IDLE]} && !${idle}) || (${when.Equal[IDLE1]} && !${idle1}) || (${when.Equal[IDLE5]} && !${idle5})) {

			/varset count ${Ini[${Me.Name}Settings.ini,Summon,count${i}]}
			/varset regent ${Ini[${Me.Name}Settings.ini,Summon,regent${i}]}
			/varset what ${Ini[${Me.Name}Settings.ini,Summon,Item${i}]}
			/varset how ${Ini[${Me.Name}Settings.ini,Summon,spell${i}]}
			/varset thresh ${Ini[${Me.Name}Settings.ini,Summon,mana${i}]}
			/if (${i}==1 && ${value}>${count}) /varset count ${value}

			:restock
			/if (${Me.PctMana}>=${thresh} && ${FindItemCount[=${what}]}<${count} && ${Me.FreeInventory} && (${regent.Equal[NULL]} || ${FindItemCount[=${regent}]})) {
				/target myself
				/if (${Me.Book[${how}]}) {
					/casting "${how}|${buffgem}
					/delay 20s ${Cast.Status.Equal[I]}
				} else /if (${Me.CombatAbility[${how}]}) {
					/if (!${Me.CombatAbilityTimer[${how}]}) /docommand /disc ${how}
				} else /if (${Me.Ability[${how}]}) {
					/if (${Me.AbilityReady[${how}]}) /docommand /doability "${how}"
				} else /if (${Me.AltAbility[${how}]}) {
					/if (${Me.AltAbilityReady[${how}]}) /docommand /aa act ${how} 
				} else /if (${FindItemCount[=${how}]}) {
					/if (!${FindItem[=${how}].Timer}) /casting "${how}"|Item
				}
				/delay 1s
				:wait
				/if (${Cursor.ID}) /autoinven
				/delay 1
				/if (${Me.Casting.ID} || ${Cast.Status.NotEqual[I]}) /goto :wait
				:store
				/delay 3
				/autoinven
				/if (${Cursor.ID}) /goto :store
				/if (!${mode} || ${Me.Moving}) /return
				/goto :restock
			}
		}
		:nexti
	/next i
/return

Sub ClickyIni
	/declare i int
	/declare itemid int

	/call LoadIni Clicky spam clickyspam
	/call LoadIni Clicky clickyset clickyset

	/varset clickycount 0
	/for i 1 to 99
		/if (!${Ini[${Me.Name}Settings.ini,${clickyset},clicky${i}].Length}) /return

		/varset itemid ${FindItem[=${Ini[${Me.Name}Settings.ini,${clickyset},clicky${i}]}].ID}

		/if (${itemid}) {
			/varcalc clickycount ${clickycount}+1
			/varset clickyname[${clickycount}] ${FindItem[=${Ini[${Me.Name}Settings.ini,${clickyset},clicky${i}]}].Name}
			/varset clickywhen[${clickycount}] ${Ini[${Me.Name}Settings.ini,${clickyset},when${i}]}
			/varset clickyfirst[${clickycount}] ${Ini[${Me.Name}Settings.ini,${clickyset},first${i}]}
			/varset clickylast[${clickycount}] ${Ini[${Me.Name}Settings.ini,${clickyset},last${i}]}
			/varset clickyzone[${clickycount}] ${Ini[${Me.Name}Settings.ini,${clickyset},zone${i}]}
			/if (${clickyfirst[${clickycount}]}<1) /varset clickyfirst[${clickycount}] 1
			/if (${clickylast[${clickycount}]}<1) /varset clickylast[${clickycount}] 99
			/varset clickyspell[${clickycount}] ${FindItem[=${Ini[${Me.Name}Settings.ini,${clickyset},clicky${i}]}].Spell.Name}
		}
	/next i
/return

Sub DoClicky
	/if ((!${bard} && ${Me.Moving}) || ${Cursor.ID}) /return FALSE
	/if (${Me.Class.Name.NotEqual[Rogue]} && ${Me.Invis}) /return FALSE
	/if (${Me.Class.Name.Equal[Rogue]} && ${Me.Invis} && (!${autohide} || ${SpawnCount[NPC radius ${Math.Calc[${sitmedrange}*2]} zradius 50]})) /return FALSE

	/declare i int
	/declare j int
	/declare wastwisting FALSE

	/varset clickytimer 5

	/for i 1 to ${clickycount}
		/if (!${clickyzone[${i}].Find[${Zone.ShortName}]} && (${clickywhen[${i}].Equal[ALWAYS]} || (${clickywhen[${i}].Equal[IDLE]} && !${idle}) || (${clickywhen[${i}].Equal[NOATTACK]} && !${Me.Combat}))) {
			/if (${Me.Buff[${clickyspell[${i}]}].ID} && ${Me.Buff[${clickyspell[${i}]}].Duration}<10 && ${FindItemCount[=${clickyname[${i}]}]} && !${FindItem[=${clickyname[${i}]}].Timer}) {
				/if (${bard}) {
					/if (${Twist}) { 
						/squelch /twist stop 
						/varset wastwisting TRUE
					} 
					/squelch /stopsong 
					/delay 10s !${Me.Casting.ID}
				}
				/if (${clickyspam}) /echo INFO: Clicking...${clickyname[${i}]} ,${clickyfirst[${i}]}/${clickylast[${i}]}
				/casting "${clickyname[${i}]}"|Item
				/call WaitCast
				/delay 5
				/if (${wastwisting} || ${sitmedtwist}) /multiline ; /squelch /twist start ; /varset sitmedtwist FALSE
				/if (${FindItem[=${clickyname[${i}]}].WornSlot[1].Name.Equal[ranged]}) {
					/declare curItem ${InvSlot[mainhand].Item.ID}
					/unequip mainhand
					/exchange ${curItem} mainhand
				}
				/return TRUE
			} else /if (!${Me.Buff[${clickyspell[${i}]}].ID} && ${Me.FreeBuffSlots} && ${FindItemCount[=${clickyname[${i}]}]} && ${Spell[${clickyspell[${i}]}].Stacks} && !${FindItem[=${clickyname[${i}]}].Timer}) {
				/for j ${clickyfirst[${i}]} to ${clickylast[${i}]}
					/if (!${Me.Buff[${j}].Spell.ID}) {
						/if (${bard}) {
							/if (${Twist.Twisting}) { 
								/squelch /twist stop 
								/varset wastwisting TRUE
							} 
							/squelch /stopsong 
							/delay 10s !${Me.Casting.ID}
						}
						/if (${clickyspam}) /echo INFO: Clicking...${clickyname[${i}]} ,${clickyfirst[${i}]}/${clickylast[${i}]}
						/casting "${clickyname[${i}]}"|Item
						/call WaitCast
						/if (${wastwisting} || ${sitmedtwist}) /multiline ; /squelch /twist start ; /varset sitmedtwist FALSE
						/if (${FindItem[=${clickyname[${i}]}].WornSlot[1].Name.Equal[ranged]}) {
							/declare curItem ${InvSlot[mainhand].Item.ID}
							/unequip mainhand
							/exchange ${curItem} mainhand
						}
						/return TRUE
					}
				/next j
			}
		}
	/next i
/return FALSE

Sub Event_SetClicky(string Line)
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp Clicky${Line.Arg[4]}
		/return
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/call ClickyIni
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset clickycount 0
	} else /if (${Line.Arg[3].Equal[SPAM]}) {
		/if (${Line.Arg[4].Equal[ON]}) /varset clickyspam TRUE
		/if (${Line.Arg[4].Equal[OFF]}) /varset clickyspam FALSE 
		/echo INFO: Clicky spam=${clickyspam}!
		/call SetIni Clicky spam ${clickyspam}
	} else /if (${Line.Arg[3].Equal[SET]}) {
		/varset clickyset Clicky
		/if (${Line.Arg[4].Length}) /varset clickyset Clicky${Line.Arg[4]}
		/echo INFO: Clicky Set is now ${clickyset}
		/call SetIni Clicky clickyset ${clickyset}
		/call ClickyIni
	} else /if (${Line.Arg[3].Equal[LIST]}) {
		/declare i int

		/echo INFO: Clicky Set = ${clickyset}
		/echo INFO: Clicky Spam = ${clickyspam}
		/if (${clickycount}) {
			/for i 1 to ${clickycount}
				/echo INFO: ...${clickyname[${i}]} -${clickyfirst[${i}]}/${clickylast[${i}]}/${clickywhen[${i}]} (${clickyzone[${i}]})
			/next i
		}
	} else {
		/declare aliasitem string
		
		/call GetAlias ${Line.Arg[3]}
		/if (${Macro.Return.Equal[NotFound]}) {
			/echo INFO: no alias "${Line.Arg[3]}" found to cast!!!
			/return
		}
		/varset aliasitem ${Macro.Return}

		/if (${FindItem[=${aliasitem}].ID} && !${FindItem[=${aliasitem}].Timer}) {
			/declare old2her int
			/if (${InvSlot[mainhand].Item.ID} && !${InvSlot[offhand].Item.ID} && (${FindItem[${aliasitem}].WornSlot[1]}==13 || ${FindItem[${aliasitem}].WornSlot[1]}==14)) {
				/varset old2her ${InvSlot[mainhand].Item.ID}
				/unequip mainhand
			}
			/casting "${aliasitem}"|Item
			/if (${old2her}) {
				/if (${InvSlot[mainhand].Item.ID}) /unequip mainhand
				/if (${InvSlot[offhand].Item.ID}) /unequip offhand
				/exchange ${old2her} mainhand
			}
		} else /if (${Me.CombatAbility[${aliasitem}]} && !${Me.CombatAbilityTimer[${aliasitem}]}) {
			/docommand /disc ${aliasitem}
			/delay 5s !${Me.Casting.ID}
		} else /if (${Me.AltAbility[${aliasitem}]} && ${Me.AltAbilityReady[${aliasitem}]}) {
			/casting "${aliasitem}"|alt
		} else /if (${Me.Ability[${aliasitem}]} && ${Me.AbilityReady[${aliasitem}]}) {
			/doability ${aliasitem}
			/delay 5s !${Me.Casting.ID}
		} else /if (${Spell[${aliasitem}].ID}) {
			/casting "${aliasitem}"|${buffgem}
		}
		/call WaitCast
	}
/return

Sub Bind_SetMelee(string Line1, string Line2, string Line3, string Line4, string Line5)
	/if (!${Line1.Length} || ${Line1.Equal[HELP]}) {
		/call EchoHelp Melee${Line2}
		/return
	} else /if (${Line1.Equal[ON]}) {
		/varset domelee TRUE
		/echo INFO: Auto Melee Attack is ON!
		/call SetIni Melee active ${domelee}
	} else /if (${Line1.Equal[OFF]}) {
		/varset domelee FALSE
		/echo INFO: Auto Melee Attack is OFF!
		/call SetIni Melee active ${domelee}
	} else /if (${Line1.Equal[PULL]}) {
		/varset autopull ${Line2}
		/echo INFO: AutoPull Range = ${autopull}
	} else /if (${Line1.Equal[STICK]}) {
		/if (${Line2.Equal[ON]}) {
			/varset dostick TRUE 
			/echo INFO: Auto-Sticking target is now ON! 
			/call SetIni Melee stick ${dostick}
		} else /if (${Line2.Equal[OFF]}) {
			/varset dostick FALSE 
			/echo INFO: Auto-Sticking target is now OFF! 
			/call SetIni Melee stick ${dostick}
		} else {
			/varset stickoption ${Line2}
			/call SetIni Melee stickoption ${stickoption}
			/echo INFO: New /stick command = /stick ${stickoption}
		}
	} else /if (${Line1.Equal[RANGE]}) {
		/varset meleerange ${Line2}
		/echo INFO: Initial melee range set at ${meleerange}
		/call SetIni Melee range ${meleerange}
		/if (${Line3.Length}) /varset rngtarget ${Line3} 
		/if (${Line4.Length}) /varset rngtank ${Line4} 
	} else /if (${Line1.Equal[BOW]}) {
		/call ValidateTarget
		/if (${Me.Combat}) /return
		/if (!${validtarget}) {
			/echo Can't Bow.....Invalid Target!
			/return
		} else /if (!${Target.LineOfSight}) {
			/echo Can't Bow.....Line of Sight issues!
			/return
		} else /if (${Target.Distance}>${rangedist}) {
			/echo Can't Bow.....Out of Range!
			/return
		} else /if (${rangeitem} && ${InvSlot[ranged].Item.ID}!=${rangeitem}) {
			/echo Bow Swap....
			/declare current ${InvSlot[ranged].Item.ID}
			/exchange ${rangeitem} ranged
			/range
			/exchange ${current} ranged
		} else {
			/echo Bowing...
			/range
		}
	} else /if (${Line1.Equal[CHICKEN]}) {
		/varset stopfighthealth ${Line2} 
		/echo INFO: Cease Combat when at: ${stopfighthealth}% HP 
		/call SetIni Melee stopfighthealth ${stopfighthealth}
	} else /if (${Line1.Equal[SWITCH]}) {
		/if (${Line2.Equal[ON]}) {
			/varset dotargetswitch TRUE 
			/echo INFO: Auto target switching is now ON! 
			/call SetIni Melee targetswitch ${dotargetswitch}
		} else /if (${Line2.Equal[OFF]}) {
			/varset dotargetswitch FALSE 
			/echo INFO: Auto target swtich is now OFF! 
			/call SetIni Melee targetswitch ${dotargetswitch}
		}
	} else /if (${Line1.Equal[AUTOFIRE]}) {
		/if (${Line2.Equal[ON]}) {
			/varset doautofire TRUE
			/echo INFO: Autofire is now ON!
			/stick off
			/attack off
		} else /if (${Line2.Equal[OFF]}) {
			/varset doautofire FALSE 
			/echo INFO: Autofire is now OFF!
			/autofire off
		}
	} else /if (${Line1.Equal[DYNAMIC]}) {
		/if (${Line2.Equal[ON]}) {
			/varset dodynamicclose TRUE 
			/echo INFO: Dymanic melee range is now ON!
			/call SetIni Melee dynamic ${dodynamicclose}
		} else /if (${Line2.Equal[OFF]}) {
			/varset dodynamicclose FALSE 
			/echo INFO: Dynamic melee range is now OFF!
			/call SetIni Melee dynamic ${dodynamicclose}
		}
	} else /if (${Line1.Equal[ENRAGE]}) {
		/if (${Line2.Equal[ON]}) {
			/varset doenrage TRUE 
			/echo INFO: Enraged Target check is now ON!
			/call SetIni Melee enraged ${doenrage}
		} else /if (${Line2.Equal[OFF]}) {
			/varset doenrage FALSE 
			/echo INFO: Enraged Target check is now OFF!
			/call SetIni Melee enraged ${doenrage}
		}
	} else /if (${Line1.Equal[BS]}) {
		/if (${Line2.Equal[ON]}) {
			/varset autobs TRUE 
			/echo INFO: Auto BackStab is now ON!
		} else /if (${Line2.Equal[OFF]}) {
			/varset autobs FALSE 
			/echo INFO: Auto BackStab is now OFF!
		} else /if (${Line2.Equal[SET]}) {
			/varset bsmainhand ${InvSlot[mainhand].Item.ID}
			/varset bsoffhand ${InvSlot[offhand].Item.ID}
			/call SetIni Melee bsmainhand ${bsmainhand}
			/call SetIni Melee bsoffhand ${bsoffhand}
			/echo INFO: BackStab Weapons set as ${InvSlot[mainhand].Item}/${InvSlot[offhand].Item}
		}
	} else /if (${Line1.Equal[STRIKE]}) {
		/varset strikeendur ${Line2}
		/if (${Line3.Length}) /varset strikedisc ${Line3}
		/call SetIni Melee strikedisc ${strikedisc}
		/call SetIni Melee strikeendur ${strikeendur}
		/echo INFO: Strike disc = ${strikedisc} @ ${strikeendur}% endurance
	}
/return

Sub Event_SetLeash(string Line)
	/if (${Line.Arg[3].Equal[ON]}) {
		/varset doleash TRUE
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset doleash FALSE
	} else {
		/if (${Line.Arg[3].Length}>3) {
			/if (${Spawn[pc ${Line.Arg[3]}].ID}) {
				/varset doleash TRUE
				/varset leashholder ${Line.Arg[3]}
				/if (${Line.Arg[4].Length} && ${Line.Arg[4]}>=10) /varset leashlength ${Line.Arg[4]}
				/if (${Line.Arg[5].Length} && ${Line.Arg[5]}>=5) /varset leashslop ${Line.Arg[5]}
			} else {
				/echo INFO: Can't locate ${Line.Arg[3]} for leashing!
			}
		} else {
			/if (${Line.Arg[4].Length}<4) {
				/varset doleash TRUE
				/varset leashholder nobody
				/if (${Line.Arg[3].Length} && ${Line.Arg[3]}>=10) /varset leashlength ${Line.Arg[3]}
				/if (${Line.Arg[4].Length} && ${Line.Arg[4]}>=5) /varset leashslop ${Line.Arg[4]}
				/varset stakeX ${Me.X} 
				/varset stakeY ${Me.Y} 
			} else {
				/if (${Spawn[pc ${Line.Arg[4]}].ID}) { 
					/varset doleash TRUE
					/varset leashholder ${Line.Arg[4]}
					/if (${Line.Arg[3].Length} && ${Line.Arg[3]}>=10) /varset leashlength ${Line.Arg[3]}
					/if (${Line.Arg[5].Length} && ${Line.Arg[5]}>=5) /varset leashslop ${Line.Arg[5]}
				} else {
					/echo INFO: Can't locate ${Line.Arg[4]} for leashing!
				}
			}
		} 
	}

	/echo INFO: Leashing=${doleash}
	/if (${doleash} && ${leashholder.NotEqual[Nobody]}) {
		/echo INFO: Leashed to ${leashholder}, length=${leashlength} slop=${leashslop}
	} else /if (${doleash} && ${leashholder.Equal[Nobody]}) {
		/echo INFO: Leash stake planted @X:${stakeX},Y:${stakeY}, length=${leashlength} slop=${leashslop}
	}
	/call SetIni General leashholder ${leashholder}
	/call SetIni General leashlength ${leashlength}
	/call SetIni General leashslop ${leashslop}
/return 

Sub Event_SetAssist(string Line) 
	/if (!${Line.Arg[3].Length} || ${Line.Arg[3].Equal[HELP]}) {
		/call EchoHelp AutoAssist${Line.Arg[4]}
		/return
	}
	/if (${Line.Arg[3].Equal[ON]}) { 
		/varset doautoassist TRUE 
		/echo INFO: Auto-Assist is now ON! 
	} else /if (${Line.Arg[3].Equal[OFF]}) { 
		/varset doautoassist FALSE 
		/echo INFO: Auto-Assist is now OFF! 
	} else /if (${Line.Arg[3].Length}<4) {
		/varset assistpct ${Line.Arg[3]}
	} else { 
		/varset doautoassist TRUE 
		/if (${Line.Arg[3].Length}) /varset assistlist ${Line.Arg[3]} 
		/if (${Line.Arg[4].Length}) /varset assistpct ${Line.Arg[4]} 
	}
	/call SetIni General autoassist ${doautoassist}
	/call SetIni General assistlist ${assistlist}
	/call SetIni General assistpct ${assistpct}
	
	/if (${doautoassist}) {
	/echo INFO: Auto-Assisting ${assistlist} @ ${assistpct}
	}
	
	/call AssistIni
/return 

Sub AssistIni
	/declare i int

	/if (!${Defined[doautoassist]}) {
		/declare doautoassist bool outer FALSE
		/declare assistcheck timer outer
		/declare assistlist string outer
		/declare assistpct int outer 95
		/declare assistcur string outer
		/declare assistuse int outer
		/declare assistidle string outer 1m
		/declare assistcorpse string outer 30s
		/declare assistname[10] string outer
		/declare assistx[10] float outer
		/declare assisty[10] float outer
		/declare assistdir[10] float outer
		/declare assistcnt int outer 0
		/for i 1 to 10
			/declare assisttimer${i} timer outer
		/next i
	}

	/call LoadIni General autoassist doautoassist
	/call LoadIni General assistpct assistpct
	/call LoadIni General assistlist assistlist
	/call LoadIni General assistcorpse assistcorpse
	/call LoadIni General assistidle assistidle

	/for i 1 to 10
		/if (!${assistlist.Token[${i},|].Length}) /return
		/varset assistname[${i}] ${assistlist.Token[${i},|]}
		/varset assistx[${i}] 0
		/varset assisty[${i}] 0
		/varset assistdir[${i}] 0
		/varset assisttimer${i} 999m
		/varset assistcnt ${i}
	/next i	
/return

Sub FindAssist
	/declare i int
	/declare rating int 99

	/varset assistcur
	/for i 1 to ${assistcnt}
		/if (!${Spawn[pc ${assistname[${i}]}].ID}) {
			/varset assisttimer${i} 0
		} else {
			/if (${Spawn[corpse ${assistname[${i}]}].ID}) {
				/varset assisttimer${i} ${assistcorpse}
				/if (${rating}>9) {
					/varset assistcur ${assistname[${i}]}
					/varset rating 9
				}
				/goto :nexti
			}

			/if (${Spawn[pc ${assistname[${i}]}].X}==${assistx[${i}]} && ${Spawn[pc ${assistname[${i}]}].Y}==${assisty[${i}]} && ${Spawn[pc ${assistname[${i}]}].Heading.Degrees}==${assistdir[${i}]}) {
				/if (${assisttimer${i}}>10000) /varset assisttimer${i} ${assistidle}
			} else {
				/if (${assisttimer${i}}>10000 || !${assisttimer${i}}) /varset assisttimer${i} 999m
				/varset assistx[${i}] ${Spawn[pc ${assistname[${i}]}].X}
				/varset assisty[${i}] ${Spawn[pc ${assistname[${i}]}].Y}
				/varset assistdir[${i}] ${Spawn[pc ${assistname[${i}]}].Heading.Degrees}
			}
			
			/if (${assisttimer${i}} && ${Spawn[pc ${assistname[${i}]}].Distance}<250 && ${rating}>5) {
				/varset assistcur ${assistname[${i}]}
				/varset rating 5
			}
		}
		:nexti
	/next i
/return

Sub AutoRez
	/if (!${autorez}) /return

	/declare diedzone int ${Zone.ID}
	/doevents flush
	:wait1
	/doevents SetPause
	/delay 2
	/if (!${paused}) /return
	/if (!${Window[ConfirmationDialogBox].Open} && ${Window[RespawnWnd].Open}) /goto :wait1

	/if (${Window[RespawnWnd].Open}) {
		/nomodkey /notify ConfirmationDialogBox Yes_Button leftmouseup
		/delay 2s
		/nomodkey /notify RespawnWnd RW_OptionsList listselect 2
		/delay 1s 
		/nomodkey /notify RespawnWnd RW_SelectButton leftmouseup 
		/delay 5s
		/if (${Me.Class.Name.Equal[Bard]}) {
			/timed 50 /docommand /twist start
		}
		/docommand /mac ZBot
		/call ResetVars
	} else {
		/delay 3m ${Zone.ID}!=${diedzone}
		/call JustZoned
		/delay 5s
		/docommand /ssm normal
		/delay 5m ${Cast.Status.Equal[I]}

		/declare wait timer 60m
		:wait
		/doevents SetPause
		/delay 2
		/if (!${paused}) /return
		/if (!${wait}) /endmac
		/if (!${Window[ConfirmationDialogBox].Open}) /goto :wait
		/delay 5
		/nomodkey /notify ConfirmationDialogBox Yes_Button leftmouseup

		/delay 3m ${Zone.ID}==${diedzone}
		:zoneffs
		/call JustZoned
	}
	/varset paused FALSE
	/doevents flush
/return

Sub AutoRezTwo
	/declare diedzone int ${Zone.ID}
	/doevents flush
	
	:waitreztwo
	/delay 1s
	/if (${Window[RespawnWnd].Open}) /goto :waitreztwo
	
	/if (!${Window[RespawnWnd].Open}) {
		/delay 1s
		/if (${Me.Class.Name.Equal[Bard]}) {
			/timed 50 /docommand /twist start
		}
		/timed 10 /docommand /mac ZBot
		/end
	}
/return

Sub EchoHelp(section)
	/declare s ${section}
	/declare i int

	/if (${s.Right[4].Equal[NULL]}) /varset s ${s.Left[-4]}
	/if (!${Ini[Zbot.ini,${s},1].Length}) {
		/echo INFO: sorry no additional help on that topic.
		/return
	}

	/for i 1 to 500
		/if (!${Ini[Zbot.ini,${s},${i}].Length}) /return
		/echo ${Ini[Zbot.ini,${s},${i}]}
	/next i
/return

Sub ModRodIni
	/declare i int
	/call LoadIni ModRod modrod modrod
	/call LoadIni ModRod modrodspell modrodspell
	/call LoadIni ModRod modrodname modrodname
	/call LoadIni ModRod feedperson feedperson
	/call LoadIni ModRod feedperc feedperc
	/for i 1 to 10
		/call LoadIni ModRod caster${i} modrodcaster[${i}]
		/call LoadIni ModRod tell${i} modrodtell[${i}]
	/next i
/return

Sub DoModRod
	/if (${Cursor.Name.Equal[Summoned: Modulating Rod]} || ${Cursor.Name.Equal[Molten Orb]} || ${Cursor.Name.Equal[Rod of Mystical Transvergence]} || ${Cursor.Name.Equal[Wand of Elemental Transvergence]} || ${Cursor.Name.Equal[Rod of Prime Transvergence]}) {
		/autoinven
		/varset modrodwait 6000
		/varset modrodtimer 0
	}
	/if (!${modrod} || ${Me.Invis} || ${Me.Moving}) /return FALSE

	/if (${FindItemCount[=Summoned: Modulating Rod]}) {
		/if (${Me.PctMana}<${modrod} && !${Me.Casting.ID} && !${FindItem[=Summoned: Modulating Rod].Timer}) {
			/casting "Summoned: Modulating Rod"|item
			/delay 1
			/varset modrodwait 6000
			/varset modrodtimer 0
			/return TRUE
		}
	} else /if (${FindItemCount[=Wand of Elemental Transvergence]}) {
		/if (${Me.PctMana}<${modrod} && !${Me.Casting.ID} && !${FindItem[=Wand of Elemental Transvergence].Timer}) {
			/casting "Wand of Elemental Transvergence"|item
			/delay 1
			/varset modrodwait 6000
			/varset modrodtimer 0
			/return TRUE
		}
	} else /if (${FindItemCount[=Rod of Mystical Transvergence]}) {
		/if (${Me.PctMana}<${modrod} && !${Me.Casting.ID} && !${FindItem[=Rod of Mystical Transvergence].Timer}) {
			/casting "Rod of Mystical Transvergence"|item
			/delay 1
			/varset modrodwait 6000
			/varset modrodtimer 0
			/return TRUE
		}
	} else /if (${Me.Class.Name.Equal[Magician]} && ${modrod}) {
		/if (!${Me.Casting.ID} && ${Me.Class.Name.Equal[Magician]} && !${FindItem[=${modrodname}]} && ${Me.SpellReady[${modrodspell}]}) {
			/target ${Me.Name}
			/delay 1
			/casting "${modrodspell}"|${buffgem}
			/call WaitCast
			/delay 1
		}
	} else /if (!${modrodtimer}) {
		/declare i int

		/for i 1 to 21
			/if (${InvSlot[${i}].Item.ID}) /goto :foundgear
		/next i
		/return FALSE
		:foundgear
		/for i 1 to 10
			/if (${modrodcaster[${i}].Equal[NULL]}) /return FALSE
			/if (${Spawn[pc ${modrodcaster[${i}]} radius 75].ID}) {
				/tell ${modrodcaster[${i}]} ${modrodtell[${i}]}
				/varset modrodtimer ${modrodwait}
				/varcalc modrodwait ${modrodwait}*2
				/return FALSE
			}
		/next i
	}
/return FALSE

Sub DoSitMed
	/if (${sitmedtimer} || ${Me.Moving} || (${Me.Casting.ID} && !${bard}) || ${Me.State.Equal[Feign]}) /return

	/if (${Me.Sitting}) {
		/if (${Me.Class.CanCast}) {
			/if (${Me.PctMana}==100 && ${sitmed}>0 && !${Window[SpellBookWnd]}) {
				/stand
				/varset sitmedtimer 5s
				/return
			}
		} else {
			/if (${Me.PctEndurance}==100 && ${sitmed}>0) {
				/stand
				/varset sitmedtimer 5s
				/return
			}
		}
		/return
	}

	/if ((${Me.Class.CanCast} && ${Me.PctMana}>=${sitmed}) || (!${Me.Class.CanCast} && ${Me.PctEndurance}>=${sitmed})) /return
	/if ((${Me.Casting.ID} && !${bard}) || ${Me.AutoFire} || ${Me.Combat} || (${bard} && ${idle})) /return

	/declare i int 0
	/declare count int ${SpawnCount[NPC radius ${sitmedrange} zradius 30]}

	/if (${count}==0) {
		/if (${bard} && !${Me.Invis}) {
			/if (!${sitmedtwist}) /varset sitmedtwist ${Twist}

			/if (${Me.Gem[${sitmedsong}]}) {
				/if (${Twist}) /multiline ; /squelch /twist stop ; /delay 1s !${Twist}
				/if (${Me.Casting.ID}) /stopsong
					
				/cast ${Me.Gem[${sitmedsong}]}
				/delay 5 ${Me.Casting.ID}==${Spell[${sitmedsong}].ID}
				/delay 30s !${Window[CastingWindow]}
			}
		}
		/sit
		/varset sitmedtimer 5s
		/return
	}

	/for i 1 to ${count}
		/if (${NearestSpawn[${i},NPC].Type.NotEqual[Corpse]}) /return
	/next i

	/sit
	/varset sitmedtimer 5s
/return

Sub DoShrinks
	/declare shrink
	/declare shropt string
	/declare shrtype string
	/declare shrdist int
	/declare i int
	/declare old float
	/declare old2her int 0

	/call GetAlias shrink
	/varset shrink ${Macro.Return}
	/if (${shrink.Equal[NotFound]}) /return

	/if (${FindItemCount[=${shrink}]}) {
		/varset shrtype ${FindItem[${shrink}].Spell.TargetType}
		/varset shropt Item
		/if (${shrtype.Equal[SINGLE]}) {
			/varset shrdist ${FindItem[${shrink}].Spell.Range}
		} else {
			/varset shrdist ${FindItem[${shrink}].Spell.AERange}
		}
		/if (${InvSlot[mainhand].Item.ID} && !${InvSlot[offhand].Item.ID} && (${FindItem[${shrink}].WornSlot[1]}==13 || ${FindItem[${shrink}].WornSlot[1]}==14)) {
			/varset old2her ${InvSlot[mainhand].Item.ID}
			/unequip mainhand
		}
	} else /if (${Me.Book[${shrink}]}) {
		/varset shrtype ${Spell[${shrink}].TargetType}
		/varset shropt ${buffgem}
		/if (${shrtype.Equal[SINGLE]}) {
			/varset shrdist ${Spell[${shrink}].Range}
		} else {
			/varset shrdist ${Spell[${shrink}].AERange}
		}
	} else {
		/return
	}
	
	/if (${shrtype.Equal[SELF]}) {
		/call LoadShrink ${Me.Race.ID}
		:self
		/if (${Me.Height}<=${shrink${Me.Race.ID}}) /goto :doneshrink
		/varset old ${Me.Height}
		/casting "${shrink}"|${shropt}
		:wait1
		/if (${Me.Height}<=${shrink${Me.Race.ID}}) /interrupt
		/delay 2
		/if (${Cast.Status.NotEqual[I]}) /goto :wait1
		/if (${Cast.Result.Equal[CAST_SUCCESS]} && ${old}==${Me.Height}) /call SaveShrink ${Me.Race.ID} ${Me.Height}
		/goto :self
	} else /if (${shrtype.Equal[SINGLE]}) {
		/for i 0 to ${Group}
			/call LoadShrink ${Group.Member[${i}].Race.ID}
			:single
			/if (${Spawn[${Group.Member[${i}].ID}].ID} && ${Group.Member[${i}].Height}>${shrink${Group.Member[${i}].Race.ID}} && ${Group.Member[${i}].Distance}<=${shrdist}) { 
				/varset old ${Group.Member[${i}].Height}
				/casting "${shrink}"|${shropt} -targetid|${Group.Member[${i}].ID}
				:wait2
				/if (${Group.Member[${i}].Height}<=${shrink${Group.Member[${i}].Race.ID}}) /interrupt
				/delay 2
				/if (${Cast.Status.NotEqual[I]}) /goto :wait2
				/if (${Cast.Result.Equal[CAST_SUCCESS]} && ${old}==${Group.Member[${i}].Height}) /Call SaveShrink ${Group.Member[${i}].Race.ID} ${Group.Member[${i}].Height}
				/goto :single
			} 
		/next i
	} else {
		/for i 0 to ${Group}
			/call LoadShrink ${Group.Member[${i}].Race.ID}
			:group
			/if (${Spawn[${Group.Member[${i}].ID}].ID} && ${Group.Member[${i}].Height}>${shrink${Group.Member[${i}].Race.ID}} && ${Group.Member[${i}].Distance}<=${shrdist}) {
				/varset old ${Group.Member[${i}].Height}
				/squelch /target clear
				/casting "${shrink}"|${shropt}
				:wait3
				/if (${Group.Member[${i}].Height}<=${shrink${Group.Member[${i}].Race.ID}}) /interrupt
				/delay 2
				/if (${Cast.Status.NotEqual[I]}) /goto :wait3
				/if (${Cast.Result.Equal[CAST_SUCCESS]} && ${old}==${Group.Member[${i}].Height}) /call SaveShrink ${Group.Member[${i}].Race.ID} ${Group.Member[${i}].Height}
				/goto :group
			}
		/next i
	}
	:doneshrink
	/if (${old2her}) {
		/if (${InvSlot[mainhand].Item.ID}) /unequip mainhand
		/if (${InvSlot[offhand].Item.ID}) /unequip offhand
		/exchange ${old2her} mainhand
	}
/return

Sub LoadShrink(int r)
	/if (!${Defined[shrink${r}]}) /declare shrink${r} float outer 1
	/if (${Ini[ZShrink.ini,${Zone.ShortName},${r}].Length}) /varset shrink${r} ${Ini[ZShrink.ini,${Zone.ShortName},${r}]}
/return

Sub SaveShrink(int r,float height)
	/varset shrink${r} ${height}
	/if (!${Ini[ZShrink.ini,${Zone.ShortName},${r}].Length}) /ini "ZShrink.ini" "${Zone.ShortName}" "${r}" "${height}" 
/return

Sub InGroup(who)
	/declare i int

	/for i 0 to ${Group}
		/if (${Group.Member[${i}].Name.Equal[${who}]}) /return TRUE
	/next i
/return FALSE

Sub FindMsgNum(string msg)
	/declare i int

	/for i 1 to 200
		/if (!${Ini[${Me.Name}Settings.ini,Messages,spell${i}].Length}) /return 0
		/if (${msg.Equal[${Ini[${Me.Name}Settings.ini,Messages,spell${i}]}]}) {
			/if (!${Ini[${Me.Name}Settings.ini,Messages,success${i}].Length} || !${Ini[${Me.Name}Settings.ini,Messages,fail${i}].Length}) {
				/echo ERROR: spell message ${i}=${msg} found, but no success or failure message defined!!!! FIX INI!!!
				/return 0
			}
			/return ${i}
		}
	/next i
/return 0

Sub DisplayMsg(bool spam, string channel, string result, int msgnum, int mobid)
	/declare s string Mana
	/declare c string m
	/if (${Select[${Me.Class.ShortName},WAR,ROG,MNK,BER]}) {
		/varset s Endurance
		/varset c e
	}
	/if (!${msgnum} || ${Spawn[${mobid}].Type.Equal[CORPSE]}) /return
	/if (${Select[${result},CAST_SUCCESS,CAST_TAKEHOLD]}) {
		/if (${spam} && (${channel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${channel} ${Ini[${Me.Name}Settings.ini,Messages,success${msgnum}]}${Spawn[${mobid}].CleanName}
		/if (${EQBC.Connected} && ${bcspam}) {
			/if (${Select[${result},CAST_TAKEHOLD]}) {
				/docommand /${bctell} [+G+]${Ini[${Me.Name}Settings.ini,Messages,success${msgnum}]}${Spawn[${mobid}].CleanName} - <${Me.Pct${s}}${c}>[+x+]
			} else {
				/docommand /${bctell} [+g+]${Ini[${Me.Name}Settings.ini,Messages,success${msgnum}]}${Spawn[${mobid}].CleanName} - <${Me.Pct${s}}${c}>[+x+]
			}
		}
	} else {
		/if (${spam} && (${channel.NotEqual[rsay]} || ${Raid.Members})) /docommand /${channel} ${Ini[${Me.Name}Settings.ini,Messages,fail${msgnum}]}${Spawn[${mobid}].CleanName}
		/if (${EQBC.Connected} && ${bcspam}) {
			/if (${Select[${result},CAST_IMMUNE]}) {
				/docommand /${bctell} [+R+]${Ini[${Me.Name}Settings.ini,Messages,fail${msgnum}]}${Spawn[${mobid}].CleanName} - <${Me.Pct${s}}${c}>[+x+]
			} else {
				/docommand /${bctell} [+r+]${Ini[${Me.Name}Settings.ini,Messages,fail${msgnum}]}${Spawn[${mobid}].CleanName} - <${Me.Pct${s}}${c}>[+x+]
			}
		}
	}
/return

Sub GetAlias(string aliasname)
	/declare i int
	
	/for i 1 to 200
		/if (!${Ini[${Me.Name}Settings.ini,Alias,alias${i}].Length}) /return NotFound
		/if (${Ini[${Me.Name}Settings.ini,Alias,alias${i}].Equal[${aliasname}]}) /return ${Ini[${Me.Name}Settings.ini,Alias,name${i}]}
	/next i
/return NotFound

Sub SaveAlias(string aliasname, string aliasitem)
	/declare i int
	
	/for i 1 to 200
		/if (!${Ini[${Me.Name}Settings.ini,Alias,alias${i}].Length}) {
			/call SetIni Alias alias${i} "${aliasname}"
			/call SetIni Alias name${i} "${aliasitem}"
			/return
		}
		/if (${Ini[${Me.Name}Settings.ini,Alias,alias${i}].Equal[${aliasname}]}) {
			/call SetIni Alias name${i} "${aliasitem}"
			/return
		}
	/next i
/return

Sub CastAlias(string aliasitem}
	/if (${FindItem[=${aliasitem}].ID}) {
		/if (!${FindItem[=${aliasitem}].Timer} && ${Spell[${FindItem[=${aliasitem}].Spell}].Stacks}) {
			/casting "${aliasitem}"|Item
		}
	} else /if (${Me.CombatAbility[${aliasitem}]}) {
		/if (!${Me.CombatAbilityTimer[${aliasitem}]} && ${Spell[${aliasitem}].Stacks}) {
			/docommand /disc ${aliasitem}
			/delay 5s !${Me.Casting.ID}
		}
	} else /if (${Me.AltAbility[${aliasitem}]}) {
		/if (${Me.AltAbilityReady[${aliasitem}]} && ${Spell[${aliasitem}].Stacks}) {
			/casting "${aliasitem}"|alt
		}
	} else /if (${Me.Ability[${aliasitem}]}) {
		/if (${Me.AbilityReady[${aliasitem}]}) {
			/doability ${aliasitem}
		}
	} else /if (${Spell[${aliasitem}].ID}) {
		/if (${Me.SpellReady[${aliasitem}]} && ${Spell[${aliasitem}].Stacks}) {
			/casting "${aliasitem}"|${buffgem}
		}
	}
/return

Sub ListAliases()
	/declare i int
	/declare alias string
	/declare aliasitem string

	/echo INFO: Listing Defined Aliases
	/for i 1 to 200
		/if (!${Ini[${Me.Name}Settings.ini,Alias,alias${i}].Length}) /return
		/varset alias ${Ini[${Me.Name}Settings.ini,Alias,alias${i}]}
		/varset aliasitem ${Ini[${Me.Name}Settings.ini,Alias,name${i}]}
		/if (${FindItem[=${aliasitem}].ID}) {
			/echo INFO ...${alias}=${aliasitem} (ITEM)
		} else /if (${Me.CombatAbility[${aliasitem}]}) {
			/echo INFO ...${alias}=${aliasitem} (CA)
		} else /if (${Me.AltAbility[${aliasitem}]}) {
			/echo INFO ...${alias}=${aliasitem} (AA)
		} else /if (${Me.Ability[${aliasitem}]}) {
			/echo INFO ...${alias}=${aliasitem} (ABILITY)
		} else /if (${Spell[${aliasitem}].ID}) {
			/echo INFO ...${alias}=${aliasitem} (SPELL)
		} else {
			/echo ERROR ...${alias}=${aliasitem} FOUND NO MATCH...FIX YOUR INI
		}
	/next i
/return

Sub WriteDebug(string section, string varname, string varvalue)
	/ini "debug.ini" "${Me.Name}.${section}" "${varname}" "${varvalue}"
/return

Sub WaitCast
	/delay 5
	:top
	/doevents Enraged 
	/doevents NLEnraged 
	/doevents Camping
	/delay 5
	/if (${Cast.Status.NotEqual[I]}) /goto :top
	/delay 5
/return

Sub Event_Camping
	/if (${Me.Mount.ID}) {
		/dismount
		/delay 1s !${Me.Mount.ID}
		/sit
		/delay 1s ${Me.Sitting}
		/camp
		/endmac
	}
	/if (!${Me.Sitting}) {
		/sit
		/delay 1s ${Me.Sitting}
		/camp
	}
	/endmac
/return

Sub Event_Invited
	/invite
/return

Sub Event_Trade
	/notify TradeWnd TRDW_Trade_Button leftmouseup
/return

Sub Event_TaskUpdate(Line,name) 
	/if (${EQBC.Connected} && ${Ini[${Me.Name}Settings.ini,General,taskupdate]}) /docommand /${bctell} [+t+]Task updated...(${name})[+x+]
/return

Sub Event_BackStab(Line,int dmg) 
	/if (!${Defined[maxbsdmg]}) {
		/declare maxbsdmg int outer 0
		/call LoadIni Melee maxbackstab maxbsdmg
	}

	/if (${dmg}>${maxbsdmg}) {
		/varset maxbsdmg ${dmg}
		/call SetIni Melee maxbackstab ${maxbsdmg}
		/if (${EQBC.Connected}) /docommand /${bctell} [+y+]New backstab high=${maxbsdmg}[+x+]
	}  
/return

Sub Event_StopPct(Line,int pct) 
	/varset stoppct ${pct}
	/echo INFO: Stop fight at ${stoppct}%.
/return

Sub WatchMobs
	/declare i int

	/if (${watchlist.Length}) {
		/varset watchtimer 1m
	} else {
		/varset watchtimer 999m
	}
	/for i 1 to 10
		/if (!${watchlist.Token[${i},|].Length}) /return
		/if (${Spawn[${watchlist.Token[${i},|]}].ID} && ${Spawn[${watchlist.Token[${i},|]}].Type.NotEqual[Corpse]}) {
			/if (${EQBC.Connected}) /docommand /bc [+y+]${Spawn[${watchlist.Token[${i},|]}].CleanName} SPAWNED!!![+x+]
			/if (${watchcmd.Length}) /docommand /${watchcmd}
			/varset watchtimer 5m
		}
	/next i
/return

Sub CheckBehind 
	/declare behind FALSE 
	/declare i int
	/declare dir int

	/for i -3 to 3
		/varcalc dir (${Target.Heading.Clock}+${i})%12 
		/if (${dir}<1) /varcalc dir ${dir}+12 
		/if (${dir}>12) /varcalc dir ${dir}-12 
		/if (${dir} == ${Me.Heading.Clock}) /varset behind TRUE 
	/next i    
/return ${behind} 

Sub ListAppendElement(string sList,string sElement,string sDiv) 
	/if (!${Defined[sDiv]}) /declare sDiv string | 
	/if (${${sList}.Length}) { 
		/varset ${sList} ${${sList}}${sDiv}${sElement} 
	} else { 
		/varset ${sList} ${sElement} 
	} 
/return 

Sub LoadIni(string section, string Item, string variable, string default)
	/if (!${Ini[${Me.Name}Settings.ini,${section},${Item}].Length}) {
		/if (${default.Length}) {
			/ini "${Me.Name}Settings.ini" "${section}" "${Item}" "${default}"
			/varset ${variable} ${default}
		}
	} else {
		/varset ${variable} ${Ini[${Me.Name}Settings.ini,${section},${Item}]} 
	}
/return

Sub SetIni(string section, string Item, string value)
	/ini "${Me.Name}Settings.ini" "${section}" "${Item}" "${value}"
/return

Sub Event_SetPause(string Line)
	/if (!${Line.Arg[3].Length}) {
		/if (${paused}) { 
			/varset paused FALSE 
			/echo INFO: ZBot is now RESUMING! 
		} else { 
			/varset paused TRUE 
			/echo INFO: ZBot is now PAUSED! 
		} 
	} else /if (${Line.Arg[3].Equal[ON]}) {
		/varset paused TRUE
		/echo INFO: ZBot is now PAUSED!
	} else /if (${Line.Arg[3].Equal[OFF]}) {
		/varset paused FALSE
		/echo INFO: ZBot is now RESUMING!
	} else {
		/echo ERROR: /pause ${Line.Arg[3]}!
	}
/return 

Sub Event_TooFarAway 
	/if (${dodynamicclose} && !${meleetimer} && ${Stick.Status.Equal[ON]} && ${Stick.Distance}>15) {
		/squelch /stick $[stickoption} ${meleerange}
		/varset meleetimer 5
		/doevents
	} 
/return 

Sub Event_Gating
	/varset gating TRUE
	/timed 30 /varset gating FALSE
/return 

Sub Event_Enraged 
	/varset enraged TRUE 

	/if (${Me.Pet.ID} && ${petcombat}) {
		/declare behind FALSE 
		/declare i int
		/declare dir int
		/for i -3 to 3
			/varcalc dir (${Spawn[${pettarget}].Heading.Clock}+${i})%12 
			/if (${dir}<1) /varcalc dir ${dir}+12 
			/if (${dir}>12) /varcalc dir ${dir}-12 
			/if (${dir}==${Me.Pet.Heading.Clock}) /varset behind TRUE 
		/next i
		/if (!${behind}) {
			/pet back off
			/varset petcombat FALSE
		}
	}
/return

Sub Event_NLEnraged 
	/varset enraged FALSE 
/return 

Sub Event_GainExp(string Line) 
	/varset enraged FALSE
	/if (${Me.Pet.ID}) {
		/squelch /pet ghold on
		/varset petcombat FALSE
	}
/return 

Sub Event_GainSomething(string Line,string text)
	/if (!${EQBC.Connected}) /return

	/if (${Line.Find["ABILITY POINT!"]}) {
		/docommand /${bctell} [+t+]${Me.Name} gained an AA, now has ${Me.AAPoints} unspent![+x+]
	} else /if (${Line.Find[LEVEL]}) {
		/docommand /${bctell} [+t+]${Me.Name} gained a level, now is Level ${Me.Level}![+x+]
	} else /if (${Line.Find[GROUP LEADERSHIP]}) {
		/docommand /${bctell} [+t+]${Me.Name} gained group leadership, now has ${Me.GroupLeaderPoints} unspent![+x+]
	} else /if (${Line.Find[RAID LEADERSHIP]}) {
		/docommand /${bctell} [+t+]${Me.Name} gained raid leadership, now has ${Me.RaidLeaderPoints} unspent![+x+]
	}
/return 

Sub Event_FoodDrink(string Line)
	/if (${fooddrink} || ${paused}) /return
	/if (${EQBC.Connected}) /docommand /${bctell} [+t+]${Me.Name} is out of food/drink![+x+]
	/varset fooddrink 5m
/return 

Sub Event_Component(Line,string comp)
	/if (${component}) /return
	/if (${EQBC.Connected}) /docommand /${bctell} [+t+]${Me.Name} is missing ${comp}![+x+]
	/varset component 1m
/return 

Sub Event_PauseDPS
	/varset dpspaused TRUE
	/if (${Me.Pet.ID}) {
		/pet back off
		/pet ghold on
	}
		/echo INFO: Pausing DPS
/return

Sub Event_ResumeDPS
	/varset dpspaused FALSE
	/echo INFO: Resuming DPS
/return

Sub SpecialZone
/return FALSE

Sub Event_AddMaster(string Line) 
	/declare index int 

	/if (${Line.Arg[3].Length}) { 
		/for index 1 to 20 
			/if (${Ini[${Me.Name}Settings.ini,Masters,Controller${index}].Equal[Nobody]} || !${Ini[${Me.Name}Settings.ini,Masters,Controller${index}].Length}) { 
				/ini "${Me.Name}Settings.ini" "Masters" "Controller${index}" "${Line.Arg[3]}" 
				/echo INFO: ${Line.Arg[3]} added as a master controller... 
				/return
			} 
		/next index 
		/echo INFO: Master controller slots all filled! Get rid of some! 
	} else { 
		/echo ** Huh? 
	} 
/return 

Sub Event_RemMaster(string Line) 
	/declare index int

	/if (${Line.Arg[3].Length}) { 
		/for index 1 to 20 
			/if (${Ini[${Me.Name}Settings.ini,Masters,Controller${index}].Equal[${Line.Arg[3]}]}) { 
				/ini "${Me.Name}Settings.ini" "Masters" "Controller${index}" "Nobody" 
				/echo INFO: ${Line.Arg[3]} removed from master controller list...
				/goto :FallOut 
			} 
		/next index 
		/echo INFO: Can't find ${Line.Arg[3]} in master controller list! 
	} else { 
		/echo ** Huh? 
	} 
	:FallOut 
/return 

Sub Event_Chat(ChatType, Sender, ChatText)
	/varset Sender ${Sender}
	/declare i int
	/declare j int
	/declare k int


	/if (${ChatText.Left[1].Equal[/]}) { 
		/for i 1 to 20 
			/if (${Ini[${Me.Name}Settings.ini,Masters,Controller${i}].Equal[${Sender}]}) {
				/echo INFO: User ${Sender} Authenticated! 
				/echo ACTION: "${ChatText}" 
				/if (${Me.AFK}) /delay 2s 
|				/tell ${Sender} Command received, performing: ${ChatText} 
				/docommand ${ChatText} 
				/return
			}
		/next i 
		/return
	}

	/for i 1 to MAXBUFFTELLS
		/if (${Sender.Equal[${bufftellauth[${i}]}]}) /goto :authorized
		/if (${Spawn[pc ${Sender}].Guild.Equal[${bufftellauth[${i}]}]}) /goto :authorized
	/next i
	/if (${Group}) {
		/for i 1 to ${Group}
			/if (${Sender.Equal[${Group.Member[${i}]}]}) /goto :authorized
		/next i
	}
	/if (${Raid.Members}) {
		/for i 1 to ${Raid.Members}
			/if (${Sender.Equal[${Raid.Member[${i}].Name}]}) /goto :authorized
		/next i
	}
	/return

	:authorized
	/if (${ChatText.Equal[RAIDLEADER]}) {
		/makeraid ${Sender}
		/return
	}

	/if (${ChatText.Arg[1].Equal[PORT]}) {
		/if (${Sender.Equal[${portauth1}]} || ${Sender.Equal[${portauth2}]}) /goto :portauth

		/call InGroup ${Sender}
		/if (!${Macro.Return}) /return

		/for i 1 to MAXBUFFTELLS
			/if (${Sender.Equal[${bufftellauth[${i}]}]}) /goto :portauth
			/if (${Spawn[pc ${Sender}].Guild.Equal[${bufftellauth[${i}]}]}) /goto :portauth
		/next i
		/return

		:portauth
		/for i 1 to 75
			/if (${Ini[Zport.ini,List,alias${i}].Equal[${ChatText.Arg[2]}]}) {
				/for j 1 to 10
					/if (${Ini[Zport.ini,List,port${i}-${j}].Length} && ${Me.Book[${Ini[Zport.ini,List,port${i}-${j}]}]}) {
						/declare port timer 0
						/declare tm int
						/call InGroup ${Sender}
|						/if (!${Macro.Return}) /tell ${Sender} Casting PORT ${Ini[Zport.ini,List,port${i}-${j}]}
						/gsay INCOMING PORT: ${Ini[Zport.ini,List,port${i}-${j}]}
						/if (!${Me.Gem[${Ini[Zport.ini,List,port${i}-${j}]}]}) {
							/memorize "${Ini[Zport.ini,List,port${i}-${j}]}"|${buffgem}
							:waitmem
							/delay 2
							/if (${Cast.Status.NotEqual[I]}) /goto :waitmem
							/if (!${Me.Gem[${Ini[Zport.ini,List,port${i}-${j}]}]}) {
								/docommand /${bctell} [+y+]MEM INTERRUPTED: ${Ini[Zport.ini,List,port${i}-${j}]}[+x+]
								/return
							}
						}
						/delay 1m ${Me.SpellReady[${Ini[Zport.ini,List,port${i}-${j}]}]}
						/casting "${Ini[Zport.ini,List,port${i}-${j}]}"|${buffgem}
						:waitportcast
						/if (!${port} && ${Cast.Timing} && ${EQBC.Connected}) {
							/delay 2
							/varcalc tm ${Cast.Timing}/600
							/docommand /${bctell} [+y+]CASTING PORT: ${Ini[Zport.ini,List,port${i}-${j}]}...${tm} secs left[+x+]
							/varset port 3s
						}
						/if (${Cast.Status.NotEqual[I]}) /goto :waitportcast
						/if (${Cast.Result.NotEqual[CAST_SUCCESS]}) /docommand /${bctell} [+y+]PORT INTERRUPTED: ${Ini[Zport.ini,List,port${i}-${j}]}[+x+]
						/return
					}
				/next j
				/return
			}
		/next i
		/return
	}

	/if (!${Spawn[pc ${Sender}].ID}) /return

	/if (${ChatText.Arg[1].Equal[TL]}) {
		/for i 1 to 75
			/if (${Ini[Zport.ini,List,alias${i}].Equal[${ChatText.Arg[2]}]}) {
				/for j 1 to 10
					/if (${Ini[Zport.ini,List,tl${i}-${j}].Length} && ${Me.Book[${Ini[Zport.ini,List,tl${i}-${j}]}]}) {
|						/tell ${Sender} TL incoming ${Ini[Zport.ini,List,tl${i}-${j}]}
						/call AddBuff ${Spawn[pc ${Sender}].ID} ${Spell[${Ini[Zport.ini,List,tl${i}-${j}]}].ID}
						/return
					}
				/next j
				/return
			}
		/next i
		/return
	}

	/if (${ChatText.Equal[BUFFLIST]}) {
		/for i 1 to MAXBUFFTELLS
			/if (${bufftellalias[${i}].Equal[NULL]}) /return
|			/tell ${Sender} ${bufftellalias[${i}]} = ${bufftellspell[${i}]}
			/delay 2s
		/next i
		/return
	}

	/if (${ChatText.Arg[1].Equal[CURED]}) {
		/call RemoveCure ${Sender} ${ChatText.Arg[2]}
		/return
	}
	/if (${ChatText.Arg[1].Equal[CURE]}) {
		/declare priority int 3
		/if (${ChatText.Arg[3].Length}) {
			/if (${ChatText.Arg[3].Equal[NOW]}) {
				/call DoCureNow ${Sender} ${ChatText.Arg[2]}
				/return
			}
			/varset priority ${ChatText.Arg[3]}
			/call AddCure ${Sender} ${ChatText.Arg[2]} ${priority}
		}
		/return
	}

	/if (${Me.Class.Name.Equal[Necromancer]} && ${ChatText.Find[FEED]}) {
		/for i 1 to 10
			/if (${feedlist[${i}]}==${Spawn[pc ${Sender}].ID}) {
				/varset feedcount[${i}] 10
				/return
			} else /if (!${feedcount[${i}]}) {
				/varset feedlist[${i}] ${Spawn[pc ${Sender}].ID}
				/varset feedcount[${i}] 10
				/return
			}
		/next i
		/return
	}

	/if (${ChatText.Equal[BUFF ME]}) {
		/if (${buffsetsingle.Equal[NULL]}) /return
|		/tell (${Sender}) ${bufftellmsg} (${buffsetsingle})
		/for i 1 to 5
			/if (${Spell[${buffsetsingle.Token[${i},|]}].ID}) /call AddBuff ${Spawn[pc ${Sender}].ID} ${Spell[${buffsetsingle.Token[${i},|]}].ID}
		/next i
		/return
	}
	/if (${ChatText.Equal[BUFF REZ]}) {
		/if (${buffsetrez.Equal[NULL]}) /return
|		/tell ${Sender} ${bufftellmsg} (${buffsetrez})
		/for i 1 to 5
			/if (${Spell[${buffsetrez.Token[${i},|]}].ID}) /call AddBuff ${Spawn[pc ${Sender}].ID} ${Spell[${buffsetrez.Token[${i},|]}].ID}
		/next i
		/return
	}
	/if (${ChatText.Equal[BUFF GROUP]}) {
		/if (${buffsetgroup.Equal[NULL]}) /return
|		/tell ${Sender} ${bufftellmsg} (${buffsetgroup})
		/for i 1 to 5
			/if (${Spell[${buffsetgroup.Token[${i},|]}].ID}) /call AddBuff ${Spawn[pc ${Sender}].ID} ${Spell[${buffsetgroup.Token[${i},|]}].ID}
		/next i
		/return
	}

	/for i 1 to MAXBUFFTELLS
		/for j 1 to 5
			/if (${bufftellalias[${i}].Token[${j},|].Equal[${ChatText.Arg[1]}]} && ${ChatText.Arg[2].Equal[GROUP]}) {
|				/tell ${Sender} ${bufftellmsg} (${bufftellspell[${i}]}) FOR GROUP
				/for k 0 to ${Group}
					/if (${Spawn[${Group.Member[${k}].ID}].ID}) /call AddBuff ${Group.Member[${k}].ID} ${Spell[${bufftellspell[${i}]}].ID}
				/next k
				/return
			} else /if (${bufftellalias[${i}].Token[${j},|].Equal[${ChatText}]}) {
				/if (${FindItemCount[=${bufftellspell[${i}]}]}) {
					/if (${Me.Invis}) /return
|					/tell ${Sender} ${bufftellmsg} (${FindItem[${bufftellspell[${i}]}].Spell})
					/declare oldid ${Target.ID}
					/casting "${bufftellspell[${i}]}"|Item -targetid|${Spawn[pc ${Sender}].ID}
					/call WaitCast
					/target id ${oldid}
					/return
				} else /if (${Me.AltAbility[${bufftellspell[${i}]}]}) {
					/if (${Me.Invis}) /return
					/if (${Me.AltAbilityReady[${bufftellspell[${i}]}]}) {
|						/tell ${Sender} ${bufftellmsg} (${bufftellspell[${i}]})
						/casting "${bufftellspell[${i}]}"|alt -targetid|${Spawn[pc ${Sender}].ID}
						/call WaitCast
						/return
					} else {
|						/tell ${Sender} Ability not ready... (${bufftellspell[${i}]})
						/return
					}
				} else /if (${Spell[${bufftellspell[${i}]}].ID}) {
|					/tell ${Sender} ${bufftellmsg} (${bufftellspell[${i}]})
					/call AddBuff ${Spawn[pc ${Sender}].ID} ${Spell[${bufftellspell[${i}]}].ID}
					/return
				} else {
					/echo ERROR: buff tell ${bufftellalias[${i}]} has no Item/spell/AA valid... 
					/return
				}
			}
		/next j
	/next i
/return 

Sub ResistCast
/return

Sub Event_RangedOnly
		/if (${Me.Class.Name.Equal[Bard]} || ${Me.Class.Name.Equal[Monk]} || ${Me.Class.Name.Equal[Berserker]} || ${Me.Class.Name.Equal[Rogue]} || ${Me.Class.Name.Equal[Ranger]} || ${Me.Class.Name.Equal[Shadow Knight]} || ${Me.Class.Name.Equal[Paladin]} || ${Me.Class.Name.Equal[Beastlord]}) {
			/melee off
		}
/return

Sub Event_GoMelee
		/if (${Me.Class.Name.Equal[Bard]} || ${Me.Class.Name.Equal[Monk]} || ${Me.Class.Name.Equal[Berserker]} || ${Me.Class.Name.Equal[Rogue]} || ${Me.Class.Name.Equal[Ranger]} || ${Me.Class.Name.Equal[Shadow Knight]} || ${Me.Class.Name.Equal[Paladin]} || ${Me.Class.Name.Equal[Beastlord]}) {
			/melee on
			/call LoadIni Melee stickoption stickoption
			/call LoadIni Melee range meleerange
			/echo DEBUG: Melee Restored: ${meleerange} ${stickoption}
			/delay 1
			/stick off
			/attack off
		}
/return

Sub Event_MaxMelee(string Line)
		/if (${Me.Class.Name.Equal[Bard]} || ${Me.Class.Name.Equal[Monk]} || ${Me.Class.Name.Equal[Berserker]} || ${Me.Class.Name.Equal[Rogue]} || ${Me.Class.Name.Equal[Ranger]} || ${Me.Class.Name.Equal[Beastlord]}) {
			/varset meleerange ${Line.Arg[6].Left[-1]}
			/varset stickoption moveback
			/echo DEBUG: Melee Range Set to ${meleerange} ${stickoption}
			/delay 1
			/stick off
			/attack off
		}
/return

Sub Event_SetXP
		/docommand /alt on ${Me.PctExp}
		/echo INFO: Experience to AA set to ${Me.PctExp}
/return

Sub Bind_Gearpets(string Line1, string Line2, string Line3, string Line4, string Line5)
	/declare i int
	/declare k int
	/declare o int
	/declare j int
	
		/echo INFO: Pet Gearing Started!
		/for o 1 to 10
			/delay 1
			/multiline ; /autoinventory ; /keypress esc
		/next k
		
			/delay 2s
			/keypress Shift+B
			/delay 2s
		
		/for i 1 to 5
			/if (!${Line${i}.Length}) /break
				/echo INFO: Attemping to Pet Gear ${Line${i}}
				/if (${FindItemCount[=Summoned: Crystal Belt]}<1) {
					/casting "Summon Crystal Belt"|${petgem}
					/call WaitCast
						/delay 1s
						/autoinventory
				}
				/if (${FindItemCount[=Summoned: Muzzle of Mardu]}<1) {
					/casting "Muzzle of Mardu"|${petgem}
					/call WaitCast
						/delay 1s
						/autoinventory
				}
				/if (${FindItemCount[=Summoned: Dagger of the Deep]}<1) {
					:secondpetweapon
					/casting "Summon Dagger of the Deep"|${petgem}
					/call WaitCast
						/delay 1s
						/autoinventory
			|			/if (${FindItemCount[=Summoned: Blade of the Kedge]}<2) /goto :secondpetweapon
				}
				/if (${FindItemCount[=Summoned: Fireblade]}<1) {
					/casting "Summon Fireblade"|${petgem}
					/call WaitCast
						/delay 1s
						/autoinventory
				}
			/multiline ; /target ${Line${i}} ; /delay 5
				/multiline ; /delay 20 ; /stick 10
			/itemnotify ${FindItem[=Summoned: Dagger of the Deep].InvSlot} leftmouseup
				/click left target
				/delay 5
			/itemnotify ${FindItem[=Summoned: Fireblade].InvSlot} leftmouseup
				/click left target
				/delay 5
			/itemnotify ${FindItem[=Summoned: Muzzle of Mardu].InvSlot} leftmouseup
				/click left target
				/delay 5
			/itemnotify ${FindItem[=Summoned: Crystal Belt].InvSlot} leftmouseup
				/click left target
				/delay 10
					/notify GiveWnd GVW_Give_Button leftmouseup
			/for k 1 to 7
				/delay 1
				/autoinventory
			/next k
		/next i
			/for j 1 to 15
				/delay 1
				/autoinventory
				/keypress esc
			/next j
		/echo INFO: Finished Gearing Pets!
/return

|--------------------- ZControl Impliment Below

Sub Bind_SetDriver(string Line1)
	/if (${Line1.Equal[ON]}) {
		/varset driver TRUE
		/call SetIni General Driver TRUE
		/call LoadDriverSettings
	} else /if (${Line1.Equal[OFF]}) {
		/varset driver FALSE
		/call SetIni General Driver FALSE
		/echo MODE: Bot
	}
/return

Sub Bind_SetTaunt(string Line1)
	/if (${Line1.Equal[ON]}) {
		/varset ztaunt TRUE
		/call SetIni General taunt TRUE
		/echo INFO: Taunting ON!
	} else /if (${Line1.Equal[OFF]}) {
		/varset ztaunt FALSE
		/call SetIni General taunt FALSE
		/echo INFO: Taunting OFF!
	}
/return

Sub Bind_BossMods(string Line1)
	/if (${Line1.Equal[ON]}) {
		/varset bossmods TRUE
		/call SetIni General bossmods TRUE
		/echo INFO: Boss Mods are ON!
	} else /if (${Line1.Equal[OFF]}) {
		/varset bossmods FALSE
		/call SetIni General bossmods FALSE
		/echo INFO: Boss Mods are OFF!
	}
/return

Sub LoadDriverSettings
	/echo MODE: Driver
	/call RaidSetupIni
	/call SingleBuffsIni
	/call BuffGroupIni
	/call AssistSetupIni
	/echo INFO: Driver Settings Loaded.
/return

Sub Bind_SetScan(string Line1,string Line2)
	/if (!${Line1.Length}) {
		/return
	} else /if (${Line1.Equal[ON]}) {
		/varset doscan TRUE
		/varset doleash TRUE
				/varset doleash TRUE
				/varset leashholder nobody
				/varset leashlength 150
				/varset leashslop 30
				/varset stakeX ${Me.X} 
				/varset stakeY ${Me.Y}
					/call LoadIni Scan XYDistance xydistance 50
					/call LoadIni Scan ZDistance zdistance 20
					/call LoadIni Scan MinLevel minlevel 1
					/call LoadIni Scan MaxLevel maxlevel 65
					/call LoadIni Scan StickRange stickrange 8
					/call LoadIni Scan StickMode stickmode moveback
		/echo Scanning Enabled! Level ${minlevel} to ${maxlevel} | XY ${xydistance} | Z ${zdistance} | /stick ${stickrange} ${stickmode}
	} else /if (${Line1.Equal[OFF]}) {
		/varset doscan FALSE
		/varset doleash FALSE
		/echo Scanning Disabled!
	} else /if (${Line1.Equal[MAX]}) {
		/if (${Line2.Length}) /varset maxlevel ${Line2}
		/call SetIni Scan MaxLevel ${Line2}
		/echo SCAN: Maximum Level to Attack = ${maxlevel}
	} else /if (${Line1.Equal[MIN]}) {
		/if (${Line2.Length}) /varset minlevel ${Line2}
		/call SetIni Scan MinLevel ${Line2}
		/echo SCAN: Minimum Level to Attack = ${minlevel}
	} else /if (${Line1.Equal[RANGE]}) {
		/if (${Line2.Length}) /varset xydistance ${Line2}
		/call SetIni Scan XYDistance ${Line2}
		/echo SCAN: X, Y Distance = ${xydistance}
	} else /if (${Line1.Equal[Z]}) {
		/if (${Line2.Length}) /varset zdistance ${Line2}
		/call SetIni Scan ZDistance ${Line2}
		/echo SCAN: Z Axis = ${zdistance}
	} else /if (${Line1.Equal[StickRange]}) {
		/if (${Line2.Length}) /varset stickrange ${Line2}
		/call SetIni Scan StickRange ${Line2}
		/echo SCAN: Stick Range = ${stickrange}
	} else /if (${Line1.Equal[StickMode]}) {
		/if (${Line2.Length})	/varset stickmode ${Line2}
		/call SetIni Scan StickMode ${Line2}
		/echo SCAN: Stick Mode = ${stickmode}
	} else {
		/echo ERROR: /scan ${Line}
	}
/return

Sub DoScan
|	/echo in DoScan
	/if (${Me.Sitting})	/stand
		/if (${Target.DisplayName.Equal[The Performer]}) {
			/attack off
			/target ${Me}
			/goto :scanbottom
			}
		/if (${Target.Type.Equal[NPC]} || ${Target.Type.Equal[Pet]}) {
			/if (${maxlevel}>=68 && ${Target.Level}<=68) {
	|			/squelch /target NPC Range 69 ${maxlevel} radius ${xydistance} zradius ${zdistance}
				}
			/if (!${Me.Combat})	{
				/attack on
				/pet attack
				}
			/if (!${Stick.Active})	{
				/stick ${stickrange} ${stickmode}
				}
		} else /if (!${Target.Type.Equal[NPC]} || !${Target.Type.Equal[Pet]}) {
|			/squelch /target NPC Pet Range 45 58 radius ${xydistance} zradius ${zdistance} LoS
			/squelch /target NPC Range ${minlevel} ${maxlevel} radius ${xydistance} zradius ${zdistance} LoS
			/if (${Me.Combat})	{
				/attack off
				}
			/if (${Stick.Active})	{
				/stick off
				}
		}
		:scanbottom
/return

Sub Bind_DoZSF(string Line1)	
			/varset zstickholder ${Line1}
			/target clear
			/docommand /bca //mqpause ON
				/docommand /bca //stick off
					/docommand /bca //target clear
						/docommand /bca //target ${zstickholder}
				/delay 5
					/echo ZSF Enabled! Driver: ${zstickholder}
						/squelch /docommand /bcaa //keypress HOME
					/docommand /bca //stick 5 underwater
/return

Sub Bind_DoGSF(string Line1)	
			/varset zstickholder ${Line1}
			/target clear
			/docommand /bcg //mqpause ON
				/docommand /bcg //stick off
					/docommand /bcg //target clear
						/docommand /bcg //target ${zstickholder}
				/delay 5
					/echo GSF Enabled! Driver: ${zstickholder}
						/squelch /docommand /bcga //keypress HOME
					/docommand /bcg //stick 5 underwater
/return

Sub Bind_DoZLF(string Line1)
			/varset zstickholder ${Line1}
			/target clear
			/docommand /bca //mqpause ON
				/docommand /bca //stick off
					/docommand /bca //target clear
						/docommand /bca //target ${zstickholder}
				/delay 5
					/echo ZLF Enabled! Driver: ${zstickholder}
						/squelch /docommand /bcaa //keypress HOME
					/docommand /bca //afollow on
/return

Sub Bind_DoClickDoor
			/docommand /bca //doortarget
				/delay 5
			/docommand /bca //click left door
/return

Sub Bind_DoZSay(string Line1, Line2)
		/if (${Me.Class.Name.Equal[Rogue]}) { 
			/if (${Me.Sneaking}) /doability sneak
			/if (${Me.Invis}) /doability hide
		}
		/target clear
		/if (${Me.Sitting}) /stand
			/delay 3
		/if (${Me.Invis}) /attack on
			/delay 3
		/multiline ; /stick off ; /attack off ; /pet back off ; /stopcast ; /pet back off
			/delay 3
			/docommand /target ${Line1}
			/delay 3
			/docommand /say ${Line2}
/return

Sub Bind_DoGLF(string Line1)
			/varset zstickholder ${Line1}
			/target clear
			/docommand /bcg //mqpause ON
				/docommand /bcg //stick off
					/docommand /bcg //target clear
						/docommand /bcg //target ${zstickholder}
				/delay 5
					/echo GLF Enabled! Driver: ${zstickholder}
						/squelch /docommand /bcga //keypress HOME
					/docommand /bcg //afollow on
/return

Sub Bind_ZStop
			/varset doscan FALSE
			/docommand /bca //stick off
			/docommand /bca //afollow off
			/docommand /bca //target clear
				/docommand /bca //mqpause off
				/docommand /bca //leash off
				/squelch /docommand /bcaa //keypress Home
					/echo INFO: Stopping Z Follows!
/return

Sub Bind_GStop
			/varset doscan FALSE
			/docommand /bcg //stick off
			/docommand /bcg //afollow off
			/docommand /bcg //target clear
				/docommand /bcg //mqpause off
				/docommand /bcg //leash off
				/squelch /docommand /bcga //keypress Home
					/echo INFO: Stopping G Follows!
/return

Sub RaidSetupIni(string Line)
	/declare gl int
	/declare p int
	
	/call LoadIni RaidSetup RaidSet raidset
	/call LoadIni RaidSetup RaidLeader raidleader

	/varset partycount 0
	/for p 1 to 72
		/if (${Ini[${Me.Name}Settings.ini,${raidset},party${p}].Length}) {
			/varcalc partycount ${partycount}+1
			/varset party[${partycount}] NULL
			/call LoadIni ${raidset} party${p} party[${partycount}]
		}
	/next p
	/varset groupleadercount 0
	/for gl 1 to 12
		/if (${Ini[${Me.Name}Settings.ini,${raidset},groupleader${gl}].Length})	{
			/varcalc groupleadercount ${groupleadercount}+1
			/varset groupleader[${groupleadercount}] NULL
			/call LoadIni ${raidset} groupleader${gl} groupleader[${groupleadercount}]
		}
	/next gl
/return

Sub Bind_DoFormRaid(string Line1, string Line2, string Line3)
	/declare gl int
	/declare p int
	
		/if (${Line1.Equal[RAID]}) {
			/varset doraid TRUE
			/echo Forming Raid...
		} else /if (${Line1.Equal[GROUP]}) {
			/varset doraid FALSE
			/echo Forming Groups...
		} else /if (${Line1.Equal[SET]}) {
		/varset raidset raidsetup
		/if (${Line2.Length}) /varset raidset Raid${Line2}
		/echo INFO: RaidSetup=${raidset}
		/call SetIni RaidSetup RaidSet ${raidset}
		/call RaidSetupIni
		/return
		}
		/if (${EQBC.Connected}) /docommand /squelch /bcaa //raiddisband
		/if (${EQBC.Connected}) /docommand /squelch /bcaa //disband
		/if (${EQBC.Connected}) /docommand /squelch /bca //mqpause ON
			/delay 2s
			
		/if (${groupleadercount}>=1) {
			/for gl 1 to 1	{
				/for p 1 to 5
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=2) {
			/for gl 2 to 2 {
				/for p 6 to 10
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=3) {
			/for gl 3 to 3 {
				/for p 11 to 15
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=4) {
			/for gl 4 to 4 {
				/for p 16 to 20
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=5) {
			/for gl 5 to 5 {
				/for p 21 to 25
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=6) {
			/for gl 6 to 6 {
				/for p 26 to 30
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=7) {
			/for gl 7 to 7 {
				/for p 31 to 35
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=8) {
			/for gl 8 to 8 {
				/for p 36 to 40
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}		
		/if (${groupleadercount}>=9) {
			/for gl 9 to 9 {
				/for p 41 to 45
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=10) {
			/for gl 10 to 10 {
				/for p 46 to 50
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=11) {
			/for gl 11 to 11 {
				/for p 51 to 55
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
		/if (${groupleadercount}>=12) {
			/for gl 12 to 12 {
				/for p 56 to 60
					/if (${EQBC.Connected}) /squelch /docommand /bct ${groupleader[${gl}]} //invite ${party[${p}]}
				/next p
			}
		}
				/delay 2s
					/if (${EQBC.Connected})	/squelch /bcaa //target clear
					/if (${EQBC.Connected}) /squelch /bcaa //invite
			/if (!${doraid})	{
					/delay 2s
					/if (${EQBC.Connected}) /squelch /bca //mqpause OFF
					/echo ...Groups Formed!
					/return
			}
			/if (${doraid})	{
				/for gl 1 to ${groupleadercount}
					/if (${EQBC.Connected}) /docommand /squelch /bct ${groupleader[${gl}]} //nomodkey /notify ConfirmationDialogBox No_Button leftmouseup
					/if (${EQBC.Connected}) /docommand /squelch /bct ${groupleader[${gl}]} //nomodkey /notify ConfirmationDialogBox No_Button leftmouseup
					/if (${EQBC.Connected}) /docommand /squelch /bct ${groupleader[${gl}]} //nomodkey /notify ConfirmationDialogBox No_Button leftmouseup
				/next gl
			/for gl 1 to ${groupleadercount}
					/if (${EQBC.Connected}) /docommand /squelch /bct ${raidleader} //raidinvite ${groupleader[${gl}]}
					/delay 2s
					/if (${EQBC.Connected}) /squelch /bct ${groupleader[${gl}]} //raidaccept
				/next gl
					/delay 2s
					/if (${EQBC.Connected}) /squelch /bca //mqpause OFF
					/echo ...Raid Formed!
			}	
/return

Sub BuffGroupIni(string Line)
	/declare b int
	/declare gs int

	/varset groupbuffercount 0
	/for b 1 to 10
		/if (${Ini[${Me.Name}Settings.ini,BuffGroup,groupbuffer${b}].Length}) {
			/varcalc groupbuffercount ${groupbuffercount}+1
			/varset groupbuffer[${groupbuffercount}] NULL
			/call LoadIni BuffGroup groupbuffer${b} groupbuffer[${groupbuffercount}]
		}
	/next b
	/varset groupsendercount 0
	/for gs 1 to 10
		/if (${Ini[${Me.Name}Settings.ini,BuffGroup,groupsender${gs}].Length})	{
			/varcalc groupsendercount ${groupsendercount}+1
			/varset groupsender[${groupsendercount}] NULL
			/call LoadIni BuffGroup groupsender${gs} groupsender[${groupsendercount}]
		}
	/next gs
/return

Sub Event_DoBuffGroup(string Line)
	/declare b int
	/declare gs int
	
	/for gs 1 to ${groupsendercount}	{
		/for b 1 to ${groupbuffercount}
			/if (${EQBC.Connected}) /docommand /bct ${groupsender[${gs}]} //t ${groupbuffer[${b}]} Buff Group
				/next b
			}
		/next gs
/return

Sub Event_DoSingleBuffs(string Line)
	/declare i int
	
	/for i 1 to ${singlebuffcount}
		/if (${EQBC.Connected}) /docommand /bct ${sender[${i}]} //t ${buffer[${i}]} ${alias[${i}]}	
	/next i
/return

Sub SingleBuffsIni(string Line)
	/declare i int
	
	/varset singlebuffcount 0
	/for i 1 to 20
		/if (${Ini[${Me.Name}Settings.ini,SingleBuffs,sender${i}].Length})	{
			/varcalc singlebuffcount ${singlebuffcount}+1
			/varset sender[${singlebuffcount}]
			/varset buffer[${singlebuffcount}]
			/varset alias[${singlebuffcount}]
			/call LoadIni SingleBuffs sender${i} sender[${singlebuffcount}]
			/call LoadIni SingleBuffs buffer${i} buffer[${singlebuffcount}]
			/call LoadIni SingleBuffs alias${i} alias[${singlebuffcount}]
		}
	/next i
/return

Sub Bind_DoRaidBuffs(string Line1)
	/call Event_DoBuffGroup
	/call Event_DoSingleBuffs
		/timed 15 /echo Calling for Raid Buffs...
/return

Sub AssistSetupIni(string Line)
	/declare o int
	
	/varset offcount 0
	/for o 1 to 20
		/if (${Ini[${Me.Name}Settings.ini,AssistSetup,off${o}].Length})	{
			/varcalc offcount ${offcount}+1
			/varset off[${offcount}] NULL
			/call LoadIni AssistSetup off${o} off[${offcount}]
		}
	/next o
/return

Sub Bind_DoAssistSetup(string Line1, string Line2)
	/declare o int
	
		/if (${Line1.Length} && !${Line2.Length}) {
			/varset mainassist ${Line1}
				/call SetIni AssistSetup MainAssist ${Line1}
				/if (${EQBC.Connected}) /docommand /bca //autoassist ${Line1} ${percent}
					/delay 2
					/echo Main Assist: ${Line1} ${percent}
		}
		/if (${Line2.Length}) {
			/varset mainassist ${Line1}
				/call SetIni AssistSetup MainAssist ${Line1}
				/if (${EQBC.Connected}) /docommand /bca //autoassist ${Line1} ${Line2}
					/delay 2
					/varset percent ${Line2}
					/call SetIni AssistSetup Percent ${percent}
					/echo Main Assist: ${Line1} ${Line2}
		}
		/if (${EQBC.Connected}) {
			/for o 1 to ${offcount}
				/if (${EQBC.Connected}) /squelch /docommand /bct ${off[${o}]} //autoassist OFF
			/next o
		}
/return

Sub Bind_DoReBuff(string Line1)
	/declare b int
	
	/for b 1 to ${groupbuffercount}
		/if (${EQBC.Connected}) /docommand /bct ${Line1} //t ${groupbuffer[${b}]} Buff Me
			/next b
/return

Sub Bind_ZDrag
	/declare list string
	/declare count int
	/declare i int
	/declare pccount int 0
	
	/varset count ${SpawnCount[corpse radius 100 zradius 75]} 
	/if (${count}) {
		/for i 1 to ${count} 
			/if (${Spawn[${NearestSpawn[${i},corpse radius 100 zradius 75].ID}].Deity.ID}) {
				/varset list ${list}${NearestSpawn[${i},corpse radius 100 zradius 75].ID}|
				/varcalc pccount ${pccount}+1
			}
		/next i
	}
	
	/docommand /echo Dragging ${pccount} Corpses...

	/for i 1 to 100
		/if (!${list.Token[${i},|].Length}) /return
		/if (${Window[RespawnWnd].Open}) /return
		/if (${Spawn[${list.Token[${i},|]}].ID}) {
			/target id ${list.Token[${i},|]}
			/docommand /corpse
		}
	/next i
/return

Sub Bind_TargetBuff(string Line1, string Line2, string Line3, string Line4, string Line5)
		/declare j int
		/declare i int
		
		/for i 1 to 5
			/if (!${Line${i}.Length}) /break
			/echo INFO: Single Buffing ${Line${i}}
			/if (${buffsetsingle.Equal[NULL]}) /return
			/for j 1 to 5
				/if (${Spell[${buffsetsingle.Token[${j},|]}].ID}) /call AddBuff ${Spawn[${Line${i}}].ID} ${Spell[${buffsetsingle.Token[${j},|]}].ID}
			/next j
		/next i
		/return
/return

Sub Bind_GroupBuff(string Line1, string Line2, string Line3, string Line4, string Line5)
		/declare j int
		/declare i int
		
		/for i 1 to 5
			/if (!${Line${i}.Length}) /break
			/echo INFO: Group Buffing ${Line${i}}
			/if (${buffsetgroup.Equal[NULL]}) /return
			/for j 1 to 5
				/if (${Spell[${buffsetgroup.Token[${j},|]}].ID}) /call AddBuff ${Spawn[${Line${i}}].ID} ${Spell[${buffsetgroup.Token[${j},|]}].ID}
			/next j
		/next i
		/return
/return

Sub Bind_CheckBuffs
/return

