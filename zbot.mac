Sub Event_PerfSethTwo
	/if (!${bossmods}) /return
		/varset perfsong It's a long winter in the swirling chaotic void.
		/varset perftarget Seth Kimble
		/echo BOSSMODS: Emote Acquired - ${perftarget} + ${perfsong}
		/delay 5
		/call Event_PerfDoEmote
/return

