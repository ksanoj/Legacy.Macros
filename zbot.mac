|------- Mayong

Sub Event_MayongBackOut
	/if (!${bossmods}) /return
		/if (${Me.Class.Name.Equal[Bard]} || ${Me.Class.Name.Equal[Monk]} || ${Me.Class.Name.Equal[Berserker]} || ${Me.Class.Name.Equal[Rogue]} || ${Me.Class.Name.Equal[Ranger]} || ${Me.Class.Name.Equal[Beastlord]}) {
			/multiline ; /stick off ; /attack off ; /pet back off ; /varset mayongdanger TRUE
			/moveto loc 2895 -625 471
			/echo BOSSMODS: Moving Away from Mayong...
			/delay 10
		}
/return

Sub Event_MayongBackIn
	/if (!${bossmods}) /return
		/varset mayongdanger FALSE
		/echo BOSSMODS: Resuming Combat with Mayong...
/return

Sub Event_MayongBOTimer
	/if (!${bossmods}) /return
		/timed 125 /varset mayongdanger FALSE
		/timed 125 /echo BOSSMODS: Resuming Combat with Mayong...
		/echo BOSSMODS: Setting Timer for Back In!
/return

Sub Event_MayongBaneNow(string Line)
	/if (!${bossmods}) /return
	/if (!${Line.Arg[6].Equal[${Me.Name}]}) /return
		/bandolier Activate Mayong
		/if (${Me.Class.Name.Equal[Bard]}) {
			/echo BARD: Stopping Twist!
			/twist stop
			/delay 10
		}
		/multiline ; /stick off ; /attack off ; /pet back off ; /stopcast
		/delay 7
		/if (${Me.Class.Name.Equal[Beastlord]} || ${Me.Class.Name.Equal[Bard]}) /varset mayongbaneitem Gold Chime of Resonance
		/if (${Me.Class.Name.Equal[Monk]} || ${Me.Class.Name.Equal[Necromancer]}) /varset mayongbaneitem Bloodstained Mirror
		/if (${Me.Class.Name.Equal[Rogue]} || ${Me.Class.Name.Equal[Enchanter]}) /varset mayongbaneitem Jagged Silver Shortsword
		/if (${Me.Class.Name.Equal[Shadow Knight]} || ${Me.Class.Name.Equal[Berserker]}) /varset mayongbaneitem Dalur Ak-Daal
		/if (${Me.Class.Name.Equal[Wizard]} || ${Me.Class.Name.Equal[Magician]}) /varset mayongbaneitem Firestarter Wand
		/if (${Me.Class.Name.Equal[Cleric]} || ${Me.Class.Name.Equal[Paladin]}) /varset mayongbaneitem Vial of Blessed Water
		/if (${Me.Class.Name.Equal[Warrior]} || ${Me.Class.Name.Equal[Ranger]}) /varset mayongbaneitem Vampire Killer
		/if (${Me.Class.Name.Equal[Druid]} || ${Me.Class.Name.Equal[Shaman]}) /varset mayongbaneitem Glimmering Dawnstone
			/echo BOSSMODS: Attempting to Bane at ${Line.Arg[7]} with ${mayongbaneitem}
				/target ${Line.Arg[7]}
					/delay 5
				/casting "${mayongbaneitem}"
				/call WaitCast
		/bandolier Activate Normal
		/if (${Me.Class.Name.Equal[Bard]}) {
			/echo BARD: Restarting Twist!
			/delay 10
			/twist start
		}
	/echo BOSSMODS: Finished with Bane!
/return