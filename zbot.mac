Sub Event_PerfDoEmote
	/if (!${bossmods}) /return
		/if (${Me.Class.Name.Equal[Warrior]}) /return
		/if (${Me.Class.Name.Equal[Shadow Knight]}) /return
		/if (${Me.Class.Name.Equal[Paladin]}) /return
		/multiline ; /stick off ; /attack off ; /pet back off ; /stopcast
		/echo BOSSMODS: Emote - ${perftarget} + ${perfsong}
		/if (${Me.Class.Name.Equal[Rogue]} && ${Me.Sneaking}) /doability sneak
		
		:perfstart
		/target ${perftarget}
		/delay 5
		/if (${Target.DisplayName.NotEqual[${perftarget}]}) /goto :perfstart
		/if (${Target.DisplayName.Equal[${perftarget}]}) /nav target
			/delay 15
		/if (${Target.DisplayName.NotEqual[${perftarget}]}) /goto :perfstart
		/if (${Target.Distance}>=15) /goto :perfstart
			/delay 5
			/say ${perfsong}
			/delay 2s
			/target clear
			/varset perfsong Nothing
			/varset perftarget Nobody
		/if (${Navigation.Active}) /nav stop
/return

